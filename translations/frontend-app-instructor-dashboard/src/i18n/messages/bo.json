  "instruct.courseTeam.roles.limitedStaff": "ལས་བྱེད་ཀྱི་ཚད་བཀག་ཟིན་པ།",
  "instruct.courseTeam.roles.limitedStaffDescription": "ལས་བྱེད་པ་ཚད་གཞི་ཅན་གྱི་སློབ་ཚན་གྱི་རུ་ཁག་གི་ཚོགས་མི་ཚོས་ཁྱེད་ཀྱི་སློབ་ཚན་འཛིན་སྐྱོང་བྱེད་པར་རོགས་རམ་བྱེད། ལས་བྱེད་ཚད་གཞི་ཅན་གྱིས་སློབ་ཕྲུག་ཐོ་འགོད་དང་ཐོ་འགོད་མེད་པར་བཟོ་ཐུབ་པ་དང་། དེ་བཞིན་ཁོང་ཚོའི་གྲུབ་འབྲས་བསྒྱུར་བཅོས་བྱེད་ཐུབ་པ་དང་སློབ་ཚན་གྱི་གནས་ཚུལ་ཚང་མ་འཛུལ་ཐུབ། ལས་བྱེད་ཚད་གཞི་ཅན་ཚོས་ཁྱེད་ཀྱི་སློབ་ཚན་དེ་སློབ་ཁང་ནང་དུ་འཛུལ་ཐུབ་ཀྱི་མེད། སློབ་ཚན་ནང་ད་དུང་ཐོ་འགོད་མ་བྱས་པའི་སྤྱོད་མཁན་གང་རུང་ཞིག་ཚད་གཞི་ཅན་གྱི་ལས་བྱེད་དུ་ཁ་སྣོན་བྱེད་སྐབས་རང་འགུལ་གྱིས་ཐོ་འགོད་བྱེད།",
  "instruct.courseTeam.roles.staff": "ལས་བྱེད།",
  "instruct.courseTeam.roles.staffDescription": "ལས་བྱེད་པའི་འགན་འཁུར་བའི་སློབ་ཚན་གྱི་རུ་ཁག་གི་ཚོགས་མི་ཚོས་ཁྱེད་ཀྱི་སློབ་ཚན་འཛིན་སྐྱོང་བྱེད་པར་རོགས་རམ་བྱེད། ལས་བྱེད་པས་སློབ་མ་ཐོ་འགོད་དང་ཐོ་འགོད་མེད་པར་བཟོ་ཐུབ་པ་དང་། དེ་བཞིན་ཁོང་ཚོའི་གྲུབ་འབྲས་བསྒྱུར་བཅོས་བྱེད་ཐུབ་པ་དང་སློབ་ཚན་གྱི་གནས་ཚུལ་ཚང་མ་འཛུལ་ཐུབ། ལས་བྱེད་པ་རྣམས་ཀྱིས་ཁྱེད་ཀྱི་སློབ་ཚན་དེ་སློབ་ཁང་དང་ཤེས་རྟོགས་ནང་དུ་འཛུལ་ཐུབ། སློབ་ཚན་ནང་ད་དུང་ཐོ་འགོད་མ་བྱས་པའི་སྤྱོད་མཁན་གང་རུང་ལས་བྱེད་དུ་ཁ་སྣོན་བྱེད་སྐབས་རང་འགུལ་གྱིས་ཐོ་འགོད་བྱེད།",
