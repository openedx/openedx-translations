msgstr "Skonfiguruj interfejsy API, które będą używane do pobierania danych."

#: apps/core/admin.py:53
msgid "Marketing Site Configuration"
msgstr "Konfiguracja witryny marketingowej"

#: apps/core/admin.py:54
msgid ""
"Configure the marketing site URLs that will be used to retrieve data and "
"create URLs."
msgstr ""
"Skonfiguruj adresy URL witryn marketingowych, które będą używane do "
"pobierania danych i tworzenia adresów URL."

#: apps/core/admin.py:58
msgid "Analytics Configuration"
msgstr "Konfiguracja analityki"

#: apps/core/admin.py:59
msgid ""
"Configure the analytics API that will be used to retrieve enrollment data"
msgstr ""
"Skonfiguruj interfejs API analizy, który będzie używany do pobierania danych"
" rejestracji"

#. Translators: 'period_choices' is a list of possible values, like ('second',
#. 'minute', 'hour')
