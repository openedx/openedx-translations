#: apps/api/filters.py:48
#, python-brace-format
msgid "No user with the username [{username}] exists."
msgstr "Nie istnieje żaden użytkownik o nazwie [ {username} ]."

#: apps/api/filters.py:51
msgid ""
"Only staff users are permitted to filter by username. Remove the username "
"parameter."
msgstr ""
"Tylko pracownicy mogą filtrować według nazwy użytkownika. Usuń parametr "
"nazwy użytkownika."

#: apps/api/serializers.py:850
msgid "Number of courses contained in this catalog"
msgstr "Liczba kursów zawartych w tym katalogu"

