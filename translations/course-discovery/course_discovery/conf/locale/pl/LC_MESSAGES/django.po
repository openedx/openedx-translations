#: apps/course_metadata/templates/course_metadata/email/go_live.html:17
#: apps/course_metadata/templates/course_metadata/email/go_live.txt:7
#, python-format
msgid ""
"The About page for the %(course_run_number)s course run of %(course_name)s "
"has been submitted for publishing. The new session will appear on the edX "
"website following the next couple of deployments—typically within 24 to 48 "
"business hours."
msgstr ""
"Strona O Stronie dla edycji kursu %(course_run_number)s o nazwie "
"%(course_name)s została przesłana do opublikowania. Nowa sesja pojawi się na"
" stronie edX po kolejnych wdrożeniach — zazwyczaj w ciągu 24 do 48 godzin "
"roboczych."

#: apps/course_metadata/templates/course_metadata/email/go_live.txt:11
msgid ""
"Note: This is a no-reply email. For any questions or comments, please "
"contact your Project Coordinator at"
msgstr ""
"Uwaga: To jest e-mail, na który nie można odpowiadać. W przypadku pytań lub "
"komentarzy prosimy o kontakt z Koordynatorem Projektu pod adresem"
