#: apps/api/filters.py:48
#, python-brace-format
msgid "No user with the username [{username}] exists."
msgstr "მომხმარებელი მომხმარებლის სახელით [{username}] არ არსებობს."

#: apps/api/filters.py:51
msgid ""
"Only staff users are permitted to filter by username. Remove the username "
"parameter."
msgstr ""
"მომხმარებლის სახელით გაფილტვრის უფლება მხოლოდ თანამშრომლებს აქვთ. წაშალეთ "
"მომხმარებლის სახელის პარამეტრები."

