#: models.py:39
msgid "Display Correctness?"
msgstr "გაჩვენოთ სწორია თუ არა?"

#: models.py:49
msgid "Display Other Student Responses"
msgstr "სხვა სტუდენტების პასუხების ჩვენება"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr "აჩვენებს სტუდენტს სხვათა პასუხებს მას შემდეგ, რაც საკუთარს გაგზავნის."

#: models.py:60
msgid "System selected answers to give to students"
msgstr "სისტემის მიერ შერჩეული პასუხები სტუდენტებისთვის მისაცემად"

#: models.py:63
msgid "Display Name"
msgstr "ხილვადი სახელი"

#: models.py:65
msgid "This is the title for this question type"
msgstr "ეს არის ამ ტიპის კითხვის სათაური"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "სრული კრედიტის მქონე ძირითადი ფრაზები"

#: models.py:121
msgid "Prompt"
msgstr "მინიშნება"

#: models.py:140
msgid "Weight"
msgstr "წონა"

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "მიმდინარეობს შემოწმება..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "გაგზავნა"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "შენახვა"

#: templates/view.html:34
msgid "Hide"
msgstr "დამალვა"

#: templates/view.html:35
msgid "Show"
msgstr "ჩვენება"

#: templates/view.html:36
msgid "peer responses"
msgstr "თანაკურსელების პასუხები"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "სხვების მიერ წარდგენილი"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "ამ დროისთვის პასუხები არ არის ხილული"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} წერტილი შესაძლებელია"
msgstr[1] "{weight} შესაძლო ქულა"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string} / {weight} წერტილი"
msgstr[1] "{score_string} / {weight} ქულა"

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "თქვენ გამოიყენეთ {count_attempts} {max_attempts} TXEND."
msgstr[1] ""
"თქვენ გამოიყენეთ {count_attempts} წარდგენის მაქსიმუმ რაოდენობიდან "
"{max_attempts} "

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "თქვენი პასუხი უნდა იყოს {min} და {max} ს შორის."
msgstr[1] "თქვენი პასუხი უნდა იყოს {min} და {max} სიტყვებს შორის."

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "არასწორი სიტყვების რაოდენობა. {word_count_message}"
