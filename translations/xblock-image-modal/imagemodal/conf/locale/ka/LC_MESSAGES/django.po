#: models.py:25
msgid "Display Name"
msgstr "ხილვადი სახელი"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "ეს არის XBlock-ის საჩვენებელი სახელი"

#: models.py:32
msgid "Image URL"
msgstr "სურათის URL"

#: models.py:41
msgid "This is the location of the full-screen image to be displayed."
msgstr "ეს არის სრულეკრანიან გამოსახულებაზე გამოსაჩენი ადგილი."

#: models.py:46
msgid "Thumbnail URL"
msgstr "მინიატურული URL"

#: models.py:50
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr ""
"ეს არის მინიატურული სურათის (არასავალდებულო) მდებარეობა, რომელიც უნდა "
"გამოისახოს მთავარი სურათის გადიდებამდე."

#: models.py:56
msgid "Description"
msgstr "აღწერა"

#: models.py:59
msgid "Description text, displayed to screen readers"
msgstr "აღწერილობის ტექსტი, რომელიც ეკრანის წამკითხველებისთვის არის ნაჩვენები"

#: models.py:64
msgid "Alt Text"
msgstr "ალტერნატიული ტექსტი"

#: models.py:68
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr ""
"ეს ველი საშუალებას გაძლევთ დაამატოთ ალტერნატიული ან აღწერითი ტექსტი, რომელიც"
" თქვენს სურათს ეხება."

#: templates/view.html:15
msgid "Fullscreen"
msgstr "სრულეკრანიანი რეჟიმი"

#: templates/view.html:25
msgid "Zoom In"
msgstr "გამოსახულების გადიდება"

#: templates/view.html:29
msgid "Close"
msgstr "დახურვა"
