#. youtube
#: cms/djangoapps/contentstore/video_storage_handlers.py:133
msgid "YouTube Duplicate"
msgstr "Створити копію на YouTube"

#: cms/lib/xblock/upstream_sync.py:72
msgid "Content is not linked to a Content Library."
msgstr "Контент не пов'язаний з контентом бібліотеки."

#: cms/lib/xblock/upstream_sync.py:255
msgid "Downstream is not an XBlock or is missing required UpstreamSyncMixin"
msgstr "Downstream не є XBlock або відсутній необхідний UpstreamSyncMixin"

#: cms/lib/xblock/upstream_sync.py:269
msgid "Reference to linked library item is malformed"
msgstr "Посилання на елемент бібліотеки є некоректним"

#: cms/lib/xblock/upstream_sync.py:275
msgid ""
"Updating content with children is not yet supported unless the upstream is a"
" container."
msgstr ""
"Оновлення контенту за допомогою дітей поки що не підтримується, якщо "
"висхідним потоком не є контейнер."

#: cms/lib/xblock/upstream_sync.py:281
msgid "Linked upstream library block was not found in the system"
msgstr "Пов'язаний з висхідним потоком блок бібліотеки не знайдено в системі"

#: cms/lib/xblock/upstream_sync.py:288
msgid "Linked upstream library container was not found in the system"
msgstr "Пов'язаний контейнер бібліотеки вище за течією не знайдено в системі"

#: cms/lib/xblock/upstream_sync.py:301
#, python-brace-format
msgid ""
"Content type mismatch: {downstream_id} ({downstream_type}) cannot be linked "
"to {upstream_id}."
msgstr ""
"Невідповідність типів контенту: {downstream_id} ({downstream_type}) не може "
"бути пов'язано з {upstream_id}."

#: cms/lib/xblock/upstream_sync_block.py:108
msgid "Linked library item could not be loaded: {}"
msgstr "Не вдалося завантажити елемент бібліотеки: {}"

#: common/djangoapps/course_modes/models.py:94
msgid "Lock upgrade deadline date"
msgstr "Заблокувати дедлайн оновлення"

#: common/djangoapps/course_modes/models.py:96
msgid ""
"OPTIONAL: Set to True to lock in the explicitly defined upgrade deadline "
"date. Set to False if there is no upgrade deadline or to use the default "
"upgrade deadline."
msgstr ""
"НЕОБОВ'ЯЗКОВИЙ: установіть значення на \"Правильно\", щоб зафіксувати чітко "
"визначений дедлайн оновлення. Встановіть значення на \"ХИБНИЙ\", якщо немає "
"дедлайну оновлення або щоб використовувати дедлайн за замовчуванням."

#: common/djangoapps/course_modes/models.py:133
msgid ""
"OPTIONAL: This is the Android SKU registered on play store for this mode of "
"the course. Leave this blank if the course has not yet been migrated to the "
"ecommerce service."
msgstr ""
"НЕОБОВ'ЯЗКОВИЙ: Це ідентифікаційний номер Android, зареєстрований у Play "
"Store для цього режиму курсу. Залиште це поле порожнім, якщо курс ще не "
"перенесено до служби електронної комерції."

#: common/djangoapps/course_modes/models.py:145
msgid ""
"OPTIONAL: This is the iOS SKU registered on app store for this mode of the "
"course.  Leave this blank if the course has not yet been migrated to the "
"ecommerce service."
msgstr ""
"НЕОБОВ'ЯЗКОВИЙ: Це ідентифікаційний номер iOS, зареєстрований у AppStore для"
" цього режиму курсу. Залиште це поле порожнім, якщо курс ще не перенесено до"
" служби електронної комерції."

#: common/djangoapps/course_modes/models.py:258
#, python-brace-format
msgid ""
"The {course_mode} course mode has a minimum price of {min_price}. You must "
"set a price greater than or equal to {min_price}."
msgstr ""
"Режим курсу {course_mode} має мінімальну ціну {min_price}. Ви повинні "
"встановити ціну, більшу або рівну {min_price}."

#: common/djangoapps/student/admin.py:657
#, python-format
msgid "%(count)d student account was unlocked."
msgid_plural "%(count)d student accounts were unlocked."
msgstr[0] "%(count)d обліковий запис студента розблоковано."
msgstr[1] "%(count)d облікові записи студентів розблоковано."
msgstr[2] "%(count)d облікові записи студентів розблоковано."
msgstr[3] "%(count)dоблікових записів студентів було розблоковано."

#: common/djangoapps/student/admin.py:714
#, python-brace-format
msgid ""
"Please add a key/value 'THIRD_PARTY_AUTH_ONLY_DOMAIN/{site_email_domain}' in"
" SiteConfiguration model's site_values field."
msgstr ""
"Будь ласка, додайте ключ/значення "
"'THIRD_PARTY_AUTH_ONLY_DOMAIN/{site_email_domain}' у поле site_values моделі"
" SiteConfiguration."

#: common/djangoapps/student/models/course_enrollment.py:1763
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     user_id, username, email, course_id, "
"is_verified, verification_date"
msgstr ""
"Очікується, що дані будуть надані у форматі CSV-файлу, де перший рядок буде "
"заголовком, а стовпці будуть такі: user_id, username, email, id курсу, "
"is_verified, verification_date."

#: common/djangoapps/student/models/course_enrollment.py:1777
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     course_id, username, mode"
msgstr ""
"Очікується, що дані будуть надані у форматі CSV-файлу, де перший рядок буде "
"заголовком, а стовпці: id курсу, username, mode."

#: common/djangoapps/student/models/user.py:1745
msgid ""
"An employee (a user whose email has current site's domain name) whose email "
"exists in this model, can be able to login from login screen through email "
"and password. And if any employee's email doesn't exist in this model then "
"that employee can login via third party authentication backend only."
msgstr ""
"Співробітник (користувач, електронна пошта якого має доменне ім’я поточного "
"сайту), електронна пошта якого існує в цій моделі, може входити зі сторінки "
"входу за допомогою електронної пошти та пароля. І якщо в цій моделі не існує"
" жодної електронної пошти працівника, тоді цей працівник може входити лише "
"через бекенд автентифікації третьої сторони."

#: common/djangoapps/student/models/user.py:1760
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     username, current_email, desired_email"
msgstr ""
"Очікується, що дані будуть надані у форматі файлу csv з першим рядком - "
"заголовком і наступними стовпцями: username, current_email, desired_email"

#: common/djangoapps/student/views/management.py:580
#, python-brace-format
msgid ""
"{html_start}Your {account_or_email} could not be "
"{activated_or_confirmed}{html_end}Something went wrong, please <a "
"href=\"{support_url}\">contact support</a> to resolve this issue."
msgstr ""
"{html_start} Ваш {account_or_email} не може бути активованим або "
"підтвердженим {html_end} Щось пішло не так. Будь ласка, <a "
"href=\"{support_url}\">зв’яжіться з службою підтримки</a>, щоб вирішити цю "
"проблему."

#: common/djangoapps/student/views/management.py:627
#, python-brace-format
msgid ""
"{html_start}Success{html_end} You have {activated_or_confirmed} your "
"{account_or_email}."
msgstr ""
"{html_start} Успішно!{html_end} Ви {activated_or_confirmed} свій "
"{account_or_email}."

#: common/djangoapps/student/views/management.py:640
#, python-brace-format
msgid ""
"{html_start}Success! You have {activated_or_confirmed} your "
"{account_or_email}.{html_end}You will now receive email updates and alerts "
"from us related to the courses you are enrolled in. Sign In to continue."
msgstr ""
"{html_start} Успішно! Ви {activated_or_confirmed} ваш "
"{account_or_email}.{html_end} Тепер Ви отримуватимете на електронну пошту "
"оновлення і сповіщення, пов’язані з курсами, на які Ви записані. Щоб "
"продовжити, увійдіть."

#: common/djangoapps/third_party_auth/models.py:158
msgid ""
"optional. If this provider is an Organization, this attribute can be used "
"reference users in that Organization"
msgstr ""
