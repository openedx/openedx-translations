#: xmodule/video_block/video_xfields.py:156
msgid "The default speed for the video."
msgstr "བརྙན་གྱི་རྨང་གཞིའི་མགྱོགས་ཚད།"

#: xmodule/video_block/video_xfields.py:161
msgid ""
"Specify whether to advance automatically to the next unit when the video "
