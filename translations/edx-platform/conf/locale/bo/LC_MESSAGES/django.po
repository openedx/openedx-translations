"སྔ་མའི་འབུལ་སྤྲོད་བྱས་པ་ནས་བཟུང་ལན་འདེབས་བྱས་དང་མ་བྱས་ཅི་རིགས་པ་ཉར་ཚགས་བྱས་ཡོད།"

#: xmodule/capa_block.py:319
msgid "Whether the student has answered the problem"
msgstr "སློབ་ཕྲུག་གིས་དྲི་བར་ལན་འདེབས་བྱས་ཡོད་དམ།"

#: xmodule/capa_block.py:320
msgid "Random seed for this student"
msgstr "སློབ་ཕྲུག་འདིའི་དོན་དུ་ཐོལ་བྱུང་འགོ་རྩོམ།"

#: xmodule/capa_block.py:321
msgid "Last submission time"
