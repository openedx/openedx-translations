"སློབ་མ་ཞིག་གིས་ཚོད་ལྟ་མང་པོ་བྱེད་པའི་དཀའ་ངལ་ལ་ཕུལ་བའི་བར་ལ་སྐར་ཆ་འགའ་ཤས་སྒུག་དགོས།"

#: xmodule/capa_block.py:329
msgid "Problem Weight"
msgstr "དྲི་བ་དཀའ་མོ།"

#: xmodule/capa_block.py:331
msgid ""
"Defines the number of points each problem is worth. If the value is not set,"
" each response field in the problem is worth one point."
msgstr ""
"དྲི་བ་རེ་རེའི་རིན་ཐང་གི་སྐར་གྲངས་གཏན་འཁེལ་བྱོས། "
"རིན་ཐང་གི་སྐར་གྲངས་མ་བསྒྲིག་ན་དྲི་བའི་སྡེ་ཚན་ནང་གི་ལན་འདེབས་རེ་རེ་ནི་རྩ་བའི་སྐར་གྲངས་གཅིག་ལ་བརྩི་འགྲོ།"

#: xmodule/capa_block.py:337
msgid "Markdown source of this module"
msgstr "མ་དཔེ་འདིའི་MD ཡི་ཁུངས།"

#: xmodule/capa_block.py:339
msgid ""
"Source code for LaTeX and Word problems. This feature is not well-supported."
msgstr ""
"LaTeX ཡི་ཁུངས་ཀྱི་ཨང་བརྡ་དང་Word དཀའ་ངལ་ལ། "
"ཁྱད་ཆོས་འདིས་རམ་འདེགས་ཡག་པོ་བྱེད་མི་ཐུབ།"

#: xmodule/capa_block.py:341 xmodule/html_block.py:77
msgid "Enable LaTeX templates?"
msgstr "LaTeX མ་དཔེ་ཐུབ་པ་བྱ་རྒྱུ་ཡིན་ནམ།"

#: xmodule/capa_block.py:343 xmodule/modulestore/inheritance.py:150
msgid "Matlab API key"
msgstr "Matlab API ཚིག་གནད།"

#: xmodule/capa_block.py:345
msgid ""
"Enter the API key provided by MathWorks for accessing the MATLAB Hosted "
"Service. This key is granted for exclusive use by this course for the "
"specified duration. Please do not share the API key with other courses and "
"notify MathWorks immediately if you believe the key is exposed or "
"compromised. To obtain a key for your course, or to report an issue, please "
"contact moocsupport@mathworks.com"
msgstr ""
"Enter the API key provided by MathWorks for accessing the MATLAB Hosted "
"Service. This key is granted for exclusive use by this course for the "
"specified duration. Please do not share the API key with other courses and "
"notify MathWorks immediately if you believe the key is exposed or "
"compromised. To obtain a key for your course, or to report an issue, please "
"contact moocsupport@mathworks.com"

#: xmodule/capa_block.py:433
msgid ""
"We're sorry, there was an error with processing your request. Please try "
"reloading your page and trying again."
msgstr ""
"ཁྱེད་ཀྱི་རེ་ཞུ་བརྒྱུད་རིམ་ལ་གནད་དོན་ཞིག་བྱུང་སོང་། དགོངས་དག "
"ཤོག་ངོས་བསྐྱར་ལེན་བྱས་ཏེ་བསྐྱར་དུ་ཚོད་ལྟ་བྱོས།"

#: xmodule/capa_block.py:438
msgid ""
"The state of this problem has changed since you loaded this page. Please "
"refresh your page."
msgstr ""
"ཁྱེད་ཀྱིས་ཤོག་ངོས་བསྐྱར་ལེན་བྱས་པའི་སྐབས་དྲི་བ་འདིའི་གནས་བབ་འགྱུར་བ་བྱུང་སོང་།"
" ཤོག་ངོས་བསྐྱར་སྐོར་ཞིག་བྱོས།"

#: xmodule/capa_block.py:758 xmodule/capa_block.py:775
msgid "Answer ID"
msgstr "དྲི་བའི་ ID"

#: xmodule/capa_block.py:763
msgid "Correct Answer"
msgstr "དྲི་བ་འགྲིག་པ།"

#: xmodule/capa_block.py:1014
msgid "Submitting"
msgstr "འབུལ་སྤྲོད་བྱེད་བཞིན་པ།"

#: xmodule/capa_block.py:1136
msgid "Warning: The problem has been reset to its initial state!"
msgstr "ཉེན་བརྡ།: དྲི་བ་དེ་ཐོག་མའི་གནས་བབས་ལ་བསྐྱར་སྒྲིག་བྱས་ཡོད།"

#. Translators: Following this message, there will be a bulleted list of
#. items.
#: xmodule/capa_block.py:1140
msgid ""
"The problem's state was corrupted by an invalid submission. The submission "
"consisted of:"
msgstr ""
"ཚུལ་མཐུན་མ་ཡིན་པའི་འབུལ་སྤྲོད་ཅིག་གིས་དྲི་བའི་གནས་བབས་སྐྱོན་ཅན་བྱས་སོང་།"

#: xmodule/capa_block.py:1147
msgid "If this error persists, please contact the course staff."
msgstr "གནད་དོན་འདི་ཡང་ཡང་བྱུང་ཡང་། སློབ་ཚན་བཟོ་མཁན་ལ་འབྲེལ་བ་བྱོས།"

#. Translators: {previous_hints} is the HTML of hints that have already been
#. generated, {hint_number_prefix}
#. is a header for this hint, and {hint_text} is the text of the hint itself.
#. This string is being passed to translation only for possible reordering of
#. the placeholders.
#: xmodule/capa_block.py:1202
#, python-brace-format
msgid "{previous_hints}{list_start_tag}{strong_text}{hint_text}</li>"
msgstr "{previous_hints}{list_start_tag}{strong_text}{hint_text}</li>"

#. Translators: e.g. "Hint 1 of 3: " meaning we are showing the first of three
#. hints.
#. This text is shown in bold before the accompanying hint text.
#: xmodule/capa_block.py:1208
#, python-brace-format
msgid "Hint ({hint_num} of {hints_count}): "
msgstr "བརྡ་སྟོན། ({hint_num} ནས་ {hints_count})། "

#: xmodule/capa_block.py:1289
#, python-brace-format
msgid ""
"Your answers were previously saved. Click '{button_name}' to grade them."
msgstr ""
"ཁྱེད་ཀྱི་ལན་འདེབས་སྔ་མོ་ནས་ཉར་ཚགས་ཡོད། དེ་དག་ལ་རིམ་པ་བསྒྲིག་ན་ "
"'{button_name}' སྣུན།"

#: xmodule/capa_block.py:1365
#, python-brace-format
msgid "Incorrect ({progress} point)"
