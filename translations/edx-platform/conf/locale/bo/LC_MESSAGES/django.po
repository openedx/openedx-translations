#: openedx/core/djangoapps/user_authn/views/password_reset.py:415
msgid "Error in resetting your password."
msgstr "ཁྱེད་ཀྱི་གསང་ཚིག་བསྐྱར་སྒྲིག་ཁྲོད་གནད་དོན་ཞིག་བྱུང་སོང་།"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:445
msgid "Error in resetting your password. Please try again."
msgstr ""
"ཁྱེད་ཀྱི་གསང་ཚིག་བསྐྱར་སྒྲིག་ཁྲོད་གནད་དོན་ཞིག་བྱུང་སོང་། "
"བསྐྱར་དུ་ཚོད་ལྟ་བྱ་རོགས།"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:470
#, python-brace-format
msgid ""
"{html_start}Password Creation Complete{html_end}Your password has been "
"created. {bold_start}{email}{bold_end} is now your primary login email."
msgstr ""
"{html_start}Password Creation Complete{html_end}Your password has been "
"created. {bold_start}{email}{bold_end} is now your primary login ཡིག་ཟམ."

#: openedx/core/djangoapps/user_authn/views/password_reset.py:664
msgid "Some error occurred during password change. Please try again"
msgstr ""
"གསང་གྲངས་བརྗེ་བའི་སྐབས་སུ་གནད་དོན་ཁ་ཤས་བྱུང་སོང་། "
"ཡང་བསྐྱར་ཚོད་ལྟ་ཞིག་བྱེད་རོགས།"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:668
msgid "No email address provided."
msgstr "ཡིག་ཟམ་ཁ་བྱང་མཁོ་མ་བྱས་རུང་ཆོག"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:746
msgid ""
"An error has occurred. Try refreshing the page, or check your internet "
"connection."
msgstr ""
"གནད་དོན་ཞིག་བྱུང་སོང་། ཤོག་ངོས་དེ་བསྐྱར་ལེན་ཞིག་བྱོས། "
"ཡང་ན་ཁྱེད་ཀྱི་དྲ་རྒྱའི་འབྲེལ་མཐུད་ཏག་ཏག་ཡོད་མེད་ལྟ་རོགས།"

#: openedx/core/djangoapps/user_authn/views/register.py:186
#, python-brace-format
msgid "Registration using {provider} has timed out."
msgstr "{provider} བཀོལ་ནས་ཐོ་འགོད་བྱེད་པའི་དུས་ཚོད་རྫོགས་ཟིན།"

#: openedx/core/djangoapps/user_authn/views/register.py:329
msgid "An access_token is required when passing value ({}) for provider."
msgstr "provider་གི་རིན་ཐང་({}) འབུལ་སྤྲོད་སྐབས་ཆོག་མཆན་_མཚོན་རྟགས་དགོས་རེད།"

#: openedx/core/djangoapps/user_authn/views/register.py:342
msgid "The provided access_token is already associated with another user."
msgstr "The provided access_token is already associated with another user."

#: openedx/core/djangoapps/user_authn/views/register.py:345
msgid "The provided access_token is not valid."
msgstr "ཁྱེད་ཀྱི་ཆོག་མཆན་_མཚོན་རྟགས་དེ་ཚུལ་མཐུན་ཞིག་མ་རེད།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:107
msgid "Full Name cannot contain the following characters: < >"
msgstr "མིང་ཆ་ཚང་འབྲི་དུས་གཤམ་བཀོད་ཀྱི་ཡིག་འབྲུ་ཁག་འདུས་མི་རུང་།: < >"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:147
msgid "A properly formatted e-mail is required"
msgstr "རྣམ་པ་ཚད་དང་ལྡན་པའི་གློག་འཕྲིན་ e-mail ཞིག་ངེས་པར་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:148
msgid "Your legal name must be a minimum of one character long"
msgstr ""
"ཁྱེད་ཀྱི་ཁྲིམས་མཐུན་གྱི་མིང་ ཡིག་འབྲུ་གཅིག་ལས་ཉུང་མི་ཆོག་པའི་རིང་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:161
#, python-format
msgid "Email cannot be more than %(limit_value)s characters long"
msgstr "ཡིག་ཟམ་ཡིག་འབྲུ་གི་རིང་ཚད་གིས་ %(limit_value)s ལས་མཐོང་མི་ཆོག་པས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:193
msgid "You must accept the terms of service."
msgstr "ཁྱེད་ཀྱིས་ཞབས་ཞུའི་སྒྲིག་གཞི་ཁག་ངེས་པར་དུ་ངོས་ལེན་བྱ་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:197
msgid "A level of education is required"
msgstr "ཤེས་ཡོན་གནས་ཚད་ངེས་པར་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:198
msgid "Your gender is required"
msgstr "ཁྱེད་ཕོ་མོ་གང་ཡིན་ངེས་པར་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:199
msgid "Your year of birth is required"
msgstr "ཁྱེད་ཀྱི་སྐྱེས་ལོ་ངེས་པར་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:200
msgid "Your mailing address is required"
msgstr "ཁྱེད་ཀྱི་སྦྲགས་སྐུར་ཁ་བྱང་ངེས་པར་དགོས་འདུག"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:201
msgid "A description of your goals is required"
msgstr "ཁྱེད་ཀྱི་དམིགས་འབེན་གྱི་འགྲེལ་བརྗོད་ཅིག་ངེས་པར་དགོས་འདུག"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:202
msgid "A city is required"
msgstr "གྲོང་ཁྱེར་ཞིག་ངེས་པར་དུ་འདེམ།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:203
msgid "A country is required"
msgstr "རྒྱལ་ཁབ་ཅིག་ངེས་པར་འདེམ།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:211
msgid "To enroll, you must follow the honor code."
msgstr ""
"ཞུགས་ཐོ་འགོད་པར་ཁྱེད་ཀྱིས་ངེས་པར་དུ་ honor code "
"སྒྲིག་ཁྲིམས་འདི་བརྩི་སྲུང་བྱ་དགོས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:219
msgid "You are missing one or more required fields"
msgstr "ཁྱེད་ཀྱིས་དགོས་ངེས་ཀྱི་སྡེ་ཚན་གཅིག་དང་ཡང་ན་འགའ་ཤས་ཤོར་འདུག"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:271
msgid "Unauthorized email address."
msgstr "དབང་ཆ་སྤྲད་མེད་པའི་གློག་འཕྲིན་ཁ་བྱང་།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:275
#, python-brace-format
msgid ""
"It looks like {email} belongs to an existing account. Try again with a "
"different email address."
msgstr ""
"{email} འདི་ནི་ད་ལྟོའི་ཁ་བྱང་ཞིག་ལ་འབྲེལ་བ་ཡོད་འདུག "
"ཡིག་ཟམ་གཞན་ཞིག་བཀོལ་ཏེ་བསྐྱར་དུ་ཚོད་ལྟ་རོགས།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:311
msgid "Registration from this country is not allowed due to restrictions."
msgstr "རྒྱལ་ཁབ་འདི་ནས་ཐོ་འགོད་བྱེད་ཆོག་གི་མེད་པས་ཚད་བཀག་ཡོད་སྟབས།"

#. Translators: These instructions appear on the registration form,
#. immediately
#. below a field meant to hold the user's email address.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:510
msgid "This is what you will use to login."
msgstr "འདི་ནི་ཁྱེད་ཀྱིས་གཞུག་ཕྱོགས་ནང་འཛུལ་བྱ་ཚུལ་ཡིན།"

#. Translators: These instructions appear on the registration form,
#. immediately
#. below a field meant to hold the user's full name.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:560
msgid "This name will be used on any certificates that you earn."
msgstr "ཁྱེད་ཀྱིས་ཐོབ་པའི་ལག་ཁྱེར་གང་རུང་ལ་མིང་འདི་བེད་སྤྱོད་གཏོང་གི་རེད།"

#. Translators: This label appears above a field on the registration form
#. meant to hold the user's public username.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:581
msgid "Public Username"
msgstr "སྤྱི་སྤྱོད་མཁན་མིང་།"

#. Translators: These instructions appear on the registration form,
#. immediately
#. below a field meant to hold the user's public username.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:586
msgid ""
"The name that will identify you in your courses. It cannot be changed later."
msgstr ""
"མིང་འདི་ནི་སློབ་ཚན་གྱི་ནང་ཁྱེད་རང་གི་ངོས་འཛིན་བྱེད་ཀྱི་མིང་ཡིན། "
"རྗེས་ནས་བརྗེ་མི་ཐུབ།"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:702
#, python-brace-format
msgid "I agree that {platform_name} may send me marketing messages."
msgstr ""
"{platform_name} ཡིས་ང་ལ་ཚོང་བསྒྲགས་བརྡ་འཕྲིན་གཏོང་རྒྱུར་ངས་མོས་མཐུན་བྱེད།"

#. Translators: This label appears above a dropdown menu on the registration
#. form used to select the country in which the user lives.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:967
msgid "Country or Region of Residence"
msgstr "བཅའ་སྡོད་བྱ་སའི་མངའ་ཁུལ་དང་ཡང་ན་རྒྱལ་ཁབ།"

#. Translators: These instructions appear on the registration form,
#. immediately
#. below a field meant to hold the user's country.
#: openedx/core/djangoapps/user_authn/views/registration_form.py:978
msgid "The country or region where you live."
msgstr "ཁྱེད་རང་གནས་ཡུལ་གྱི་མངའ་ཁུལ་དང་ཡང་ན་རྒྱལ་ཁབ།"

