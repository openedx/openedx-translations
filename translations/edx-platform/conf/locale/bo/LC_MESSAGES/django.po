msgid ""
"Enter true or false. If true, students can create discussion posts that are "
"anonymous to all users."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞིག་བཙུགས། "
"བདེན་པ་ཡིན་ན་སློབ་ཕྲུག་ཚོས་མིང་མི་གསལ་བར་སྤྱོད་མཁན་ཡོངས་ལ་གླེང་མོལ་འཇོག་ཆོག་པ་རེད།"

#: xmodule/course_block.py:563
msgid "Allow Anonymous Discussion Posts to Peers"
msgstr "རང་ཉིད་དང་གོ་བབ་མཚུངས་པའི་རིགས་ལ་མིང་མི་གསལ་བའི་གླེང་མོལ་སྤེལ་ཆོག"

#: xmodule/course_block.py:565
msgid ""
"Enter true or false. If true, students can create discussion posts that are "
"anonymous to other students. This setting does not make posts anonymous to "
"course staff."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག། "
"བདེན་པ་ཡིན་ན་སློབ་ཕྲུག་གིས་སློབ་ཕྲུག་གཞན་ལ་མིང་མེད་བགྲོ་གླེང་རིགས་སྤེལ་ཆོག "
"འོན་ཀྱང་། སྒྲིག་འགོད་འདིས་སློབ་ཚན་ལས་བྱེད་པ་ལ་མིང་མེད་བྱེད་མི་ཐུབ།"

#: xmodule/course_block.py:571 xmodule/library_root_xblock.py:36
msgid "Advanced Module List"
msgstr "ཚད་མཐོའི་གྲུབ་ཆའི་ཐོ་གཞུང་།"

#: xmodule/course_block.py:572
msgid "Enter the names of the advanced modules to use in your course."
msgstr "ཁྱེད་ཀྱི་སློབ་ཚན་ནང་སྤྱད་རྒྱུའི་ཚད་མཐོའི་ཚད་གཞིའི་མིང་།"

#: xmodule/course_block.py:578
msgid ""
"True if timezones should be shown on dates in the course. Deprecated in "
"favor of due_date_display_format."
msgstr ""
"དུས་མཇུག་གི་ཟླ་ཚེས་འཆར་སྟོན་གྱི་རྣམ་པ་སྟོན་མི་འདོད་ན། བདེན་པ་བཞག་ན། "
"དུས་ཚོད་ཀྱི་རྣམ་པ་དེ་སློབ་ཚན་གྱི་ཟླ་ཚེས་ནང་སྟོན་ངེས་ཡིན། "

#: xmodule/course_block.py:584
msgid "Due Date Display Format"
msgstr "དུས་བཅད་རྫོགས་པའི་འཆར་སྟོན་རྣམ་སྒྲིག"

#: xmodule/course_block.py:586
msgid ""
"Enter the format for due dates. The default is Mon DD, YYYY. Enter "
"\"%m-%d-%Y\" for MM-DD-YYYY, \"%d-%m-%Y\" for DD-MM-YYYY, \"%Y-%m-%d\" for "
"YYYY-MM-DD, or \"%Y-%d-%m\" for YYYY-DD-MM."
msgstr ""
"དུས་ཡུན་རྫོགས་པའི་ཟླ་ཚེས་ཀྱི་རྣམ་པ་ཞོག སྤྱིར་བཏང་གི་འགྲོ་སྟངས་ནི་ ཟླ་བ། "
"ཚེས་པ། ལོ་ཡིན།. MM-DD-YYYY, འདི་ནི་ \"%ཟླ་-%d-%ལོ་\" འདི་ལྟར་ཞོག, DD-MM-"
"YYYY, འདི་ནི་\"%d-%ཟླ་-%ལོ་\" ལྟར་ཡིན།, YYYY-MM-DD འདི་ནི་ \"%ལོ་-%ཟླ་-%d\" "
"འདི་ལྟར་དང་།, ཡང་ན་ YYYY-DD-MM \"%ལོ་-%d-%ཟླ་\" འདི་ལྟར་ཡིན།"

#: xmodule/course_block.py:592
msgid "External Login Domain"
msgstr "ཕྱིའི་ནང་འཛུལ་གྱི་དྲ་གནས།"

#: xmodule/course_block.py:593
msgid "Enter the external login method students can use for the course."
msgstr "སློབ་ཕྲུག་གིས་སློབ་ཚན་དུ་བཀོལ་ཐུབ་པའི་ཕྱིའི་ནང་འཛུལ་ཐབས་ནང་འཇུག་རོགས།"

#: xmodule/course_block.py:597
msgid "Certificates Downloadable Before End"
msgstr "མཇུག་མ་རྫོགས་གོང་ལག་ཁྱེར་ཕབ་ལེན་བྱ་ཐུབ་པ།"

#: xmodule/course_block.py:599
msgid ""
"Enter true or false. If true, students can download certificates before the "
"course ends, if they've met certificate requirements."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞིག་ཞོག བདེན་པ་བཞག་ན། "
"སློབ་ཕྲུག་གིས་ལག་ཁྱེར་གྱི་དགོས་མཁོའི་ཆ་རྐྱེན་ཁག་མཐུས་ཚང་བསྒྲུབས་ཡོད་ན་སློབ་ཚན་མཇུག་མ་རྫོགས་གོང་ལག་ཁྱེར་ཕབ་ལེན་བྱ་ཐུབ།"

#: xmodule/course_block.py:608
msgid "Certificates Display Behavior"
msgstr "ལག་ཁྱེར་འཆར་སྟོན་གྱི་རྣམ་པ།"

#: xmodule/course_block.py:610
msgid ""
"This field, together with certificate_available_date will determine when a "
"user can see their certificate for the course"
msgstr ""
"སྡེ་ཚན་འདི་དང་ལྷན་དུ། "
"ལག་འཁྱེར་དང་མཉམ་དུ་ཟླ་ཚེས་ཀྱང་སྤྱོད་མཁན་ཞིག་གིས་སློབ་ཚན་དེའི་ལག་འཁྱེར་ལ་བལྟ་ཐུབ་དུས་གཏན་འཁེལ་བྱེད་ཡོང་ཡིན།"

#: xmodule/course_block.py:617
msgid "Course About Page Image"
msgstr "སློབ་ཚན་སྐོར་གྱི་ཤོག་ངོས་འདྲ་པར།"

#: xmodule/course_block.py:619
msgid ""
"Edit the name of the course image file. You must upload this file on the "
"Files & Uploads page. You can also set the course image on the Settings & "
"Details page."
msgstr ""
"སློབ་ཚན་དེ་དང་འབྲེལ་བའི་འདྲ་པར་གྱི་མིང་སྒྲིག "
"ཁྱེད་ཀྱིས་ཡིག་ཆ་འདི་ངེས་པར་དུ་ཡིག་ཆ་ & "
"ཡར་སྤྲོད་ཤོག་ངོས་གཉིས་ཀྱི་ནང་ཡར་སྤྲོད་བྱ་དགོས། "
"ད་དུང་ཁྱེད་ཀྱིས་སློབ་ཚན་དང་འབྲེལ་བའི་འདྲ་པར་དེ་སྒྲིག་འགོད་ & "
"ཞིབ་ཕྲའི་ཤོག་ངོས་གཉིས་ཀྱི་ནང་སྒྲིག་ཐུབ།"

#: xmodule/course_block.py:628
msgid "Course Banner Image"
msgstr "སློབ་ཚན་གྱི་འཕྲེད་ཉལ་འདྲ་པར།"

#: xmodule/course_block.py:630
msgid ""
"Edit the name of the banner image file. You can set the banner image on the "
"Settings & Details page."
msgstr ""
"འཕྲེད་ཉལ་འདྲ་པར་གྱི་མིང་རྩོམ་སྒྲིག་བྱེད། "
"ཁྱེད་ཀྱིས་འཕྲེད་ཉལ་འདྲ་པར་དེ་སྒྲིག་འགོད་དང་ & "
"ཤོག་ངོས་ཀྱི་ཞིབ་ཕྲ་ཟེར་བ་གཉིས་ཀྱི་ནང་སྒྲིག་ཐུབ།"

#: xmodule/course_block.py:638
msgid "Course Video Thumbnail Image"
msgstr "སློབ་ཚན་བརྙན་གྱི་གདོང་ཁེབ་འདྲ་པར།"

#: xmodule/course_block.py:640
msgid ""
"Edit the name of the video thumbnail image file. You can set the video "
"thumbnail image on the Settings & Details page."
msgstr ""
"སློབ་ཚན་བརྙན་གྱི་མིང་གྱི་འདྲ་པར་རྩོམ་སྒྲིག་བྱེད། "
"ཁྱེད་ཀྱིས་སློབ་ཚན་བརྙན་གྱི་འདྲ་པར་དེ་སྒྲིག་འགོད་དང་ & "
"ཤོག་ངོས་ཀྱི་ཞིབ་ཕྲ་ཟེར་བ་གཉིས་ཀྱི་ནང་སྒྲིག་ཐུབ།"

#: xmodule/course_block.py:650
msgid ""
"Use this setting only when generating PDF certificates. Between quotation "
"marks, enter the short name of the type of certificate that students receive"
" when they complete the course. For instance, \"Certificate\"."
msgstr ""
"PDF ཡི་རྣམ་པའི་ལག་ཁྱེར་བཟོ་དུས་སྒྲིག་འགོད་འདི་རྒྱུན་སྤྱོད་བྱེད། "
"ལུང་རྟགས་ཀྱི་བར་ལ་མིང་ཐུང་ངུ་ཞིག་འཇུག་དགོས། "
"དེ་ནི་སློབ་མས་སློབ་ཚན་མཐར་ཕྱིན་དུས་འཐོབ་རྒྱུའི་ལག་ཁྱེར་གྱི་གྲས་ཡིན། དཔེར་ན། "
"\"ལག་ཁྱེར།\" ལྟ་བུ།"

#: xmodule/course_block.py:654
msgid "Certificate Name (Short)"
msgstr "ལག་ཁྱེར་གྱི་མིང་། (ཐུང་ཐུང་།)"

#: xmodule/course_block.py:660
msgid ""
"Use this setting only when generating PDF certificates. Between quotation "
"marks, enter the long name of the type of certificate that students receive "
"when they complete the course. For instance, \"Certificate of Achievement\"."
msgstr ""
"PDF ཡི་རྣམ་པའི་ལག་ཁྱེར་བཟོས་དུས་ད་གཟོད་སྒྲིག་འགོད་འདི་བཀོལ་སྤྱོད་བྱེད། "
"ལུང་རྟགས་ཀྱི་བར་ལ་མིང་རིང་ཙམ་ཞིག་འཇུག་དགོས། "
"དེ་ནི་སློབ་མས་སློབ་ཚན་དེ་སློབ་མཐཪ་ཕྱིན་དུས་འཐོབ་རྒྱུའི་ལག་ཁྱེར་གྱི་གྲས་ཤིག་ཡིན་དགོས།"
" དཔེར་ན། \"གྲུབ་འབྲས་ཀྱི་ལག་ཁྱེར།\" ལྟ་བུ།"

#: xmodule/course_block.py:664
msgid "Certificate Name (Long)"
msgstr "ལག་ཁྱེར་གྱི་མིང་། (རིང་པོ།)"

#: xmodule/course_block.py:669
msgid "Certificate Web/HTML View Enabled"
msgstr "ལག་ཁྱེར་གྱི་དྲ་ཚིགས་/HTML འཆར་སྟོན་ནུས་པ།"

#: xmodule/course_block.py:670
msgid "If true, certificate Web/HTML views are enabled for the course."
msgstr ""
"བདེན་པ་ཡིན་ན་སློབ་ཚན་འདིའི་ལག་ཁྱེར་གྱི་དྲ་ཚིགས་/HTMLའཆར་སྟོན་ནུས་པ་ཡིན།"

#. Translators: This field is the container for course-specific certificate
#. configuration values
#: xmodule/course_block.py:677
msgid "Certificate Web/HTML View Overrides"
msgstr "ལག་ཁྱེར་དྲ་ཚིགས་/HTML འཆར་སྟོན་ཟུར་འཇོག་བྱས་པ།"

#. Translators: These overrides allow for an alternative configuration of the
#. certificate web view
#: xmodule/course_block.py:679
msgid ""
"Enter course-specific overrides for the Web/HTML template parameters here "
"(JSON format)"
msgstr ""
"དྲ་ཚིགས་དེའི་Web/HTML དཔེ་བྱེད་ (JSON format) རྣམས་ཀྱི་ཆེད་དུ། "
"སློབ་ཚན་གྱི་དམིགས་བསལ་གྱི་འགོག་མཚམས་རྣམས་ཞོག"

#. Translators: This field is the container for course-specific certificate
#. configuration values
#: xmodule/course_block.py:686
msgid "Certificate Configuration"
msgstr "ལག་ཁྱེར་གྲུབ་ཆ་གོ་སྒྲིག"

#. Translators: These overrides allow for an alternative configuration of the
#. certificate web view
#: xmodule/course_block.py:688
msgid "Enter course-specific configuration information here (JSON format)"
msgstr ""
"སློབ་ཚན་གྱི་དམིགས་བསལ་ཆེད་སྤྱོད་བཀོད་སྒྲིག་གི་ཆ་འཕྲིན་ (JSON format) ཞོག"

#: xmodule/course_block.py:702
msgid "CSS Class for Course Reruns"
msgstr "སློབ་ཚན་བསྐྱར་གཏོང་གི་ཆེད་དུ་ CSS ཡི་སྡེ་ཚན།"

#: xmodule/course_block.py:703
msgid ""
"Allows courses to share the same css class across runs even if they have "
"different numbers."
msgstr ""
"ཁོང་ཚོའི་ཨང་གྲངས་ཁྱབ་ཚད་མི་གཅིག་ན་ཡང་། སློབ་ཚན་ཚུ་གིས་css "
"འཛིན་གྲྭ་གཅིག་པ་བརྒྱུད་སྐུར་བྱེད་ཆོག །"

#: xmodule/course_block.py:714
msgid "Discussion Forum External Link"
msgstr "གླེང་མོལ་གླེང་སྟེགས་ཀྱི་ཕྱིའི་དྲ་ཐག"

#: xmodule/course_block.py:715
msgid "Allows specification of an external link to replace discussion forums."
msgstr ""
"ཕྱིའི་དྲ་ཐག་གི་དམིགས་འཛིན་ཚད་གཞི་ཡིས་གླེང་མོལ་གླེང་སྟེགས་བརྗེ་ལེན་བྱེད་འཇུག་པ།"

#: xmodule/course_block.py:724
msgid "Hide Progress Tab"
msgstr "ཡར་རྒྱས་རྟགས་ཀྱི་ཐེབས་སྦེད།"

#: xmodule/course_block.py:725
msgid "Allows hiding of the progress tab."
msgstr "ཡར་རྒྱས་རྟགས་ཀྱི་ཐེབས་སྦེད་འཇུག་པ།"

#: xmodule/course_block.py:731
msgid "Course Organization Display String"
msgstr "སློབ་ཚན་རྩ་འཛུགས་འཆར་སྟོན་གྱི་བང་རིམ།"

#: xmodule/course_block.py:733
msgid ""
"Enter the course organization that you want to appear in the course. This "
"setting overrides the organization that you entered when you created the "
"course. To use the organization that you entered when you created the "
"course, enter null."
msgstr ""
"ཁྱེད་ཀྱིས་སློབ་ཚན་འདིའི་ནང་སྟོན་འདོད་པའི་སློབ་ཚན་རྩ་འཛུགས་ཞོག "
"སྒྲིག་འགོད་འདིས་ཁྱེད་ཀྱིས་སློབ་ཚན་བཟོས་དུས་ནང་འཇུག་བྱས་པའི་རྩ་འཛུགས་བཀག་འགྲོ་བ་ཡིན།"
" "
"ཁྱེད་ཀྱིས་ནང་འཇུག་བྱས་པའི་རྩ་འཛུགས་མུ་མཐུད་ནས་འཇོག་དགོས་ན་སློབ་ཚན་བཟོས་དུས་་མེད་ཟེར་བ་ཞོག།"

#: xmodule/course_block.py:741
msgid "Course Number Display String"
msgstr "སློབ་ཚན་ཨང་འཅར་སྟོན་གྱི་བང་རིམ།"

#: xmodule/course_block.py:743
msgid ""
"Enter the course number that you want to appear in the course. This setting "
"overrides the course number that you entered when you created the course. To"
" use the course number that you entered when you created the course, enter "
"null."
msgstr ""
"ཁྱེད་ཀྱིས་སློབ་ཚན་འདིའི་ནང་སྟོན་འདོད་པའི་སློབ་ཚན་ཨང་ཞོག "
"སློབ་ཚན་བཟོས་དུས་ནང་འཇུག་བྱས་པའི་སློབ་ཚན་ཨང་བཀག་འགྲོ་བ་ཡིན། "
"སློབ་ཚན་བཟོས་དུས་ནང་འཇུག་བྱས་པའི་སློབ་ཚན་ཨང་མུ་མཐུད་ནས་འཇོག་དགོས་ན་མེད་ཟེར་བ་ཞོག།"

#: xmodule/course_block.py:752
msgid "Course Maximum Student Enrollment"
msgstr "སློབ་ཚན་ལ་ཞུགས་ཐོ་འགོད་མཁན་གྱི་སློབ་ཕྲུག་གི་མང་མཐའ།"

#: xmodule/course_block.py:754
msgid ""
"Enter the maximum number of students that can enroll in the course. To allow"
" an unlimited number of students, enter null."
msgstr ""
"སློབ་ཚན་འདི་ལ་ཞུགས་ཐོ་འགོད་ཆོག་པའི་སློབ་ཕྲུག་ག་ཚོད་ཀྱིས་ཕྲིས། ཚད་བཅད་མེད་ན། "
"མེད་ཕྲིས།"

#: xmodule/course_block.py:761
msgid "Allow Public Wiki Access"
msgstr "སྤྱི་སྤྱོད་ཀྱི་ཝེ་ཁེ་བལྟ་ཀློག་ཆོག་པ།"

#: xmodule/course_block.py:763
msgid ""
"Enter true or false. If true, students can view the course wiki even if "
"they're not enrolled in the course."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག "
"བདེན་པ་ཡིན་ན་སློབ་ཕྲུག་གིས་སློབ་ཚན་དེར་ཐོ་འགོད་བྱས་མེད་ཀྱང་སློབ་ཚན་དེའི་ཝེ་ཁེ་བལྟ་ཆོག"
" རེད།"

#: xmodule/course_block.py:771
msgid "Invitation Only"
msgstr "མགྲོན་བརྡ་གཏོང་རྒྱུ་ཁོ་ན།"

#: xmodule/course_block.py:772
msgid "Whether to restrict enrollment to invitation by the course staff."
msgstr "སློབ་ཚན་ལས་བྱེད་པས་གདན་འདྲེན་བྱས་པའི་ཞུགས་ཐོ་ལ་དམ་རྒྱ་བྱེད་དམ།"

#: xmodule/course_block.py:778
msgid "Pre-Course Survey Name"
msgstr "སྔོན་འགྲོའི་སློབ་ཚན་གྱི་བརྟད་དཔྱད་ཀྱི་མིང་།"

#: xmodule/course_block.py:779
msgid "Name of SurveyForm to display as a pre-course survey to the user."
msgstr ""
"སྤྱོད་མཁན་ལ་སྔོན་འགྲོའི་སློབ་ཚན་ཞིག་ཡིན་པ་སྟོན་པའི་བརྟག་དཔྱད་ཤོག་ངོས་ཀྱི་མིང་།"

#: xmodule/course_block.py:786
msgid "Pre-Course Survey Required"
msgstr "སྔོན་འགྲོའི་སློབ་ཚན་བརྟག་དཔྱད་དགོས་ངེས།"

#: xmodule/course_block.py:788
msgid ""
"Specify whether students must complete a survey before they can view your "
"course content. If you set this value to true, you must add a name for the "
"survey to the Course Survey Name setting above."
msgstr ""
"གལ་སྲིད་སློབ་མ་ཚོས་ཁྱེད་ཀྱི་སློབ་ཚན་གྱི་ནང་དོན་ལ་མ་བལྟས་སྔོན་ཁོང་ཚོས་བརྟག་དཔྱད་དེ་ཆ་ཚང་ངེས་པར་དུ་ལེན་དགོས་མིན་གཏན་འབེབ་བྱོས།"
" "
"སྒྲིག་གནས་འདི་བདེན་པ་ཟེར་བ་བསྒྲིགས་ན་སྒང་གི་སློབ་ཚན་བརྟག་དཔྱད་ཀྱི་སྒྲིག་འགོད་ནང་བརྟག་དཔྱད་ཀྱི་མིང་ཞིག་ངེས་པར་འཇོག་དགོས།"

#: xmodule/course_block.py:797
msgid "Course Visibility In Catalog"
msgstr "སློབ་ཚན་དེ་དཀར་ཆག་ནང་འཆར་ཐུབ་པ།"

#. Translators: the quoted words 'both', 'about', and 'none' must be
#. left untranslated.  Leave them as English words.
#: xmodule/course_block.py:801
msgid ""
"Defines the access permissions for showing the course in the course catalog."
" This can be set to one of three values: 'both' (show in catalog and allow "
"access to about page), 'about' (only allow access to about page), 'none' (do"
" not show in catalog and do not allow access to an about page)."
msgstr ""
"སློབ་ཚན་དཀར་ཆག་ནང་སློབ་ཚན་སྟོན་སྟངས་ཀྱི་ཆོག་མཆན་གཏན་འཁེལ་བྱོས།: "
"འདི་ནི་རིན་ཐང་གི་ཚད་གསུམ་གྱི་གང་རུང་ཞིག་ཡིན་ཆོག་སྟེ། 'རིགས་གཉིས་ཆོག' "
"(སློབ་ཚན་དཀར་ཆག་ནང་སྟོན་ཆོག་ལ་ཤོག་ངོས་ཀྱི་སྐོར་བལྟ་ཀློག་ཀྱང་ཆོག) "
"'ཤོག་ངོས་ཀྱི་སྐོར།' (ཤོག་ངོས་ཀྱི་སྐོར་ཁོ་ནར་བལྟ་ཆོག), 'གང་ཡང་མི་ཆོག' "
"(སློབ་ཚན་དཀར་ཆག་ནང་མི་སྟོན། ཤོག་ངོས་ཀྱི་སྐོར་ཡང་བལྟ་ཀློག་མི་ཆོག)"

#: xmodule/course_block.py:815
msgid "Entrance Exam Enabled"
msgstr "ཚུད་རྒྱུགས་ནུས་ལྡན་བྱེད་པ།"

#: xmodule/course_block.py:817
msgid ""
"Specify whether students must complete an entrance exam before they can view"
" your course content. Note, you must enable Entrance Exams for this course "
"setting to take effect."
msgstr ""
"སློབ་ཕྲུག་ཚོས་ཁྱེད་ཀྱི་སློབ་ཚན་ནང་དོན་བལྟ་ཀློག་ཐུབ་པར་ཁོང་ཚོས་ཐོག་མར་ཚུད་རྒྱུགས་ཆ་ཚང་ངེས་པར་ལེན་དགོས་མིན་གཏན་འཁེལ་བྱོས།"
" གསལ་འདེབས་བྱ་རྒྱུ་ནི། "
"སློབ་ཚན་འདིའི་སྒྲིག་འགོད་ཁག་གིས་བྱེད་ནུས་འདོན་པར་ཁྱེད་ཀྱིས་ངེས་པར་དུ་ནུས་ཚུད་རྒྱུགས་དགོས།"

#: xmodule/course_block.py:828
msgid "Entrance Exam Minimum Score (%)"
msgstr "ཚུགས་རྒྱུགས་ཀྱི་ཉུང་མཐའི་ཐོབ་སྐར། (%)"

#: xmodule/course_block.py:830
msgid ""
"Specify a minimum percentage score for an entrance exam before students can "
"view your course content. Note, you must enable Entrance Exams for this "
"course setting to take effect."
msgstr ""
"སློབ་ཕྲུག་གིས་ཁྱེད་ཀྱི་སློབ་ཚན་ནང་དོན་ལ་མ་བལྟས་སྔོན་ཚུད་རྒྱུགས་ཀྱི་དམའ་མཐའི་ཐོབ་སྐར་གྱི་བརྒྱ་ཆ་ཞིག་གཏན་འཁེལ་བྱེད།"
" གསལ་འདེབས་བྱེད་རྒྱུར། "
"ཁྱེད་ཀྱིས་སློབ་ཚན་འདིའི་སྒྲིག་འགོད་ཀྱི་བྱེད་ནུས་འདོན་པར་ཚུད་རྒྱུགས་དེ་ངེས་པར་དུ་ནུས་ལྡན་བྱ་དགོས།"

#: xmodule/course_block.py:838
msgid "Entrance Exam ID"
msgstr "ཚུད་རྒྱུགས་ཀྱི་ ID"

#: xmodule/course_block.py:839
msgid "Content block identifier (location) of entrance exam."
msgstr "ཚུད་རྒྱུགས་ཀྱི་ (location) ནང་དོན་ཚན་པའི་ངོས་འཛིན་བྱེད།"

#: xmodule/course_block.py:845
msgid "Social Media Sharing URL"
msgstr "དམིགས་བསལ་སྨྱན་གཟུགས་བརྒྱུད་སྐུར་གྱི་ URL"

#: xmodule/course_block.py:847
msgid ""
"If dashboard social sharing and custom course URLs are enabled, you can "
"provide a URL (such as the URL to a course About page) that social media "
"sites can link to. URLs must be fully qualified. For example: "
"http://www.edx.org/course/Introduction-to-MOOCs-ITM001"
msgstr ""
"If dashboard social sharing and custom course URLs are enabled, you can "
"provide a URL (such as the URL to a course About page) that social media "
"sites can link to. URLs must be fully qualified. For example: "
"http://www.edx.org/course/Introduction-to-MOOCs-ITM001"

#: xmodule/course_block.py:855
msgid "Course Language"
msgstr "སློབ་ཚན་སྐད་ཡིག"

#: xmodule/course_block.py:856
msgid "Specify the language of your course."
msgstr "ཁྱེད་ཀྱི་སློབ་ཚན་གྱི་སྐད་ཡིག་ངོས་འཛིན་བྱོས།"

#: xmodule/course_block.py:862
msgid "Teams Configuration"
msgstr "ཚོགས་ཆུང་གི་གྲུབ་ཆ་གོ་སྒྲིག"

#: xmodule/course_block.py:865
msgid ""
"Configure team sets, limit team sizes, and set visibility settings using "
"JSON. See <a target=\"&#95;blank\" "
"href=\"https://docs.openedx.org/en/latest/educators/references/advanced_features/teams_configuration_options.html>teams"
" configuration documentation</a> for help and examples."
msgstr ""
"རིགས་ཚོགས་སྒྲིག་སྟངས་བཟོ་བཅོས་དང་། རིགས་ཚོགས་ཀྱི་ཚོགས་གྲངས་བཀག་སྡོམ་དང་། "
"མཐོང་སྣང་སྒྲིག་སྟངས་བཟོ་བཅོས་བྱེད་པར JSON ལག་ལེན་འཐབ། "
"རིགས་ཚོགས་སྒྲིག་སྟངས་ཡིག་ཆ་ལ་རོགས་སྐྱོར་དང་དཔེ་ཆ་ཚུལ་ལེན་འཐབ། <a "
"target=\"&#95;blank\" "
"href=\"https://docs.openedx.org/en/latest/educators/references/advanced_features/teams_configuration_options.html\">teams"
" configuration documentation</a>."

#: xmodule/course_block.py:874
msgid "Enable Proctored Exams"
msgstr "དྲ་ལམ་རྒྱུགས་སྤྲོད་ཐུབ་པ།"

#: xmodule/course_block.py:876
msgid ""
"Enter true or false. If this value is true, proctored exams are enabled in "
"your course. Note that enabling proctored exams will also enable timed "
"exams."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག གནས་བདེན་པ་ཡིན་ན་སློབ་ཚན་ནང་རྒྱུགས་ཞིབ་བཀོད་ཡོད།"
" རྒྱུགས་ཞིབ་བཀོད་ནས་དུས་ཚོད་བཅད་པའི་རྒྱུགས་སྤྲོད་ཡང་བཀོད་ཡོད་དགོས་ཡིན།"

#: xmodule/course_block.py:885
msgid "Proctoring Provider"
msgstr "དྲ་ལམ་ཡིག་རྒྱུགས་མཁོ་སྤྲོད་པ།"

#: xmodule/course_block.py:887
#, python-brace-format
msgid ""
"Enter the proctoring provider you want to use for this course run. Choose "
"from the following options: {available_providers}."
msgstr ""
"ཁྱེད་ཀྱིས་སློབ་ཚན་འདི་དོ་དམ་དང་འཆད་ཁྲིད་མཁན་འཇོག་འདོད་པ་འདི་གདམ་ཁ་གཏན་འཁེལ། "
"གཤམ་བཀོད་ཀྱི་གདམ་ཁའི་ཁྲོད་ནས་འདེམ།: {available_providers}."

#: xmodule/course_block.py:913
msgid "Allow Opting Out of Proctored Exams"
msgstr "དྲ་ལམ་རྒྱུགས་སྤྲོད་མེད་པའི་འདེམ་ཁ་སྤྲོད་པ།"

#: xmodule/course_block.py:915
msgid ""
"Enter true or false. If this value is true, learners can choose to take "
"proctored exams without proctoring. If this value is false, all learners "
"must take the exam with proctoring. This setting only applies if proctored "
"exams are enabled for the course."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞིག་ཞོག བདེན་པ་བཞག་ན། "
"སློབ་གཉེར་པ་ཚོས་ལྟ་རྟོག་ཡོད་པའི་ཡིག་རྒྱུགས་ཁག་དོ་དམ་པའི་བལྟ་ཞིབ་མེད་པའི་ཐོག་ནས་ཡིག་རྒྱུགས་འདེམ་ཆོག"
" རྫུན་པ་བཞག་ན། "
"སློབ་གཉེར་པ་ཡོད་དོ་ཅོག་གིས་ཡིག་རྒྱུགས་རྣམས་ངེས་པར་དུ་དོ་དམ་བལྟ་ཞིབ་འོག་རྒྱུགས་སྤྲོད་བྱ་དགོས།"
" "
"སློབ་ཚན་དེའི་བལྟ་རྟོག་ཡོད་པའི་ཡིག་རྒྱུགས་ཁག་ནུས་ལྡན་བྱས་ན་ད་གཟོད་སྒྲིག་འགོད་འདི་འཇོག་དགོས་པ་ཡིན།"

#: xmodule/course_block.py:925
msgid "Create Zendesk Tickets For Suspicious Proctored Exam Attempts"
msgstr "ལྟ་རྟོག་ཡོད་པའི་ཡིག་རྒྱུགས་དོགས་གཞི་ཆན་ཚོར་Zendesk Tickets ཞིག་བཟོས།"

#: xmodule/course_block.py:927
msgid ""
"Enter true or false. If this value is true, a Zendesk ticket will be created"
" for suspicious attempts."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག སྒྲིག་གནས་བདེན་པ་བསྒྲིགས་ན། "
"ལྟ་རྟོག་ཡོད་པའི་ཡིག་རྒྱུགས་དོགས་གཞི་ཅན་གྱི་ཆེད་དུ་ Zendesk ticket "
"བཟོ་ཡོང་བ་ཡིན།"

#: xmodule/course_block.py:935
msgid "Enable Timed Exams"
msgstr "དུས་བཅད་ཀྱི་རྒྱུགས་ནུས་ལྡན་བྱེད་པ།"

#: xmodule/course_block.py:937
msgid ""
"Enter true or false. If this value is true, timed exams are enabled in your "
"course. Regardless of this setting, timed exams are enabled if Enable "
"Proctored Exams is set to true."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག "
"འདི་བདེན་པ་ཡིན་ན་སློབ་ཚན་ནང་དུས་ཡུན་ཚད་བཀག་ཅན་གྱི་ཡིག་རྒྱུགས་རྣམས་ནུས་ལྡན་བྱེད་འགྲོ།"
" "
"སྒྲིག་སྟངས་འདི་ལ་གནོད་མེད་པར་ལྟ་རྟོག་ཡོད་པའི་ཡིག་རྒྱུགས་རྣམས་བདེན་པ་བསྒྲིགས་ན་དུས་ཡུན་ཚད་བཀག་ཅན་གྱི་ཡིག་རྒྱུགས་རྣམས་ནུས་ལྡན་བྱེད་འགྲོ།"

#: xmodule/course_block.py:946
msgid "Minimum Grade for Credit"
msgstr "ངོ་སོའི་ཕྱིར་དམའ་མཐའི་རིམ་པ།"

#: xmodule/course_block.py:948
msgid ""
"The minimum grade that a learner must earn to receive credit in the course, "
"as a decimal between 0.0 and 1.0. For example, for 75%, enter 0.75."
msgstr ""
"The minimum grade that a learner must earn to receive credit in the course, "
"as a decimal between 0.0 and 1.0. For example, for 75%, enter 0.75."

#: xmodule/course_block.py:956 xmodule/modulestore/inheritance.py:232
msgid "Self Paced"
msgstr "རང་སྦྱོང་།"

#: xmodule/course_block.py:958 xmodule/modulestore/inheritance.py:234
msgid ""
"Set this to \"true\" to mark this course as self-paced. Self-paced courses "
"do not have due dates for assignments, and students can progress through the"
" course at any rate before the course ends."
msgstr ""
"འདི་ \"true\" ལ་སྒྲིག་ནས་སློབ་ཚན་འདི་རང་སྦྱོང་སློབ་ཚན་ཡིན་པར་མཚན་རྟགས་འགོད། "
"རང་སྦྱོང་སློབ་ཚན་ཚུ་ལ་ལས་བྱའི་དུས་བཀག་མེད་པ་དང་། "
"སློབ་ཚན་མཇུག་མ་རྫོགས་བར་དུ་སློབ་ཕྲུག་ཚུ་གིས་དུས་ཚོད་ནམ་ཁོམ་ལ་སློབ་སྦྱོང་བྱ་ཆོག་པ་ཡིན།"

#: xmodule/course_block.py:967
msgid "Enable Subsection Prerequisites"
msgstr "ནང་གསེས་སྡེ་ཚན་གྱི་སྔོན་འགྲོའི་དགོས་མཁོ་ནུས་ལྡན་བྱེད་པ།"

#: xmodule/course_block.py:969
msgid ""
"Enter true or false. If this value is true, you can hide a subsection until "
"learners earn a minimum score in another, prerequisite subsection."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞིག་ཞོག། "
"གནས་འདི་བདེན་པ་ཡིན་ན་སློབ་གཉེར་བས་སྔོན་འགྲོའི་ནང་གསེས་སྡེ་ཚན་གཞན་ནས་ཐོབ་སྐར་གང་འཚམ་མ་བླངས་བར་དུ་ཁྱེད་ཀྱིས་ནང་གསེས་སྡེ་ཚན་ཞིག་སྐུང་ཆོག"
" ཡིན།"

#: xmodule/course_block.py:978
msgid "Course Learning Information"
msgstr "སློབ་ཚན་སྦྱོང་སྟངས་ཀྱི་གནས་ཚུལ།"

#: xmodule/course_block.py:979
msgid "Specify what student can learn from the course."
msgstr "སློབ་ཕྲུག་གིས་སློབ་ཚན་ནས་ཅི་ཞིག་བསླབ་ཐུབ་པ་ངོས་འཛིན་བྱོས།"

#: xmodule/course_block.py:985
msgid "Course Visibility For Unenrolled Learners"
msgstr "ཞུགས་ཐོ་མ་བཀོད་པའི་སློབ་ཕྲུག་གིས་སློབ་ཚན་འདི་བལྟ་ཐུབ་ཚད།"

#. Translators: the quoted words 'private', 'public_outline', and 'public'
#. must be left untranslated.  Leave them as English words.
#: xmodule/course_block.py:989
msgid ""
"Defines the access permissions for unenrolled learners. This can be set to "
"one of three values: 'private' (default visibility, only allowed for "
"enrolled students), 'public_outline' (allow access to course outline) and "
"'public' (allow access to both outline and course content)."
msgstr ""
"Defines the access permissions for unenrolled learners. This can be set to "
"one of three values: 'private' (default visibility, only allowed for "
"enrolled students), 'public_outline' (allow access to course outline) and "
"'public' (allow access to both outline and course content)."

#: xmodule/course_block.py:1003
msgid "Video Sharing Options"
msgstr "བརྙན་བརྒྱུད་སྐུར་གྱི་འདེམ་གསེས།"

#: xmodule/course_block.py:1005
msgid ""
"Specify the video sharing options for the course. This can be set to one of "
"three values: 'all-on', 'all-off' and 'per-video'. with 'per-video' as the "
"default."
msgstr ""
"སློབ་ཚན་གྱི་བརྙན་བརྒྱུད་སྐུལ་གྱི་གདམ་གསེས་གཏན་འཁེལ་བྱ། "
"གདམ་གསེས་རིགས་གསུམ་ཡོད། 'ཚང་མ་-ཆོག', 'ཚང་མ་-མི་ཆོག', 'བརྙན་-རེ་རེ་བཞིན་ཆོག' "
"ཡིན། རྨང་གཞིའི་སྒྲིག་འགོད་ནི་ 'བརྙན་-རེ་རེ་བཞིན་ཆོག' ཡིན།"

#: xmodule/course_block.py:1019
msgid "Force Flexible Grading for Peer ORAs"
msgstr "Force Flexible Grading for Peer ORAs"

#: xmodule/course_block.py:1020
msgid ""
"Setting this flag will force on the flexible grading option for all peer-"
"graded ORAs in this course."
msgstr ""
"དར་རྟགས་འདི་བསྒྲིགས་ན་འདིས་སློབ་ཚན་འདིའི་ནང་གི་གནས་རིམ་བྱས་པའི་བརྟག་དཔྱད་དྲི་བ་ཡོངས་"
" flexible grading ཅན་ལ་བསྒྲིག་འགྲོ་བ་ཡིན།"

#: xmodule/course_block.py:1040
msgid "Course Instructor"
msgstr "སློབ་ཚན་ལམ་སྟོན་པ།"

#: xmodule/course_block.py:1041
msgid "Enter the details for Course Instructor"
msgstr "སློབ་ཚན་ལམ་སྟོན་པའི་ཞིབ་ཕྲ་ཁོད།"

#: xmodule/course_block.py:1048
msgid "Add Unsupported Problems and Tools"
msgstr "བེད་སྤྱོད་མེད་པའི་དྲི་བ་དང་ལག་ཆ་ཁག་ཞོག"

#: xmodule/course_block.py:1050
msgid ""
"Enter true or false. If true, you can add unsupported problems and tools to "
"your course in Studio. Unsupported problems and tools are not recommended "
"for use in courses due to non-compliance with one or more of the base "
"requirements, such as testing, accessibility, internationalization, and "
"documentation."
msgstr ""
"Enter true or false. If true, you can add unsupported problems and tools to "
"your སློབ་ཚན in Studio. Unsupported problems and tools are not recommended "
"for use in སློབ་ཚན due to non-compliance with one or more of the base "
"requirements, such as testing, accessibility, internationalization, and "
"documentation."

#: xmodule/course_block.py:1057
msgid "Highlights Enabled for Messaging"
msgstr "འཕྲིན་ཐུང་གཏོང་བར་ནན་རྟགས་ནུས་ལྡན་བྱེད་པ།"

#: xmodule/course_block.py:1059
msgid ""
"Enter true or false. If true, any highlights associated with content in the "
"course will be messaged to learners at their scheduled time."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག "
"བདེན་པ་ཡིན་ན་སློབ་ཚན་ནང་ཡོད་པའི་ནང་དོན་དང་མཉམ་སྦྱོར་བྱས་པའི་ནན་རྟགས་སློབ་གཉེར་ལ་ཁོང་ཚོའི་དུས་བཅད་ནང་གཏོང་འགྲོ་བ་ཡིན།"

#: xmodule/course_block.py:1066
msgid "Course-wide Custom JS"
msgstr "སློབ་ཚན་གྱི་རྒྱ་ཞེང་གི་རྨང་གཞི་ JS"

#: xmodule/course_block.py:1067
msgid ""
"Enter Javascript resource URLs you want to be loaded globally throughout the"
" course pages."
msgstr ""
"ཁྱེད་ཀྱིས་སློབ་ཚན་དེའི་སྤྱི་ཡོངས་བཀོལ་སྤྱོད་བྱ་རྒྱུའི་Javascript "
"ཡི་རྒྱུ་ཆའི་དྲ་ཐག URLs ཞོག"

#: xmodule/course_block.py:1072
msgid "Course-wide Custom CSS"
msgstr "སློབ་ཚན་གྱི་རྒྱ་ཞེང་གི་རྨང་གཞི་ CSS"

#: xmodule/course_block.py:1073
msgid ""
"Enter CSS resource URLs you want to be loaded globally throughout the course"
" pages."
msgstr ""
"སློབ་ཚན་དེའི་ཤོག་ངོས་ནང་སྤྱི་ཡོངས་བཀོལ་སྤྱོད་བྱ་རྒྱུའི་CSS ཡི་རྒྱུ་ཆའི་དྲ་ཐག"
" URLs ནང་འཇུག་ཞོག།"

#: xmodule/course_block.py:1078
msgid "Other Course Settings"
msgstr "སློབ་ཚན་གྱི་སྒྲིག་འགོད་གཞན་ཁག"

#: xmodule/course_block.py:1080
msgid ""
"Any additional information about the course that the platform needs or that "
"allows integration with external systems such as CRM software. Enter a "
"dictionary of values in JSON format, such as { \"my_custom_setting\": "
"\"value\", \"other_setting\": \"value\" }"
msgstr ""
"Any additional information about the སློབ་ཚན that the platform needs or that"
" allows integration with external systems such as CRM software. Enter a "
"dictionary of values in JSON format, such as { \"my_custom_setting\": "
"\"value\", \"other_setting\": \"value\" }"

