msgstr ""
"ཁྱེད་ཀྱིས་འདི་ལ་མོས་མཐུན་ངེས་པར་བྱ་དགོས། {platform_name} {terms_of_service}"

#: openedx/core/djangoapps/user_authn/views/registration_form.py:1045
#, python-brace-format
msgid ""
"By creating an account, you agree to the                   "
