msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག། "
"བདེན་པ་ཡིན་ན་སློབ་ཚན་དེ་ཁ་པར་གྱི་ཁྱད་ཆོས་དང་མཐུན་པ་ཡིན།"

#: xmodule/course_block.py:493
msgid "Video Upload Credentials"
msgstr "བརྙན་ནང་འཇུག་ཐུབ་པའི་ཚད་འཛིན།"

#: xmodule/course_block.py:495
#, python-brace-format
msgid ""
"Enter the unique identifier for your course's video files provided by "
"{platform_name}."
msgstr ""
"{platform_name} "
"འདིས་མཁོ་སྤྲོད་བྱས་པའི་ཁྱེད་ཀྱི་སློབ་ཚན་བརྙན་ལ་དམིགས་བསལ་ངོས་འཛིན་བྱེད་ཞོག"

#: xmodule/course_block.py:500
msgid "Course Not Graded"
msgstr "སློབ་ཚན་མི་གནས་རིམ་པ།"

#: xmodule/course_block.py:501
msgid "Enter true or false. If true, the course will not be graded."
msgstr "བདེན་པ་ཡང་ན་རྫུན་པ་ཞིག་བྱིན། བདེན་པ་ཡིན་ན་སློབ་ཚན་དེ་གནས་རིམ་མི་བྱེད།"

#: xmodule/course_block.py:506
msgid "Disable Progress Graph"
msgstr "ཡར་རྒྱས་ཀྱི་རྩིས་རིས་སྒོ་ཁོག"

#: xmodule/course_block.py:507
msgid "Enter true or false. If true, students cannot view the progress graph."
msgstr ""
"བདེན་པ་དང་རྫུན་པ་གང་རུང་ཞོག། "
"བདེན་པ་ཡིན་ན་སློབ་ཕྲུག་གིས་ཡར་རྒྱས་ཀྱི་རྩིས་རིས་ལ་མི་མཐོང་།"

#: xmodule/course_block.py:512
msgid "PDF Textbooks"
msgstr "སློབ་དེབ་ཀྱི་PDF"

#: xmodule/course_block.py:513
msgid "List of dictionaries containing pdf_textbook configuration"
msgstr "སློབ་ཚན་གྱི་pdf བཀོད་སྒྲིག་ནང་འདུས་པའི་ཚིག་མཛོད་ཁག་གི་ཐོ་གཞུང་།"

#: xmodule/course_block.py:516
msgid "HTML Textbooks"
msgstr "སློབ་དེབ་ཁག་གི་ HTML"

#: xmodule/course_block.py:518
msgid ""
"For HTML textbooks that appear as separate tabs in the course, enter the "
