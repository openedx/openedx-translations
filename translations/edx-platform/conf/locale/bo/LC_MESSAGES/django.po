#: xmodule/video_block/video_xfields.py:208
msgid "Specify whether the video can be accessed publicly by learners."
msgstr ""
"སློབ་སྦྱོང་བྱེད་མཁན་གྱིས་བརྙན་དེ་ཡོངས་གྲགས་སུ་ལྟ་ཐུབ་མིན་གསལ་བཤད་བྱོས།"

#: xmodule/video_block/video_xfields.py:209
msgid "Public Access"
msgstr "སྤྱི་སྤྱོད་ཀྱི་ཆོག་མཆན་ཡོད།"

