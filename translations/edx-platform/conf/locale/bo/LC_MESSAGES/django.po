"ཁྱེད་ཀྱིས་གདམ་ཁ་འདི་བདམས་ན་ནི། "
"སློབ་ཚན་ཚོགས་མི་དང་ལས་བྱེད་ཡང་ན་འཛིན་སྐྱོང་མི་སྣ་ཁོ་ནས་ཤོག་ངོས་འདི་ལ་བལྟ་ཐུབ།"

#: xmodule/html_block.py:443
msgid "HTML for the additional pages"
msgstr "ཤོག་ངོས་སྣོན་མའི་HTML"

#: xmodule/html_block.py:461
msgid "List of course update items"
msgstr "སློབ་ཚན་ཁ་གསབ་དངོས་རིགས་ཀྱི་ཐོ་གཞུང་།"

#: xmodule/item_bank_block.py:68
msgid "Count"
msgstr "གྲངས་བརྩི།"

#: xmodule/item_bank_block.py:69
msgid ""
"Enter the number of components to display to each student. Set it to -1 to "
"display all components."
msgstr ""
"སློབ་ཕྲུག་རེ་རེ་ལ་སྟོན་རྒྱུའི་གྲུབ་ཆ་རེ་རེའི་ཨང་གྲངས་ཞོག "
"གྲུབ་ཆ་ཚང་མ་སྟོན་པར་དེ་ -1 ལ་བསྒྲིག"

#: xmodule/item_bank_block.py:82
msgid ""
"Determines whether a 'Reset Problems' button is shown, so users may reset "
"their answers and reshuffle selected items."
msgstr ""
"&#39;དཀའ་ངལ་སླར་སྒྲིག་&#39; མཐེབ་སྟོན་ཡོད་མེད་གཏན་འབེབས་བྱེད། "
"དེར་བརྟེན་སྤྱོད་མཁན་གྱིས་ལན་སླར་སྒྲིག་དང་འདེམས་སྒྲུག་བྱས་པའི་རྣམ་གྲངས་བསྐྱར་སྒྲིག་བྱེད་ཆོག"

#: xmodule/item_bank_block.py:480
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems. Please "
"specify a positive number of problems, or specify -1 to show all problems."
msgstr ""
"དེ་གི་སྐོར་དུ་བཅོས་ཡོད་པའི་འགྲེལ་བཤད་ནི་གང་ཡང་མེད། {count} "
"གྲུབ་ཐོབ་ཚུལ་གྱི་གནས་ཚུལ་སྟོན་དགོས། གྲུབ་ཐོབ་གྲངས་དང་པོ་གནད་དུ་བཀོད་དགོས། "
"ཡང་ན་ -1 གནད་དུ་བཀོད་ནས་གྲུབ་ཐོབ་ཚང་མ་སྟོན་དགོས།."

#: xmodule/item_bank_block.py:492
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems, but only "
"{actual} have been selected."
msgstr ""
"དེ་གི་སྒྲིག་སྟངས་བྱས་ཡོད་པའི་འབྲི་དོན་གྱི་སྒོ་ལ་འདུག་པའི་འབྲི་དོན་གྱི་གྲངས་གཅིག་ཡོད་རེད།"
" {count} འབྲི་དོན་སྟོན་དགོས་ཡོད་ཀྱི་རེད། དེ་ནས་ {actual} གཅིག་རེད།"

#: xmodule/library_content_block.py:57
msgid "Any Type"
