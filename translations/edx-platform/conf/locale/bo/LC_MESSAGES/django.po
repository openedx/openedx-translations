msgstr "ཡན་ལག་གཏན་འཁེལ་བྱེད་མི་ཐུབ།"

#: cms/djangoapps/contentstore/helpers.py:229
#: cms/djangoapps/contentstore/views/component.py:287
msgid "Problem Bank"
msgstr "དཀའ་ངལ་ཀྱི་གཞི་ཁང་།"

#: cms/djangoapps/contentstore/management/commands/recreate_upstream_links.py:55
msgid ""
"Recreate links for xblocks under all courses. NOTE: this can take long time "
"depending on number of course and xblocks"
msgstr ""
"སློབ་ཚན་ག་རེའི་ནང་དུ xblocks གི་འབྲེལ་ལམ་བསྐྱར་བཟོ་རོགས། དྲིལ་བརྡ། "
"སློབ་ཚན་དང xblocks གྱི་གྲངས་ཀ་ལྟོས་ནས་དུས་ཚོད་མང་པོ་འགྲོ་བར་བརྗེད་མ་རོགས།"

#: cms/djangoapps/contentstore/management/commands/recreate_upstream_links.py:67
msgid "Delete all and create links for given course(s)."
msgstr "གང་རུང་བཏོན་ཞིན་སློབ་ཚན་གྱི་འབྲེལ་ལམ་གསར་བཟོ།"

#: cms/djangoapps/contentstore/models.py:329
msgid ""
"Upstream block key (e.g. lct:...), this value cannot be null and is useful "
"to track upstream library blocks that do not exist yet or were deleted."
msgstr ""
"ཡར་འཛེགས་མེད་ཀྱི་ལྡེ་ཡིག (དཔེར་ན། lct:...), འདི་གི་རྣམ་པ་མ་སྟོང་མི་ཆོག "
"དེ་ཡིན་ནོར་བརྒྱུད་ཀྱི་དཔེ་དེབ་ཀྱི་རྒྱུན་ལམ་མེད་པ་ཡང་ན་བཏོན་བཏང་ཡོད་པའི་སྲུང་སྐྱོབ་ལ་ལེགས་ཤོམ་ཡོད།"

#: cms/djangoapps/modulestore_migrator/models.py:52
msgid "Key of the content source (a course or a legacy library)"
msgstr "ནང་དོན་འབྱུང་ཁུངས་ཀྱི་གནད་འགག (སློབ་ཚན་ནམ་དཔེ་མཛོད་རྙིང་པ།)"

#: cms/djangoapps/modulestore_migrator/models.py:59
msgid ""
"If set, the system will forward references of this source over to the target"
" of this migration"
msgstr ""
"གལ་ཏེ་སྒྲིག་འགོད་བྱས་ན། "
"མ་ལག་གིས་འབྱུང་ཁུངས་འདིའི་ལུང་འདྲེན་དེ་སྤོ་སྒྱུར་འདིའི་དམིགས་ཡུལ་ལ་བསྐུར་ངེས།"

#: cms/djangoapps/modulestore_migrator/models.py:111
msgid ""
"Should the migration preserve the location IDs of the existing blocks?If "
"not, then new, unique human-readable IDs will be generated based on the "
"block titles."
msgstr ""
"འགྲུལ་བཞག་འདིས་སྔོན་མེད་ཀྱི་ས་གནས་ཨང་རྟགས་སྲུང་དགོས་རེད་པས། "
"གལ་ཏེ་སྲུང་མི་བྱེད་ན་ནང་དོན་ཚན་མིང་གི་གཞི་བཙུགས་ནས་གསར་པ་དང་དོན་གྲུབ་ཅན་གྱི་ཨང་རྟགས་བསྐྲུན་འབད་ཚར་ཡོད་རེད།"

#: cms/djangoapps/modulestore_migrator/models.py:133
msgid ""
"Tracks the status of the task which is executing this migration. In a bulk "
"migration, the same task can be multiple migrations"
msgstr ""
"འདི་འཕྲིན་ལས་འདི་ལུ་ལས་ཀ་གནང་བའི་གནས་ཚད་རྟོགས་དགོས། "
"སྤྱིར་བཏང་འཕྲིན་འགྲོ་བའི་སྐབས་ལས་ཀ་གཅིག་གིས་འཕྲིན་འགྲོ་མང་པོ་བྱེད་ཐུབ།"

#: cms/lib/xblock/upstream_sync.py:255
msgid "Downstream is not an XBlock or is missing required UpstreamSyncMixin"
msgstr ""
"Downstream གཞི་སྒྲིག་ཆ་ཤས་མ་ཡིན་པ་ཡང་ན་ UpstreamSyncMixin "
"གི་དགོས་མཁོ་ཡོད་པ་མེད་པ་རེད།"

#: cms/lib/xblock/upstream_sync.py:275
msgid ""
"Updating content with children is not yet supported unless the upstream is a"
" container."
msgstr ""
"ཡིག་ཆ་གསར་བཟོ་བྱེད་པ་ནི་སྤྱི་བོ་གཙང་སྒྲིག་བྱེད་མི་ཚུགས་པ་ཡིན་པས། "
"ཡང་ན་ཡང་དག་གི་སྤྱི་བོ་སྒྲིག་བྱེད་དགོས་ཡོད།"

#: cms/lib/xblock/upstream_sync.py:281
msgid "Linked upstream library block was not found in the system"
msgstr ""
"སྒྲིག་སྒྲིག་བྱས་ཡོད་པའི་ཡིག་ཆའི་སྡེ་ཚན་གྱི་དབྱེ་ཚན་གཞི་བཙུགས་མ་ཡིན་པ་མ་ཐོབ་པར་བྱུང་བ།"

#: common/djangoapps/course_modes/admin.py:52
msgid ""
"OPTIONAL: After this date/time, users will no longer be able to submit "
"photos for verification.  This appies ONLY to modes that require "
"verification."
msgstr ""
"གདམ་ང་ཅན།: "
"ཟླ་ཚེས་སམ་/དུས་ཚོད་འདིའི་རྗེས་ནས་སྤྱོད་མཁན་ཚོས་ཁུངས་སྐྱེལ་གྱི་ཆེད་དུ་འདྲ་པར་འབུལ་སྤྲོད་བྱེད་མི་ཐུབ།"
" "
"འབུལ་སྤྲོད་འདི་ནི་ཁུངས་སྐྱེལ་དགོས་པའི་རྣམ་སྒྲིག་ཁོ་ན་ལ་རིགས་འབུལ་སྤྲོད་བྱེད་དགོས།"

#: common/djangoapps/course_modes/models.py:121
msgid ""
"OPTIONAL: This is the SKU (stock keeping unit) of this mode in the external "
"ecommerce service.  Leave this blank if the course has not yet been migrated"
" to the ecommerce service."
msgstr ""
"OPTIONAL: This is the SKU (stock keeping unit) of this mode in the external "
"ecommerce service.  Leave this blank if the སློབ་ཚན has not yet been "
"migrated to the ecommerce service."

#: common/djangoapps/course_modes/models.py:258
#, python-brace-format
msgid ""
"The {course_mode} course mode has a minimum price of {min_price}. You must "
"set a price greater than or equal to {min_price}."
msgstr ""
"The {course_mode} སློབ་ཚན་ཐབས་ལམ has a minimum price of {min_price}. You "
"must set a price greater than or equal to {min_price}."

#: common/djangoapps/student/admin.py:714
#, python-brace-format
msgid ""
"Please add a key/value 'THIRD_PARTY_AUTH_ONLY_DOMAIN/{site_email_domain}' in"
" SiteConfiguration model's site_values field."
msgstr ""
"Please add a key/value 'THIRD_PARTY_AUTH_ONLY_DOMAIN/{site_email_domain}' in"
" SiteConfiguration model's site_values field."

#: common/djangoapps/student/models/course_enrollment.py:1741
msgid ""
"The window of time after enrolling during which users can be granted a "
"refund, represented in microseconds. The default is 14 days."
msgstr ""
"The window of time after enrolling during which users can be granted a "
"refund, represented in microseconds. The default is 14 days."

#: common/djangoapps/student/models/course_enrollment.py:1763
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     user_id, username, email, course_id, "
"is_verified, verification_date"
msgstr ""
"It expects that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     user_id, སྤྱོད་མཁན་མིང་, ཡིག་ཟམ, སློབ་ཚན, "
"is_verified, verification_date"

#: common/djangoapps/student/models/course_enrollment.py:1777
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     course_id, username, mode"
msgstr ""
"It expects that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     སློབ་ཚན_id, སྤྱོད་མཁན་མིང་, mode"

#: common/djangoapps/student/models/user.py:1745
msgid ""
"An employee (a user whose email has current site's domain name) whose email "
"exists in this model, can be able to login from login screen through email "
"and password. And if any employee's email doesn't exist in this model then "
"that employee can login via third party authentication backend only."
msgstr ""
"An employee (a user whose ཡིག་ཟམ has current site's domain མིང་) whose "
"ཡིག་ཟམ exists in this model, can be able to login from login screen through "
"ཡིག་ཟམ and password. And if any employee's ཡིག་ཟམ doesn't exist in this "
"model then that employee can login via third party authentication backend "
"only."

#: common/djangoapps/student/models/user.py:1760
msgid ""
"It expect that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     username, current_email, desired_email"
msgstr ""
"It expects that the data will be provided in a csv file format with"
"                     first row being the header and columns will be as "
"follows:                     སྤྱོད་མཁན་མིང་, current_email, desired_email"

#: common/djangoapps/student/views/dashboard.py:607
#, python-brace-format
msgid ""
"Check your {email_start}{email}{email_end} inbox for an account activation "
"link from {platform_name}. If you need help, contact "
"{link_start}{platform_name} Support{link_end}."
msgstr ""
"ཁྱེད་ཀྱིས་རང་གི་ {email_start}{email}{email_end} གློག་འཕྲིན་ནང་གཟིགས་རོགས། "
"དེར་ {platform_name} "
"འདི་བརྒྱུད་ནས་ཁ་བྱང་གི་བྱེད་ནུས་སྒོ་འབྱེད་སའི་དྲ་ཐག་ཅིག་བསྐུར་ཡོད། "
"དེའི་ཐད་ཁྱེད་ལ་རམ་འདེགས་དགོས་ན། {link_start}{platform_name} "
"Support{link_end} འདིར་འབྲེལ་བ་བྱོས།"

#: common/djangoapps/student/views/dashboard.py:632
