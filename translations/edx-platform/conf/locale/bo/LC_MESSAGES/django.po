msgstr "འགའ་རེ་འགྲིག་པ།"

#: xmodule/capa_block.py:1386
msgid "Answer submitted."
msgstr "ལན་འདེབས་འབུལ་སྤྲོད་བྱས་ཡོད།"

#. Translators: 'closed' means the problem's due date has passed.
#. You may no longer attempt to solve the problem.
#: xmodule/capa_block.py:1778 xmodule/capa_block.py:2097
msgid "Problem is closed."
msgstr "དྲི་བ་སྒོ་བརྒྱབ་ཡོད།"

#: xmodule/capa_block.py:1784
msgid "Problem must be reset before it can be submitted again."
msgstr ""
"དྲི་བ་བསྐྱར་དུ་འབུལ་སྤྲོད་ཐུབ་པ་མ་བྱས་སྔོན་དྲི་བ་ངེས་པར་བསྐྱར་སྒྲིག་བྱ་དགོས།"

#: xmodule/capa_block.py:1794
#, python-brace-format
msgid "You must wait at least {wait} seconds between submissions."
msgstr "ཁྱེད་ཀྱིས་འབུལ་སྤྲོད་སོ་སོའི་བར་ལ་དམའ་མཐའ་ཡང་ {wait} སྒུག་དགོས།"

#: xmodule/capa_block.py:1804
#, python-brace-format
msgid ""
"You must wait at least {wait_secs} between submissions. {remaining_secs} "
"remaining."
msgstr ""
"ཁྱེད་ཀྱིས་འབུལ་སྤྲོད་སོ་སོའི་བར་ལ་དམའ་མཐའ་ཡང་ {wait_secs} སྒུག་དགོས། ད་དུང་ "
"{remaining_secs} ལྷག་འདུག།"

#: xmodule/capa_block.py:1977
#, python-brace-format
msgid "{num_hour} hour"
msgid_plural "{num_hour} hours"
msgstr[0] "{num_hour} ཆུ་ཚོད།"

#: xmodule/capa_block.py:1982
#, python-brace-format
msgid "{num_minute} minute"
msgid_plural "{num_minute} minutes"
msgstr[0] "{num_minute}སྐར་མ།"

#: xmodule/capa_block.py:1988
#, python-brace-format
msgid "{num_second} second"
msgid_plural "{num_second} seconds"
msgstr[0] "སྐར་ཆ་{num_second}"

#: xmodule/capa_block.py:2105
msgid "Problem needs to be reset prior to save."
msgstr "དྲི་བ་ཉར་ཚགས་བྱེད་པར་དེ་སྔ་མོ་ནས་ངེས་པར་བསྐྱར་སྒྲིག་བྱ་དགོས།"

#: xmodule/capa_block.py:2114
msgid "Your answers have been saved."
msgstr "ཁྱེད་ཀྱི་ལན་འདེབས་རྣམས་ཉར་ཚགས་བྱས་ཡོད།"

#: xmodule/capa_block.py:2116
#, python-brace-format
msgid ""
"Your answers have been saved but not graded. Click '{button_name}' to grade "
"them."
msgstr ""
"ཁྱེད་ཀྱི་ལན་འདེབས་རྣམས་ཉར་ཚགས་བྱས་ཡོད། འོན་ཀྱང་རིམ་པ་བྱས་མེད། "
"རིམ་པ་བསྒྲིག་ན་ '{button_name}' འདིའི་ཐོག་སྣུན།"

#. Translators: 'closed' means the problem's due date has passed.
#. You may no longer attempt to solve the problem.
#: xmodule/capa_block.py:2145
msgid "You cannot select Reset for a problem that is closed."
msgstr "སྒོ་བརྒྱབ་ཟིན་པའི་དྲི་བ་ཡིན་ན་ཁྱེད་ཀྱིས་བསྐྱར་སྒྲིག་འདེམ་མི་ཐུབ།"

#: xmodule/capa_block.py:2153
msgid "You must submit an answer before you can select Reset."
msgstr ""
"བསྐྱར་སྒྲིག་འདེམ་པར་སྔོན་ལ་ཁྱེད་ཀྱིས་ལན་འདེབས་ཤིག་ངེས་པར་འབུལ་སྤྲོད་བྱས་ཡོད་དགོས།"

#. Translators: 'rescoring' refers to the act of re-submitting a student's
#. solution so it can get a new score.
#: xmodule/capa_block.py:2209
msgid "Problem's definition does not support rescoring."
msgstr "དྲི་བའི་འགྲེལ་བཤད་འདི་ཐོབ་སྐར་སྒྲིག་པར་རམ་འདེགས་མི་ཆོག་པར་འདུག།"

#: xmodule/capa_block.py:2214
msgid "Problem must be answered before it can be graded again."
msgstr "དྲི་བ་ལ་ལན་འདེབས་དགོས་ཡིན་པས་དེ་རྗེས་སྒྲིག་ཐུབ་ཀྱི་རེད།"

#: xmodule/conditional_block.py:91
msgid "Conditional"
msgstr "ཆ་རྐྱེན་ཅན།"

#: xmodule/conditional_block.py:95
msgid "List of urls of children that are references to external modules"
msgstr ""
"བྱིས་པའི་དྲ་ཐག་ཁག་གི་ཐོ་གཞུང་། དེ་དག་ནི་ཕྱིའི་མ་དཔེ་ཁག་གི་རྒྱུ་ཆ་ཡིན་པ།"

#: xmodule/conditional_block.py:100
msgid "Source Components"
msgstr "ཡོང་ཁུངས་ཀྱི་གྲུབ་ཆ་རྣམས།"

#: xmodule/conditional_block.py:101
msgid ""
"The component location IDs of all source components that are used to "
"determine whether a learner is shown the content of this conditional block. "
"Copy the component location ID of a component from its Settings dialog in "
"Studio."
msgstr ""
"སློབ་སྦྱོང་བྱེད་མཁན་ལ་ཆ་རྐྱེན་ཅན་གྱི་བཀག་སྡོམ་འདིའི་ནང་དོན་སྟོན་ཡོད་མེད་གཏན་འབེབས་བྱེད་པར་བེད་སྤྱོད་བྱེད་པའི་ཐོན་ཁུངས་ཆ་ཤས་ཚང་མའི་ཆ་ཤས་གནས་ཡུལ་IDs"
" ཡིན། སྒྲིག་བཀོད་ཌའི་ལོག་ནས་ཆ་ཤས་ཤིག་གི་ཆ་ཤས་གནས་ཡུལ་ID འདྲ་བཤུས་བྱེད།"

#: xmodule/conditional_block.py:108
