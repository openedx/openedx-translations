msgstr[0] "འགྲིག་མེད་པ་ ({progress} points)"

#: xmodule/capa_block.py:1372
#, python-brace-format
msgid "Correct ({progress} point)"
msgid_plural "Correct ({progress} points)"
msgstr[0] "འགྲིག་པ་ ({progress} points)"

#: xmodule/capa_block.py:1379
#, python-brace-format
msgid "Partially correct ({progress} point)"
msgid_plural "Partially correct ({progress} points)"
msgstr[0] "འགའ་རེ་འགྲིག་པ་ ({progress} points)"

#: xmodule/capa_block.py:1384
