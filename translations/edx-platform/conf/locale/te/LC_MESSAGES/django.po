msgstr "{section_type} {index} విడుదల కాలేదు - 0% (?/?)"

#: xmodule/graders.py:415
#, python-brace-format
msgid "The lowest {drop_count} {section_type} scores are dropped."
msgstr "అత్యల్ప {drop_count} {section_type} స్కోర్ పడిపోయింది."

