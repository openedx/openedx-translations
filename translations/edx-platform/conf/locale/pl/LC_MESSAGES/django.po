msgstr[0] ""
"Podana biblioteka jest skonfigurowana do pobierania problemu {count} , "
msgstr[1] ""
"Podana biblioteka jest skonfigurowana do pobierania problemów {count} , "
msgstr[2] ""
"Podana biblioteka jest skonfigurowana do pobierania problemów {count} , "
msgstr[3] ""
"Podana biblioteka jest skonfigurowana do pobierania problemów {count} , "

#: xmodule/library_content_block.py:360
