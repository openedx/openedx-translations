msgid "Action required: Enter a valid date."
msgstr "Wymagane działanie: wprowadź prawidłową datę."

#: cms/static/js/models/group.js:41
msgid "Group name is required"
msgstr "Nazwa grupy jest wymagana"

#: cms/static/js/models/group_configuration.js:17
msgid "Group A"
msgstr "Grupa A"

#: cms/static/js/models/group_configuration.js:21
msgid "Group B"
msgstr "Grupa B"

#: cms/static/js/models/group_configuration.js:91
msgid "Group Configuration name is required."
msgstr "Nazwa konfiguracji grupy jest wymagana."

#: cms/static/js/models/group_configuration.js:98
msgid "There must be at least one group."
msgstr "Musi być co najmniej jedna grupa."

#: cms/static/js/models/group_configuration.js:115
msgid "All groups must have a name."
msgstr "Wszystkie grupy muszą mieć nazwę."

#: cms/static/js/models/group_configuration.js:123
msgid "All groups must have a unique name."
msgstr "Wszystkie grupy muszą mieć unikalną nazwę."

#: cms/static/js/models/settings/course_details.js:59
msgid "The course must have an assigned start date."
msgstr "Kurs musi mieć przypisaną datę rozpoczęcia."

#: cms/static/js/models/settings/course_details.js:63
msgid "The course end date must be later than the course start date."
msgstr ""
"Data zakończenia kursu musi być późniejsza niż data rozpoczęcia kursu."

#: cms/static/js/models/settings/course_details.js:68
msgid "The course start date must be later than the enrollment start date."
msgstr ""
"Data rozpoczęcia kursu musi być późniejsza niż data rozpoczęcia rejestracji."

#: cms/static/js/models/settings/course_details.js:74
msgid "The enrollment start date cannot be after the enrollment end date."
msgstr ""
"Data rozpoczęcia rejestracji nie może być późniejsza niż data zakończenia "
"rejestracji."

#: cms/static/js/models/settings/course_details.js:78
msgid "The enrollment end date cannot be after the course end date."
msgstr ""
"Data zakończenia zapisów nie może być późniejsza niż data zakończenia kursu."

#: cms/static/js/models/settings/course_details.js:83
msgid "The certificate available date must be later than the course end date."
msgstr ""
"Data udostępnienia certyfikatu musi być późniejsza niż data zakończenia "
"kursu."

#: cms/static/js/models/settings/course_details.js:93
msgid "The certificate display behavior must be one of: {behavior_options}"
msgstr ""
"Zachowanie wyświetlania certyfikatu musi być następujące: {behavior_options}"

#: cms/static/js/models/settings/course_details.js:108
msgid ""
"The certificates display behavior must be {valid_option} if certificate "
"available date is set."
msgstr ""
"Zachowanie wyświetlania certyfikatów musi mieć {valid_option} , jeśli "
"ustawiono datę dostępności certyfikatu."

#: cms/static/js/models/settings/course_details.js:118
msgid "Key should only contain letters, numbers, _, or -"
msgstr "Klucz powinien zawierać tylko litery, cyfry, _ lub -"

#: cms/static/js/models/settings/course_details.js:129
msgid "Please enter an integer between %(min)s and %(max)s."
msgstr "Proszę wprowadzić liczbę całkowitą pomiędzy %(min)s i %(max)s ."

#: cms/static/js/models/settings/course_grader.js:27
msgid "The assignment type must have a name."
msgstr "Typ przypisania musi mieć nazwę."

#: cms/static/js/models/settings/course_grader.js:32
msgid "There's already another assignment type with this name."
msgstr "Istnieje już inny typ przypisania o tej nazwie."

#: cms/static/js/models/settings/course_grader.js:39
msgid "Please enter an integer between 0 and 100."
msgstr "Wprowadź liczbę całkowitą z zakresu od 0 do 100."

#: cms/static/js/models/settings/course_grader.js:54
msgid "Please enter an integer greater than 0."
msgstr "Wprowadź liczbę całkowitą większą niż 0."

#: cms/static/js/models/settings/course_grader.js:61
msgid "Please enter non-negative integer."
msgstr "Proszę wprowadzić nieujemną liczbę całkowitą."

#: cms/static/js/models/settings/course_grader.js:66
msgid "You must have at least one undroppable <%- types %> assignment."
msgstr ""
"Musisz mieć co najmniej jedno przypisanie &lt;%-type%&gt;, którego nie można"
" upuścić."

#: cms/static/js/models/settings/course_grading_policy.js:79
msgid "Grace period must be specified in HH:MM format."
msgstr "Okres karencji należy określić w formacie GG:MM."

#: cms/static/js/models/settings/course_grading_policy.js:90
msgid "Not able to set passing grade to less than %(minimum_grade_cutoff)s%."
msgstr ""
"Nie można ustawić oceny pozytywnej na mniej niż %(minimum_grade_cutoff)s %."

#: cms/static/js/models/textbook.js:62
msgid "Textbook name is required"
msgstr "Nazwa podręcznika jest wymagana"

#: cms/static/js/models/textbook.js:68
msgid "Please add at least one chapter"
msgstr "Proszę, dodaj przynajmniej jeden rozdział"

#: cms/static/js/models/textbook.js:81
msgid "All chapters must have a name and asset"
msgstr "Wszystkie rozdziały muszą mieć nazwę i zasób"

#: cms/static/js/models/uploads.js:17
msgid ""
"Only <%- fileTypes %> files can be uploaded. Please select a file ending in "
"<%- (fileExtensions) %> to upload."
msgstr ""
"Można przesyłać tylko pliki &lt;%-fileTypes%&gt;. Wybierz plik kończący się "
"na &lt;%- (fileExtensions) %&gt; do przesłania."

