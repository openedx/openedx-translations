#: apps/badges/models.py
msgid ""
"Public signal type. Use namespaced types, e.g: "
"\"org.openedx.learning.student.registration.completed.v1\""
msgstr ""
"Тип публичного сигнала. Используйте типы с пространством имен, например: "
"\"org.openedx.learning.student.registration.завершено.v1\""

#: apps/credentials/models.py
msgid ""
"The certificate available date and time that is set in Studio and copied to "
"Credentials. This should be edited in Studio."
msgstr ""
"Дата и время доступности Сертификата устанавливают в студии и копируют в "
"Credentials. Это должно быть отредактировано в студии."

#: apps/verifiable_credentials/admin.py
msgid "Issuer ID"
msgstr "Идентификатор эмитента"

#: apps/verifiable_credentials/admin.py
msgid "At least one Issuer must be always enabled!"
msgstr "Хотя бы один эмитент должен быть всегда включен!"

#: apps/verifiable_credentials/composition/open_badges.py
msgid "Open Badges Specification v3.0"
msgstr "Открытая спецификация значков v3.0"

#: apps/verifiable_credentials/composition/open_badges.py
msgid "Open Badges Specification v3.0.1"
msgstr "Открытая спецификация значков v3.0.1"

#: apps/verifiable_credentials/composition/status_list.py
#: apps/verifiable_credentials/storages/status_list.py
msgid "Status List 2021"
msgstr "Список статусов 2021"

#: apps/verifiable_credentials/composition/verifiable_credentials.py
msgid "Verifiable Credentials Data Model v1.1"
msgstr "Модель данных проверяемых учетных данных v 1.1"

#: apps/verifiable_credentials/issuance/main.py
#, python-brace-format
msgid "Couldn't find such issuance line: [{issuance_uuid}]"
msgstr "Не удалось найти такую строку выдачи: [{issuance_uuid}]"

#: apps/verifiable_credentials/issuance/main.py
#, python-brace-format
msgid "Seems credential isn't active anymore: [{credential_id}]"
msgstr "Кажется, учетные данные больше не активны: [{credential_id}]"

#: apps/verifiable_credentials/issuance/main.py
msgid "Provided data didn't validate"
msgstr "Предоставленные данные не прошли проверку"

#: apps/verifiable_credentials/issuance/main.py
msgid "Issued verifiable credential can't be verified!"
msgstr "Выданные проверяемые учетные данные не могут быть проверены!"

#: apps/verifiable_credentials/issuance/models.py
msgid "Related Open edX learner credential"
msgstr "Связанные учетные данные слушателя Open edX"

#: apps/verifiable_credentials/issuance/models.py
msgid "Completeness indicator"
msgstr "Индикатор завершённости"

#: apps/verifiable_credentials/issuance/models.py
msgid "Issuer DID"
msgstr "DID Эмитента"

#: apps/verifiable_credentials/issuance/models.py
msgid "Target storage identifier"
msgstr "Идентификатор целевого хранилища"

#: apps/verifiable_credentials/issuance/models.py
msgid "Verifiable credential subject DID"
msgstr "Поддающийся проверке учетный предмет DID"

#: apps/verifiable_credentials/issuance/models.py
msgid "Verifiable credential specification to use"
msgstr "Поддающаяся проверке спецификация учетных данных для использования"

#: apps/verifiable_credentials/issuance/models.py
msgid "Defines a position in the Status List sequence"
msgstr "Определяет позицию в последовательности Списка состояний"

#: apps/verifiable_credentials/issuance/models.py
msgid "Keeps track on a corresponding user credential's status"
msgstr "Отслеживает статус соответствующих учетных данных пользователя"

#: apps/verifiable_credentials/issuance/models.py
msgid "program certificate"
msgstr "сертификат программы"

#: apps/verifiable_credentials/issuance/models.py
msgid "course certificate"
msgstr "сертификат курса"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid "program certificate for passing a program {program_title}"
msgstr "Сертификат на прохождение программы {program_title}"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ", with total {hours_of_effort} Hours of effort required to complete it"
msgstr ""
", с общим количеством {hours_of_effort} часов усилий, необходимых для его "
"завершения"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ""
"{credential_type} is granted on program {program_title} completion offered "
"by {organizations}, in collaboration with {platform_name}. The "
"{program_title} program includes {course_count} course(s){effort_info}."
msgstr ""
"{credential_type} предоставляется после завершения программы "
"{program_title}, предложенной {organizations} в сотрудничестве с "
"{platform_name}. Программа {program_title} включает {course_count} курсов "
"{effort_info}."

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ""
"{recipient_fullname} successfully completed all courses and received passing"
" grades for a Professional Certificate in {program_title} a program offered "
"by {organizations}, in collaboration with {platform_name}."
msgstr ""
"{recipient_fullname} успешно завершил(а) все курсы и получил(а) проходные "
"оценки для профессионального Сертификата по программе {program_title}, "
"предлагаемой {organizations} в сотрудничестве с {platform_name}."

#: apps/verifiable_credentials/issuance/models.py
msgid "recipient"
msgstr "получатель"

#: apps/verifiable_credentials/issuance/models.py
msgid ""
"Issuer secret key. See: https://w3c-ccg.github.io/did-method-"
"key/#ed25519-x25519"
msgstr ""
"Секретный ключ эмитента. См.: https://w3c-ccg.github.io/did-method-"
"key/#ed25519-x25519"

#: apps/verifiable_credentials/issuance/status_list.py
#, python-brace-format
msgid "Status List generation failed: [{issuer_id}]"
msgstr "Не удалось создать список состояний: [{issuer_id}]"

#: apps/verifiable_credentials/issuance/utils.py
msgid ""
"There are no enabled Issuance Configurations for some reason! At least one "
"must be always active."
msgstr ""
"По какой-то причине нет включенных конфигураций выдачи! По крайней мере, "
"одну из них нужно всегда активировать."

#: apps/verifiable_credentials/management/commands/create_default_issuer.py
#, python-brace-format
msgid "Verifiable Credentials feature is not enabled [{feature_name}]"
msgstr ""
"Характеристика проверяемых учетных данных не включена [{feature_name}]"

#: apps/verifiable_credentials/rest_api/v1/views.py
msgid "Mandatory data is missing"
msgstr "Отсутствуют обязательные данные"

#: apps/verifiable_credentials/rest_api/v1/views.py
msgid "Credential identifier must be valid UUID: ['credential_uuid']"
msgstr ""
"Идентификатор учетных данных должен быть действительным UUID: "
"['credential_uuid']"

#: apps/verifiable_credentials/rest_api/v1/views.py
#, python-format
msgid "No such user credential [%(credential_uuid)s]"
msgstr "Нет таких учетных данных пользователя [%(credential_uuid)s]"

#: apps/verifiable_credentials/rest_api/v1/views.py
#, python-brace-format
msgid ""
"Provided storage backend ({storage_id}) isn't active.                 "
"Storages: {active_storages}"
msgstr ""
"Предоставленная серверная часть хранилища ({storage_id}) неактивна. "
"Хранилища: {active_storages}"

#: apps/verifiable_credentials/rest_api/v1/views.py
#, python-brace-format
msgid "Can't find an Issuer with such ID [{issuer_id}]"
msgstr "Не удается найти эмитента с таким идентификатором [{issuer_id}]"

#: apps/verifiable_credentials/storages/learner_credential_wallet.py
msgid "Learner Credential Wallet"
msgstr "Кошелёк для слушателя учетные данные"

#: templates/_footer.html
msgid "Powered by"
msgstr "Работает на"

#: templates/credentials/base.html
#, python-format
msgid ""
"You worked hard to earn your certificate from %(platform_name)s — share it "
"with colleagues, friends, and family to get the word out about what you "
"mastered in %(program_display_name)s."
msgstr ""
"Вы усердно работали, чтобы заработать свой сертификат %(platform_name)s — "
"поделитесь им с коллегами, друзьями и семьей, чтобы рассказать о том, чему "
"вы научились в %(program_display_name)s."

#: templates/credentials/edx_ace/common/base_body.html
#, python-format
msgid "Go to %(platform_name)s Home Page"
msgstr "Перейдите на %(platform_name)s Главную страницу"

