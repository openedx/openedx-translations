msgid "Related Open edX learner credential"
msgstr "Zugehörige Open edX-Lernberechtigungsnachweise"

#: apps/verifiable_credentials/issuance/models.py
msgid "Completeness indicator"
msgstr "Vollständigkeitsindikator"

#: apps/verifiable_credentials/issuance/models.py
msgid "Issuer DID"
msgstr "Emittent DID"

#: apps/verifiable_credentials/issuance/models.py
msgid "Target storage identifier"
msgstr "Zielspeicher-ID"

#: apps/verifiable_credentials/issuance/models.py
msgid "Verifiable credential subject DID"
msgstr "Überprüfbarer Berechtigungsnachweis des Subjekts DID"

#: apps/verifiable_credentials/issuance/models.py
msgid "Verifiable credential specification to use"
msgstr "Zu verwendende überprüfbare Anmeldeinformationsspezifikation"

#: apps/verifiable_credentials/issuance/models.py
msgid "Defines a position in the Status List sequence"
msgstr "Definiert eine Position in der Statuslistensequenz"

#: apps/verifiable_credentials/issuance/models.py
msgid "Keeps track on a corresponding user credential's status"
msgstr "Verfolgt den Status der entsprechenden Benutzeranmeldeinformationen"

#: apps/verifiable_credentials/issuance/models.py
msgid "program certificate"
msgstr "Programmzertifikat"

#: apps/verifiable_credentials/issuance/models.py
msgid "course certificate"
msgstr "Kurszertifikat"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid "program certificate for passing a program {program_title}"
msgstr "Programmzertifikat für das Bestehen eines Programms {program_title}"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ", with total {hours_of_effort} Hours of effort required to complete it"
msgstr ""
", mit insgesamt {hours_of_effort} Arbeitsaufwand, der für die Fertigstellung"
" erforderlich ist"

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ""
"{credential_type} is granted on program {program_title} completion offered "
"by {organizations}, in collaboration with {platform_name}. The "
"{program_title} program includes {course_count} course(s){effort_info}."
msgstr ""
"{credential_type} wird nach Abschluss des Programms {program_title} gewährt,"
" das von {organizations} in Zusammenarbeit mit {platform_name} angeboten "
"wird. Das {program_title}-Programm umfasst {course_count} Kurs(e) "
"{effort_info} ."

#: apps/verifiable_credentials/issuance/models.py
#, python-brace-format
msgid ""
"{recipient_fullname} successfully completed all courses and received passing"
" grades for a Professional Certificate in {program_title} a program offered "
"by {organizations}, in collaboration with {platform_name}."
msgstr ""
"{recipient_fullname} hat alle Kurse erfolgreich abgeschlossen und die "
"bestandene Note für ein Berufszertifikat in {program_title} erhalten, einem "
"Programm, das von {organizations} in Zusammenarbeit mit {platform_name} "
"angeboten wird."

#: apps/verifiable_credentials/issuance/models.py
msgid "recipient"
msgstr "Empfänger"

#: apps/verifiable_credentials/issuance/models.py
msgid ""
"Issuer secret key. See: https://w3c-ccg.github.io/did-method-"
"key/#ed25519-x25519"
msgstr ""
"Geheimer Schlüssel des Ausstellers. Siehe: https://w3c-ccg.github.io/did-"
"method-key/#ed25519-x25519"

#: apps/verifiable_credentials/issuance/status_list.py
#, python-brace-format
msgid "Status List generation failed: [{issuer_id}]"
msgstr "Generierung der Statusliste fehlgeschlagen: [ {issuer_id} ]"

#: apps/verifiable_credentials/issuance/utils.py
msgid ""
"There are no enabled Issuance Configurations for some reason! At least one "
"must be always active."
msgstr ""
"Aus irgendeinem Grund sind keine Ausstellungskonfigurationen aktiviert! "
"Mindestens einer muss immer aktiv sein."

#: apps/verifiable_credentials/management/commands/create_default_issuer.py
#, python-brace-format
msgid "Verifiable Credentials feature is not enabled [{feature_name}]"
msgstr ""
"Die Funktion „Überprüfbare Anmeldeinformationen“ ist nicht aktiviert [ "
"{feature_name} ]"

