#, python-brace-format
msgid "Couldn't find such issuance line: [{issuance_uuid}]"
msgstr "Diese Ausgabezeile konnte nicht gefunden werden: [ {issuance_uuid} ]"

#: apps/verifiable_credentials/issuance/main.py
#, python-brace-format
msgid "Seems credential isn't active anymore: [{credential_id}]"
msgstr ""
"Anmeldeinformationen scheinen nicht mehr aktiv zu sein: [ {credential_id} ]"

#: apps/verifiable_credentials/issuance/main.py
msgid "Provided data didn't validate"
msgstr "Die bereitgestellten Daten wurden nicht validiert"

#: apps/verifiable_credentials/issuance/main.py
msgid "Issued verifiable credential can't be verified!"
msgstr "Der ausgestellte überprüfbare Ausweis kann nicht überprüft werden!"

