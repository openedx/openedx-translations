#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "აკლია LTI 1.3 ავთენტიფიკაციის ტოკენი."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr ""
"არასწორი ტოკენის სათაური. არ არის მითითებული ავთენტიფიკაციის მონაცემები."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"არასწორი ტოკენის სათაური. ტოკენის სტრიქონში არ უნდა იყოს დამატებითი "
"სივრცეები."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI კონფიგურაცია არ მოიძებნა."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "არასწორი ტოკენის ხელმოწერა."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "ენდპოინტის URL-ში მოქმედი მომხმარებლის ID ვერ მოიძებნა"

#: lti_xblock.py:147
msgid "New"
msgstr "ახალი"

#: lti_xblock.py:151
msgid "Database"
msgstr "მონაცემთა ბაზა"

#: lti_xblock.py:154
msgid "Existing"
msgstr "არსებული"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "ხილვადი სახელი"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"შეიყვანეთ სახელი, რომელსაც მოსწავლეები ხედავენ ამ კომპონენტისთვის. ეს სახელი"
" შეიძლება გამოჩნდეს ანგარიშებშიც."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI მომხმარებელი"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "მონაცემთა გაზიარების შეტყობინება"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"შეიყვანეთ მოკლე შეტყობინება ხელსაწყოს შესახებ. გამოიყენეთ ეს ველი იმის "
"ასახსნელად, თუ რატომ შეიძლება იყოს მასთან მოსწავლის მონაცემები გაზიარებული."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "კონფიგურაციის ტიპი"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"აირჩიეთ „ახალი“ ახალი LTI ხელსაწყოს კონფიგურაციისთვის. თუ თქვენმა ადმინმა "
"მოგაწოდათ არსებული ხელახლა გამოსაყენებელი ხელსაწყოს კონფიგურაციის ID, "
"აირჩიეთ „არსებული“ და შეიყვანეთ ის მარჯვნივ მდებარე ტექსტურ ველში."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI ვერსია"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "აირჩიეთ LTI ვერსია, რომელსაც თქვენი ხელსაწყო მხარს უჭერს."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "LTI-ის ხელახალი გამოყენების ID"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "შეიყვანეთ არსებული ხელსაწყოს კონფიგურაციის ID."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti 1.3 პასპორტის ID, რომელიც მიუთითებს Lti1p3Passport ცხრილზე"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "გაშვების URL"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"შეიყვანეთ ამ ხელსაწყოს გაშვების URL. LTI 1.3-ისთვის ეს არის URL, რომელსაც "
"Open edX იყენებს ხელსაწყოს გასაშვებად."

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"შეიყვანეთ ხელსაწყოს OIDC შესვლის ინიცირების URL. Open edX იყენებს ამ URL-ს "
"LTI 1.3 შესვლის პროცესის დასაწყებად."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "რეგისტრირებული გადამისამართების URI-ები"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"შეიყვანეთ გადამისამართების URI-ები, რომელთა გამოყენების უფლებაც ამ ხელსაწყოს"
" აქვს შესვლისას, მაგ., [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. დატოვეთ ცარიელი, რათა ნაგულისხმევად "
"გამოიყენოთ გაშვების URL და ღრმა ბმულის URL."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "ხელსაწყოს საჯარო გასაღების რეჟიმი"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"აირჩიეთ, როგორ მიიღებს Open edX ხელსაწყოს საჯარო გასაღებს ხელმოწერილი "
"შეტყობინებების ვალიდაციისთვის."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "ხელსაწყოთა გასაღების ნაკრების URL"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"შეიყვანეთ ხელსაწყოს JWK გასაღებების ნაკრების URL. Open edX ამ URL-ს იყენებს "
"ხელმოწერილი შეტყობინებების ვალიდაციისთვის საჭირო საჯარო გასაღებების "
"მოსაძიებლად."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "ხელსაწყოს საჯარო გასაღები"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"შეიყვანეთ ხელსაწყოს საჯარო გასაღები PEM ფორმატში (იწყება -----BEGIN PUBLIC "
"KEY-----). გამოიყენეთ ეს, როდესაც ხელსაწყო პირდაპირ გთავაზობთ სტატიკურ "
"საჯარო გასაღებს."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "სახელები და როლები (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"ჩართეთ ეს, რათა ხელსაწყოს მიეცეს საშუალება, წვდომა ჰქონდეს ჩარიცხული "
"მოსწავლეების სახელებსა და როლებზე, თუ ხელსაწყო მხარს უჭერს NRPS-ს."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "ღრმა დაბმულობა"

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "ღრმა ბმულის საწყისი URL"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"შეიყვანეთ ამ ხელსაწყოს ღრმა ბმულის URL. თუ ხელსაწყო არ აკონკრეტებს მას, "
"შეიყვანეთ „გაშვების URL“ აქ."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "დავალება და შეფასებები"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "დეკლარაციული"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "პროგრამული"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "გამორთულია"

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI პასპორტის ID"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"შეიყვანეთ ამ ხელსაწყოს გაშვების URL. LTI 1.1/1.2-ისთვის ეს არის URL, "
"რომელსაც Open edX იყენებს ხელსაწყოს გასაშვებად."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "მორგებული პარამეტრები"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"შეიყვანეთ გასაღები-მნიშვნელობის წყვილები ყოველი გაშვებისას გასაგზავნად, "
"მაგ., [\"page=1\", \"color=white\"]."

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"აირჩიეთ, როგორ გაიხსნება ხელსაწყო მოსწავლეებისთვის: გვერდზე, მოდალურ "
"ფანჯარაში ან ახალ ფანჯარაში."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "გაშვების ღილაკის ტექსტი"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"შეიყვანეთ ღილაკზე ნაჩვენები წარწერა, როდესაც ინსტრუმენტი იხსნება მოდალურ ან "
"ახალ ფანჯარაში."

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "შეიყვანეთ ჩაშენებული iframe-ის სიმაღლე პიქსელებში."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "მოდელის სიმაღლე (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "შეიყვანეთ მოდალური ფანჯრის სიმაღლე ბრაუზერის ფანჯრის პროცენტით."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "მოდელის სიგანე (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "შეიყვანეთ მოდალური ფანჯრის სიგანე ბრაუზერის ფანჯრის პროცენტით."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "ეს აქტივობა ფასდება"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "ჩართეთ ეს ვარიანტი, თუ ინსტრუმენტი Open edX-ს რიცხვით ქულას უგზავნის."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "შეფასების წონა"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "შეიყვანეთ ამ კომპონენტისთვის ქულების მაქსიმალური რაოდენობა."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"KVS xblock-ში შენახული შეფასება -- ჯანგოს ბაზაში გამოქვეყნებული შეფასების "
"ასლია"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "დააკომენტეთ, როგორც შემფასებლისგან მობრუნებული, LTI2.0 სპეციფიკაცია"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "გარე ხელსაწყოს დამალვა"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"ამ ფუნქციის ჩართვით ინსტრუმენტს შეეძლება შეფასებების გაგზავნა საბოლოო ვადის "
"გასვლის შემდეგ."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "მომხმარებლის სახელის გაზიარება"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"ჩართეთ ეს ფუნქცია, რათა მოსწავლის მომხმარებლის სახელი გაეგზავნოს ხელსაწყოს."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "გააზიარეთ სრული სახელი"

#: lti_xblock.py:544
msgid "Share Email"
msgstr "ელ.ფოსტის გაზიარება"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "გაგზავნეთ დამატებითი პარამეტრები"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "მორგებული პარამეტრები უნდა იყოს სია"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "მორგებული პარამეტრები უნდა იყოს სტრიქონები \"x=y\" ფორმატში."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"გარე კონფიგურაციის გამოყენებისას, აუცილებელია მითითდეს ხელახლა გამოყენებადი "
"კონფიგურაციის ID (მაგალითად: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"მითითებული LTI ID არ არის კონფიგურირებული ამ კურსის გაფართოებულ "
"პარამეტრებში."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "მიმდინარე მოთხოვნისთვის მომხმარებლის მონაცემების მიღება ვერ მოხერხდა"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"LTI პასპორტის პარსირება ვერ მოხერხდა: {lti_passport!r}. უნდა იყოს სტრიქონი "
"\"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "მიმდინარე მოთხოვნისთვის მომხმარებლის ID ვერ იქნა მიღებული"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
