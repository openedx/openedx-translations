#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Manglende LTI 1.3-godkendelsestoken."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Ugyldig token-header. Ingen legitimationsoplysninger angivet."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "Ugyldig token-header. Tokenstreng bør ikke indeholde mellemrum."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI-konfiguration blev ikke fundet."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Ugyldig token-signatur."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Intet gyldigt bruger-id fundet i slutpunkts-URL"

#: lti_xblock.py:147
msgid "New"
msgstr "Ny"

#: lti_xblock.py:151
msgid "Database"
msgstr "Database"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Eksisterende"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Visningsnavn"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Angiv det navn, som kursisterne ser for denne komponent. Dette navn kan også"
" vises i rapporter."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI forbruger"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Datadelingsmeddelelse"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Indtast en kort meddelelse om værktøjet. Brug dette felt til at forklare, "
"hvorfor elevdata kan deles med det."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Konfigurationstype"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Vælg 'Ny' for at konfigurere et nyt LTI-værktøj. Hvis din administrator har "
"givet dig et id for en eksisterende genanvendelig værktøjskonfiguration, "
"skal du vælge 'Eksisterende' og indtaste det i tekstfeltet til højre."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI-version"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Vælg den LTI-version, dit værktøj understøtter."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "LTI-genbrugs-ID"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Indtast id'et for en eksisterende genanvendelig værktøjskonfiguration."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti 1.3-pas-id, der peger på Lti1p3Passport-tabel"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Pas-ID til genanvendelige nøgler."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Start-URL"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Indtast start-URL'en for dette værktøj. For LTI 1.3 er dette den URL, Open "
"edX bruger til at starte værktøjet."

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Indtast værktøjets OIDC-logininitierings-URL. Open edX bruger denne URL til "
"at starte LTI 1.3-loginflowet."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Registrerede omdirigerings-URI&#39;er"

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Værktøjs offentlig nøgletilstand"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Vælg, hvordan Open edX får værktøjets offentlige nøgle til validering af "
"signerede meddelelser."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Tool Keyset URL"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Indtast URL'en til værktøjets JWK-nøglesæt. Open edX bruger denne URL til at"
" hente de offentlige nøgler, der er nødvendige for at validere signerede "
"meddelelser."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Værktøjs offentlig nøgle"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Indtast værktøjets offentlige nøgle i PEM-format (starter med -----BEGIN "
"PUBLIC KEY-----). Brug dette, når værktøjet direkte leverer en statisk "
"offentlig nøgle."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Navne og roller (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Aktiver dette for at give værktøjet adgang til navne og roller for tilmeldte"
" kursister, hvis værktøjet understøtter NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Deep linking"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr "Aktiver dette, hvis du vil dybdelinke indhold fra værktøjet i Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "Deep Linking Launch URL"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Indtast deep linking-URL'en for dette værktøj. Hvis værktøjet ikke angiver "
"en, skal du indtaste 'Launch URL' her."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Opgaver og karakterer"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklarativ"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programmatisk"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Deaktiveret"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Aktivér AGS, og vælg funktionalitet. 'Deklarativ' giver værktøjet et "
"eksisterende linjeelement. 'Programmatisk' giver værktøjer mulighed for at "
"oprette og administrere linjeelementer."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI Passport-id"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Vælg LTI-pas-ID'et for dette værktøj. Dette er ID'et for det LTI-pas, du "
"oprettede på siden Avancerede indstillinger."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Indtast start-URL'en for dette værktøj. For LTI 1.1/1.2 er dette den URL, "
"Open edX bruger til at starte værktøjet."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "tilpassede parametre"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Angiv nøgle-værdi-par, der skal sendes med hver start, f.eks. [\"page=1\", "
"\"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Åbn værktøj i"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Angiv den etiket, der vises på startknappen, når værktøjet åbnes i en modal "
"eller et nyt vindue."

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Angiv højden på den indlejrede iframe i pixels."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Modalhøjde (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Angiv modalhøjden som en procentdel af browservinduet."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Modalbredde (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Angiv modalbredden som en procentdel af browservinduet."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Denne aktivitet bedømmes"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Aktiver dette, hvis værktøjet sender en numerisk score tilbage til Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Karaktervægt"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Angiv det maksimale antal point for denne komponent."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Scoren indeholdt i xblock KVS - kopiér den offentliggjorte score i/til "
"Django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Kommentar som returneret fra grader, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Skjul eksternt værktøj"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Aktiver dette for at skjule startknappen og iframen, så du kan bruge "
"komponenten til karakter-synkronisering osv."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Accepter karakterer efter forfaldsdato"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Aktiver dette for at give værktøjet mulighed for at sende karakterer, efter "
"at afleveringsfristen er overskredet."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Del brugernavnet"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Aktiver dette for at sende elevens brugernavn til værktøjet."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Del fulde navn"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Aktiver dette for at sende elevens fulde navn til værktøjet."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Del e-mail"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Aktiver dette for at sende elevens e-mailadresse til værktøjet."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Send ekstra parametre"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Aktiver dette for at sende ekstra parametre (kan indeholde PII). Kontakt "
"webstedsadministratoren for yderligere oplysninger."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Brugerdefinerede parametre skal være en liste"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Brugerdefinerede parametre skal være strenge i formatet &quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Genanvendeligt konfigurations-id skal indstilles, når du bruger ekstern "
"konfiguration (eksempel: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Det angivne LTI-id er ikke konfigureret i dette kursuss avancerede "
"indstillinger."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Kunne ikke hente brugerdata for den aktuelle anmodning"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Kunne ikke parse LTI-pas: {lti_passport!r}. Bør være \"id:key:secret\" "
"streng."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Kunne ikke hente bruger-id for den aktuelle anmodning"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Kunne ikke parse tilpasset parameter: {custom_parameter!r}. Bør være "
"&quot;x=y&quot; streng."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Virkelig bruger blev ikke fundet mod anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Platformens genererede private nøgle. Hold denne værdi hemmelig."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platformens genererede private nøgle-id"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platformens genererede JWK-nøglesæt."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Klient-id brugt af LTI-værktøjet"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI-konfiguration, der er gemt på modellen for LTI 1.3, skal have en værdi "
"for en af lti_1p3_tool_public_key eller lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguration gemt på XBlock-felter"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfiguration gemt på denne model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguration lagret på ekstern tjeneste"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI-konfigurationsdata."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL'en på det eksterne værktøj, der starter lanceringen."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klientnøgle leveret af LTI-værktøjsudbyderen."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Klienthemmelighed leveret af LTI-værktøjsudbyderen."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI-konfigurationsbutikker på XBlock har brug for et blokplaceringssæt."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI-konfiguration, der bruger genbrugelig konfiguration, kræver et eksternt "
"ID i &quot;x:y&quot;-format."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK og CONFIG_EXTERNAL understøttes ikke for LTI 1.3 Proctoring"
" Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Ugyldig LTI-konfiguration."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Den valgte indholdstype understøttes ikke af Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Du har ikke adgang til at gemme LTI-indholdselementer."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Tjek venligst, at du har kursuspersonaletilladelser, og dobbelttjek denne "
"bloks LTI-indstillinger."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI Deep Linking mislykkedes."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI Deep Linking"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "LTI Deep Linking-indholdet blev gemt i LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Du kan roligt lukke denne side nu."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Uautoriseret."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Elever har ikke tilladelser til at udføre LTI Deep Linking-"
"konfigurationslanceringer."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Lanceringer kan kun udføres fra LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"For at konfigurere LTI-integrationen skal du registrere LMS i værktøjet med "
"oplysningerne nedenfor."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Kunde-id: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Implementerings-id: "

#: templates/html/lti_1p3_studio.html:21
