msgid "Hide External Tool"
msgstr "Slēpt ārējo rīku"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Iespējot šo, lai nosūtītu izglītojamā e-pasta adresi rīkam."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Nosūtiet papildu parametrus"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Iespējojiet šo, lai nosūtītu papildu parametrus (var saturēt PII). Sīkāku "
"informāciju jautājiet vietnes administratoram."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Pielāgotajiem parametriem ir jābūt sarakstam"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Pielāgotajiem parametriem ir jābūt virknēm formātā “x=y”."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Izmantojot ārējo konfigurāciju, ir jāiestata atkārtoti lietojamas "
"konfigurācijas ID (piemērs: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr "Norādītais LTI ID nav konfigurēts šī kursa papildu iestatījumos."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nevarēja iegūt lietotāja datus pašreizējam pieprasījumam"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nevarēja parsēt LTI pasi: {lti_passport!r}. Jābūt virknei “id:key:secret”."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Pašreizējam pieprasījumam nevarēja iegūt lietotāja ID"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nevarēja parsēt pielāgoto parametru: {custom_parameter!r}. Jābūt virknei "
"“x=y”."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: īsts lietotājs netika atrasts pret anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Platformas ģenerētā privātā atslēga. Saglabājiet šo vērtību noslēpumā."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platformas ģenerētais privātās atslēgas ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platformas ģenerētā JWK atslēgu kopa."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Klienta ID, ko izmanto LTI rīks"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI Konfigurācijā, kas saglabāta LTI 1.3 modelī, jābūt vienai no "
"lti_1p3_tool_public_key vai lti_1p3_tool_keyset_url vērtībām."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfigurācija saglabāta XBlock laukos"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfigurācija Saglabāta šajā modelī"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfigurācija Saglabāta ārējā pakalpojumā"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI konfigurācijas dati."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Tā ārējā rīka URL, kas uzsāk palaišanu."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klienta atslēga, ko nodrošina LTI rīka nodrošinātājs."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Klienta noslēpums, ko nodrošina LTI rīka nodrošinātājs."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"XBlock LTI konfigurācijas veikaliem ir jāiestata bloka atrašanās vieta."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI konfigurācijai, izmantojot atkārtoti lietojamu konfigurāciju, ir "
"nepieciešams ārējais ID formātā “x:y”."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK un CONFIG_EXTERNAL netiek atbalstīti LTI 1.3 nodrošināšanas"
" pakalpojumiem."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Nederīga LTI konfigurācija."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
