msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Individuelle Parameter"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Die Noten werden in dem xblock KVS aufbewahrt -- Kopien der veröffentlichten"
" Noten in der django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr ""
"Kommentare, wie sie durch den Bewerter zurückgegeben worden sind, nach "
"Spezifikation LTI2.0 spec."

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Verstecke externes Werkzeug"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Senden Sie zusätzliche Parameter"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Benutzerdefinierte Parameter müssen eine Liste sein"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Benutzerdefinierte Parameter sollten Zeichenfolgen im Format „x=y“ sein."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Bei Verwendung einer externen Konfiguration muss eine wiederverwendbare "
"Konfigurations-ID festgelegt werden (Beispiel: „x:y“)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Die angegebene LTI-ID ist in den erweiterten Einstellungen dieses Kurses "
"nicht konfiguriert."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Für die aktuelle Anfrage konnten keine Benutzerdaten abgerufen werden"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Der LTI-Pass konnte nicht analysiert werden: {lti_passport!r}. Sollte die "
"Zeichenfolge „id:key:secret“ sein."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr ""
"Die Benutzer-ID für die aktuelle Anfrage konnte nicht abgerufen werden"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Benutzerdefinierter Parameter konnte nicht analysiert werden: "
"{custom_parameter!r}. Sollte die Zeichenfolge „x=y“ sein."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Echter Benutzer nicht für anon_id gefunden: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Der von der Plattform generierte private Schlüssel. Halten Sie diesen Wert "
"geheim."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Die von der Plattform generierte private Schlüssel-ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Der von der Plattform generierte JWK-Schlüsselsatz."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Vom LTI-Tool verwendete Client-ID"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Die im Modell für LTI 1.3 gespeicherte LTI-Konfiguration muss einen Wert für"
" lti_1p3_tool_public_key oder lti_1p3_tool_keyset_url haben."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Auf XBlock-Feldern gespeicherte Konfiguration"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Auf diesem Modell gespeicherte Konfiguration"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguration auf externem Dienst gespeichert"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI-Konfigurationsdaten."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Die URL des externen Tools, das den Start initiiert."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Vom LTI-Tool-Anbieter bereitgestellter Client-Schlüssel."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Vom LTI-Tool-Anbieter bereitgestelltes Client-Geheimnis."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Für LTI-Konfigurationsspeicher auf XBlock ist ein Blockspeicherortsatz "
"erforderlich."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Für die LTI-Konfiguration mit wiederverwendbarer Konfiguration ist eine "
"externe ID im Format „x:y“ erforderlich."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK und CONFIG_EXTERNAL werden für LTI 1.3 Proctoring Services "
"nicht unterstützt."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Ungültige LTI-Konfiguration."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Der ausgewählte Inhaltstyp wird von Open edX nicht unterstützt."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Sie haben keinen Zugriff zum Speichern von LTI-Inhaltselementen."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Bitte überprüfen Sie, ob Sie über Berechtigungen für Kursmitarbeiter "
"verfügen, und überprüfen Sie die LTI-Einstellungen dieses Blocks noch "
"einmal."

