msgid "Custom Parameters"
msgstr "Parametri personalizat"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Scorul păstrat în xblock KVS -- duplicat al scorului publicat în django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Comentariu returnat de la evaluator, conform specificațiilor LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Ascunde instrumentul extern"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Trimiteți parametri suplimentari"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Parametrii personalizați trebuie să fie o listă"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Parametrii personalizați ar trebui să fie șiruri în format „x=y”."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Id-ul de configurație reutilizabil trebuie setat atunci când se utilizează "
"configurația externă (Exemplu: „x:y”)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"ID-ul LTI specificat nu este configurat în Setările Avansate ale acestui "
"curs."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nu putem obține date despre utilizator pentru solicitarea curentă."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nu s-a putut analiza pasaportul LTI: {lti_passport!r}. Ar trebui să fie "
"șirul „id:key:secret”."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Nu s-a putut obține id-ul de utilizator pentru solicitarea curentă"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nu s-a putut analiza parametrul particularizat: {custom_parameter!r}. Ar "
"trebui să fie șirul „x=y”."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: utilizator real nu a fost găsit pentru anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Cheia privată generată de platformă. Păstrați această valoare secretă."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID-ul cheii private generat de platformă"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Setul de chei JWK generat de platformă."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID-ul clientului utilizat de instrumentul LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Configurația LTI stocată pe modelul pentru LTI 1.3 trebuie să aibă o valoare"
" pentru unul dintre lti_1p3_tool_public_key sau lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Configurație stocată în câmpurile XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Configurație stocată pe acest model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Configurație stocată pe un serviciu extern"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dată de configurație LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Adresa URL a instrumentului extern care inițiază lansarea."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Cheia client furnizată de furnizorul de instrumente LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Secretul clientului furnizat de furnizorul de instrumente LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr "Configurația LTI de pe XBlock necesită un set de locații de bloc."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Configurația LTI care utilizează configurația reutilizabilă necesită un id "
"extern în format „x:y”."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK și CONFIG_EXTERNAL nu sunt acceptate pentru LTI 1.3 "
"Proctoring Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Configurație LTI nevalidă."

