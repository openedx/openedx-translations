#: templates/html/lti_studio_edit/_step_advantage.html:104
#: templates/html/lti_studio_edit/_step_review.html:87
#: templates/html/lti_studio_edit/_step_review.html:208
msgid "Enabled"
msgstr "Activat"

#: templates/html/lti_studio_edit/_step_advantage.html:142
msgid "Public Key"
msgstr "Cheie publică"

#: templates/html/lti_studio_edit/_step_advantage.html:152
msgid "Keyset URL"
msgstr "Adresa URL a setului de chei"

#: templates/html/lti_studio_edit/_step_review.html:22
msgid "Grading"
msgstr "Notare"

#: templates/html/lti_studio_edit/_step_review.html:39
msgid "Graded"
msgstr "Notat"

#: templates/html/lti_studio_edit/_step_review.html:49
msgid "Ungraded"
msgstr "Negradat"

#: templates/html/lti_studio_edit/_step_review.html:108
msgid "Advanced Information Sharing"
msgstr "Partajare avansată de informații"

#: templates/html/lti_studio_edit/_step_review.html:174
msgid "Administrators can enable advanced sharing options for LTI components."
msgstr ""
"Administratori pot activa opțiuni avansate de partajare pentru componentele "
"LTI."

#: templates/html/lti_studio_edit/_step_review.html:179
msgid "Learn more."
msgstr "Află mai multe."

#: templates/html/lti_studio_edit/_step_review.html:229
msgid "Appearance Options"
msgstr "Opțiuni de aspect"

