msgid "Custom Parameters"
msgstr "Parametry niestandardowe"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Wynik przechowywany w xblock KVS — duplikat wyniku opublikowanego w Django "
"DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Komentarz oceniającego, kod LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Ukryj narzędzie zewnętrzne"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Wyślij dodatkowe parametry"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Parametry niestandardowe muszą być listą"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Parametry niestandardowe powinny być ciągami w formacie „x=y”."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"W przypadku korzystania z konfiguracji zewnętrznej należy ustawić "
"identyfikator konfiguracji wielokrotnego użytku (przykład: „x:y”)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Podany identyfikator LTI nie jest skonfigurowany w Ustawieniach "
"Zaawansowanych tego kursu."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nie można pobrać danych użytkownika dla bieżącego żądania"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nie można przeanalizować paszportu LTI: {lti_passport!r}. Powinien to być "
"ciąg „id:key:secret”."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Nie można uzyskać identyfikatora użytkownika dla bieżącego żądania"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nie można przeanalizować parametru niestandardowego: {custom_parameter!r}. "
"Powinien to być ciąg „x=y”."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Nie znaleziono prawdziwego użytkownika według anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Wygenerowany przez platformę klucz prywatny. Zachowaj tę wartość w "
"tajemnicy."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Wygenerowany przez platformę identyfikator klucza prywatnego"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Wygenerowany przez platformę zestaw kluczy JWK."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Identyfikator klienta używany przez narzędzie LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Konfiguracja LTI przechowywana w modelu dla LTI 1.3 musi mieć wartość "
"lti_1p3_tool_public_key lub lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguracja przechowywana w polach XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfiguracja zapisana w tym modelu"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguracja przechowywana w serwisie zewnętrznym"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dane konfiguracyjne LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Zewnętrzne narzędzie inicjuje uruchomienie za pomocą adresu URL."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klucz klienta dostarczony przez dostawcę narzędzia LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Klucz tajny klienta dostarczony przez dostawcę narzędzia LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Sklepy konfiguracyjne LTI na XBlock wymagają ustawienia lokalizacji bloku."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Konfiguracja LTI wykorzystująca konfigurację wielokrotnego użytku wymaga "
"zewnętrznego identyfikatora w formacie „x:y”."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "Konfiguracja LTI dla wersji 1.3 wymaga ustawienia paszportu."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK or CONFIG_EXTERNAL nie są obsługiwane w przypadku usług LTI"
" 1.3 Proctoring."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Nieprawidłowa konfiguracja LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Wybrany typ zawartości nie jest obsługiwany przez Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Nie masz dostępu do zapisywania elementów zawartości LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Sprawdź, czy masz uprawnienia personelu kursu i dokładnie sprawdź ustawienia"
" LTI tego bloku."

