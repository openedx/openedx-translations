#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Hiányzó LTI 1.3 hitelesítési token."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Érvénytelen token fejléc. Nincsenek megadva hitelesítő adatok."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Érvénytelen token fejléc. A token karakterlánc nem tartalmazhat szóközöket."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Az LTI konfiguráció nem található."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Érvénytelen token aláírás."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Nem található érvényes felhasználói azonosító a végpont URL-jében."

#: lti_xblock.py:147
msgid "New"
msgstr "Új"

#: lti_xblock.py:151
msgid "Database"
msgstr "Adatbázis"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Meglévő"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Megjelenített név"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Adja meg azt a nevet, amelyet a tanulók látnak ehhez az összetevőhöz. Ez a "
"név a jelentésekben is megjelenhet."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI-fogyasztó"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Adatmegosztási értesítés"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Adjon meg egy rövid értesítést az eszközzel kapcsolatban. Ezzel a mezővel "
"magyarázza el, miért oszthatók meg a tanulói adatok az eszközzel."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Konfiguráció típusa"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Válassza az „Új” lehetőséget egy új LTI-eszköz konfigurálásához. Ha a "
"rendszergazda megadta egy meglévő, újrahasználható eszközkonfiguráció "
"azonosítóját, válassza a „Meglévő” lehetőséget, és írja be a jobb oldali "
"szövegmezőbe."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI verzió"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Válassza ki az eszköz által támogatott LTI-verziót."

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Adja meg egy meglévő, újrahasználható eszközkonfiguráció azonosítóját."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti 1.3 útlevél azonosító, amely az Lti1p3Passport táblára mutat"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Indítási URL-cím"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Adja meg az eszköz indítási URL-címét. LTI 1.3 esetén ez az az URL-cím, "
"amelyet az Open edX használ az eszköz indításához."

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Adja meg az eszköz OIDC bejelentkezés-kezdeményezési URL-jét. Az Open edX "
"ezt az URL-t használja az LTI 1.3 bejelentkezési folyamat elindításához."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Regisztrált átirányítási URI-k"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Adja meg azokat az átirányítási URI-kat, amelyeket ez az eszköz használhat "
"bejelentkezéskor, pl. [\"https://tool.com\", \"https://tool_deeplink.com\"]."
" Hagyja üresen, ha alapértelmezés szerint a kezdő URL-t és a mélylink URL-t "
"szeretné használni."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Eszköz nyilvános kulcs mód"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Válassza ki, hogyan fogja az Open edX lekérni az eszköz nyilvános kulcsát az"
" aláírt üzenetek érvényesítéséhez."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Eszköz kulcskészlet URL-címe"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Adja meg az eszköz JWK kulcskészletének URL-címét. Az Open edX ezt az URL-t "
"használja az aláírt üzenetek érvényesítéséhez szükséges nyilvános kulcsok "
"lekérésére."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Eszköz nyilvános kulcs"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Adja meg az eszköz nyilvános kulcsát PEM formátumban (a „-----BEGIN PUBLIC "
"KEY-----” karakterlánccal kezdődik). Ezt akkor használja, ha az eszköz "
"közvetlenül statikus nyilvános kulcsot biztosít."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Nevek és szerepek (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Engedélyezze ezt, hogy az eszköz hozzáférhessen a beiratkozott tanulók "
"neveihez és szerepeihez, amennyiben az eszköz támogatja az NRPS-t."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Mélylinkelés"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Engedélyezze ezt, ha a Studio eszközön belülről szeretne mélylinkelni "
"tartalmat."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "Mélyhivatkozás indítási URL-címe"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Adja meg az eszköz mélylink URL-jét. Ha az eszköz nem ad meg ilyet, adja meg"
" ide az „Indítási URL-t”."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Feladat és jegyek"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklaratív"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Letiltva"

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI útlevél azonosító"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Válassza ki az LTI útlevél azonosítóját ehhez az eszközhöz. Ez annak az LTI "
"útlevélnek az azonosítója, amelyet a Speciális beállítások oldalon hozott "
"létre."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Adja meg az eszköz indítási URL-jét. LTI 1.1/1.2 esetén ez az az URL, "
"amelyet az Open edX használ az eszköz indításához."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Egyéni paraméterek"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Adjon meg kulcs-érték párokat, amelyeket minden indítással elküld, pl. "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Válassza ki, hogyan nyíljon meg az eszköz a tanulók számára: beágyazva az "
"oldalon, modális ablakban vagy új ablakban."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Indítógomb szövege"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Adja meg az indítógombon megjelenő feliratot, amikor az eszköz modális "
"ablakban vagy új ablakban nyílik meg."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Beágyazott magasság (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Adja meg az inline iframe magasságát képpontban."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Modális ablak magassága (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Adja meg a modális ablak magasságát a böngészőablak százalékában."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Modális szélesség (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Adja meg a modális ablak szélességét a böngészőablak százalékában."

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Engedélyezze ezt, ha az eszköz numerikus pontszámot küld vissza az Open edX-"
"nek."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Értékelési súly"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Adja meg az összetevő maximális pontszámát."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Az xblock KVS-ben tárolt pontszám -- a django adatbázisban közzétett "
"pontszám másolata"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Megjegyzés a javítótól visszakapott, LTI2.0 specifikáció"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Külső eszköz elrejtése"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Engedélyezze ezt, hogy az eszköz a határidő lejárta után is küldhessen "
"jegyeket."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Felhasználónév megosztása"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Engedélyezze ezt, hogy a tanuló felhasználónevét elküldje az eszköznek."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Teljes név megosztása"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Engedélyezze ezt, hogy a tanuló teljes nevét elküldje az eszköznek."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "E-mail megosztása"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Engedélyezze ezt, hogy a tanuló e-mail címét elküldje az eszköznek."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Küldjön extra paramétereket"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Engedélyezze ezt további paraméterek küldéséhez (személyes adatokat is "
"tartalmazhat). Részletekért forduljon a webhely rendszergazdájához."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "A testreszabott paramétereknek listának kell lenniük."

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Az egyéni paramétereknek \"x=y\" formátumú karakterláncoknak kell lenniük."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"A külső konfiguráció használatakor újrafelhasználható konfigurációs "
"azonosítót kell beállítani (példa: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"A megadott LTI-azonosító nincs konfigurálva ebben a kurzusban az \"Advanced "
"Settings\" beállítások között."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nem sikerült lekérni a felhasználói adatokat a jelenlegi kéréshez."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nem sikerült elemezni az LTI útlevelet: {lti_passport!r}. A formátumnak "
"\"id:key:secret\" karakterláncnak kell lennie."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr ""
"Nem sikerült megszerezni a felhasználói azonosítót a jelenlegi kéréshez."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nem sikerült elemezni az egyéni paramétert: {custom_parameter!r}. \"x=y\" "
"formátumú szövegnek kell lennie."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Valós felhasználó nem található az anon_id alapján: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"A platform által generált privát kulcs. Tartsa ezt az értéket titokban."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "A platform által generált privát kulcs azonosítója"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "A platform által generált JWK kulcskészlet."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTI eszköz által használt ügyfélazonosító"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Az LTI 1.3 modellben tárolt LTI-konfigurációnak értéket kell tartalmaznia az"
" lti_1p3_tool_public_key vagy az lti_1p3_tool_keyset_url mezőben."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguráció az XBlock mezőkön tárolva"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "A konfiguráció ezen a modellen van tárolva."

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguráció külső szolgáltatáson tárolva"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI konfigurációs adatok."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Az indítást kezdeményező külső eszköz URL-je."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Az LTI eszközszolgáltató által biztosított ügyfélkulcs."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Az LTI eszközszolgáltató által biztosított kliens titok."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr "Az LTI-konfiguráció tárolása az XBlockon blokkelhelyezést igényel."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Az LTI konfigurációhoz újrafelhasználható konfiguráció használatakor külső "
"azonosítóra van szükség \"x:y\" formátumban."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"A CONFIG_ON_XBLOCK és a CONFIG_EXTERNAL nem támogatott az LTI 1.3 Proctoring"
" Services esetében."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Érvénytelen LTI-konfiguráció."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Az Open edX nem támogatja a kiválasztott tartalomtípust."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Önnek nincs jogosultsága LTI tartalmi elemek mentésére."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Kérjük, ellenőrizze, hogy rendelkezik-e kurzus személyzeti jogosultságokkal,"
" és alaposan ellenőrizze ennek a blokknak az LTI beállításait."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Az LTI mélyhivatkozás nem sikerült."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI mélyhivatkozás"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Az LTI Deep Linking tartalom sikeresen elmentésre került az LMS-ben."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Most már biztonságosan bezárhatja ezt az oldalt."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Jogosulatlan."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"A diákoknak nincs jogosultságuk LTI Deep Linking konfigurációs indítások "
"végrehajtására."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Az LTI 1.3 indítások csak az LMS-ből hajthatók végre."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Az LTI integráció beállításához regisztrálnia kell az LMS-t az eszközben az "
"alábbi információk megadásával."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Ügyfélazonosító: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Telepítési azonosító: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "Kulcskészlet URL: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "Hozzáférési token URL: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "Bejelentkezési URL: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "A mélyhivatkozás konfigurálva van ezen az eszközön."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "A tárolt mélyhivatkozás-konfiguráció az alábbiakban látható:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr "Ha újra futtatja a mélyhivatkozást, a fenti tartalom lecserélődik."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr "A tartalom konfigurálható az LTI Deep Linking használatával."

