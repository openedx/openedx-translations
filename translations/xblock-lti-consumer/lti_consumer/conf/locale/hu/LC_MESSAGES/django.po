#: static/js/xblock_lti_consumer.js:174
msgid ""
"Click OK to have your username, full name, and e-mail address sent to a 3rd "
"party application."
msgstr ""
"Kattintson az OK gombra, hogy a felhasználóneve, teljes neve és e-mail címe "
"elküldésre kerüljön egy harmadik fél alkalmazásának."

#: static/js/xblock_lti_consumer.js:178
msgid ""
"Click OK to have your username and e-mail address sent to a 3rd party "
"application."
msgstr ""
"Kattintson az OK gombra, hogy a felhasználóneve és e-mail címe egy harmadik "
"fél alkalmazásához kerüljön elküldésre."

#: static/js/xblock_lti_consumer.js:181
msgid ""
"Click OK to have your username and full name sent to a 3rd party "
"application."
msgstr ""
"Kattintson az OK gombra, hogy a felhasználóneve és teljes neve elküldésre "
"kerüljön egy harmadik fél alkalmazásának."

#: static/js/xblock_lti_consumer.js:184
msgid ""
"Click OK to have your full name and e-mail address sent to a 3rd party "
"application."
msgstr ""
"Kattintson az OK gombra, hogy teljes neve és e-mail címe egy harmadik fél "
"alkalmazásához kerüljön elküldésre."

#: static/js/xblock_lti_consumer.js:187
msgid "Click OK to have your username sent to a 3rd party application."
msgstr ""
"Kattintson az OK gombra, hogy a felhasználónevét elküldje egy harmadik fél "
"alkalmazásának."

#: static/js/xblock_lti_consumer.js:189
msgid "Click OK to have your full name sent to a 3rd party application."
msgstr ""
"Kattintson az OK gombra, hogy a teljes neve egy harmadik fél alkalmazásához "
"kerüljön elküldésre."

#: static/js/xblock_lti_consumer.js:191
