msgstr "Λειτουργία δημόσιου κλειδιού εργαλείου"

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Διεύθυνση URL συνόλου κλειδιών εργαλείου"

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Δημόσιο κλειδί εργαλείου"

#: lti_xblock.py:385
