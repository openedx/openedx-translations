#: static/js/xblock_lti_consumer.js:145
msgid "OK"
msgstr "Εντάξει"

#: static/js/xblock_lti_consumer.js:174
msgid ""
"Click OK to have your username, full name, and e-mail address sent to a 3rd "
"party application."
msgstr ""
"Κάντε κλικ στο OK για να σταλούν το όνομα χρήστη, το πλήρες όνομα και η "
"διεύθυνση e-mail σας σε μια εφαρμογή τρίτου μέρους."

#: static/js/xblock_lti_consumer.js:178
msgid ""
"Click OK to have your username and e-mail address sent to a 3rd party "
"application."
msgstr ""
"Κάντε κλικ στο OK για να σταλούν το όνομα χρήστη και η διεύθυνση e-mail σας "
"σε μια εφαρμογή τρίτου μέρους."

#: static/js/xblock_lti_consumer.js:181
msgid ""
"Click OK to have your username and full name sent to a 3rd party "
"application."
msgstr ""
"Κάντε κλικ στο OK για να σταλούν το όνομα χρήστη και το πλήρες όνομά σας σε "
"μια εφαρμογή τρίτου μέρους."

#: static/js/xblock_lti_consumer.js:184
msgid ""
"Click OK to have your full name and e-mail address sent to a 3rd party "
"application."
msgstr ""
"Κάντε κλικ στο OK για να σταλούν το πλήρες όνομά σας και η διεύθυνση e-mail "
"σας σε μια εφαρμογή τρίτου μέρους."

#: static/js/xblock_lti_consumer.js:187
msgid "Click OK to have your username sent to a 3rd party application."
msgstr ""
"Κάντε κλικ στο OK για να σταλεί το όνομα χρήστη σας σε μια εφαρμογή τρίτου "
"μέρους."

#: static/js/xblock_lti_consumer.js:189
msgid "Click OK to have your full name sent to a 3rd party application."
msgstr ""
"Κάντε κλικ στο OK για να σταλεί το πλήρες όνομά σας σε μια εφαρμογή τρίτου "
"μέρους."

#: static/js/xblock_lti_consumer.js:191
msgid "Click OK to have your e-mail address sent to a 3rd party application."
msgstr ""
"Κάντε κλικ στο OK για να σταλεί η διεύθυνση e-mail σας σε μια εφαρμογή "
"τρίτου μέρους."

#: static/js/xblock_lti_consumer.js:198
msgid "Click Cancel to return to this page without sending your information."
msgstr ""
"Κάντε κλικ στο 'Ακύρωση' για να επιστρέψετε σε αυτήν τη σελίδα χωρίς να "
"στείλετε τα στοιχεία σας."

#: static/js/xblock_studio_view.js:476 static/js/xblock_studio_view.js:490
#: static/js/xblock_studio_view.js:526
msgid "Unable to update settings"
msgstr "Αδυναμία ενημέρωσης ρυθμίσεων"

#: static/js/xblock_studio_view.js:511
msgid ""
"This may be happening because of an error with our server or your internet "
"connection. Try refreshing the page or making sure you are online."
msgstr ""
"Αυτό μπορεί να οφείλεται σε κάποιο σφάλμα του server μας ή στη σύνδεσή σας. "
"Δοκιμάστε να ανανεώσετε τη σελίδα ή επιβεβαιώστε ότι είστε συνδεδεμένοι στο "
"διαδίκτυο."
