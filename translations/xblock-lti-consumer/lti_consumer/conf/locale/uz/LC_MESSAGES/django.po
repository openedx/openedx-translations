msgstr "Maxsus parametrlar"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Xblock KVS da saqlanadigan ball -- django DB da chop etilgan ballning "
"dublikati"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr ""
"Baholovchi tomonidan qaytarilgan sharh, LTI2.0 spetsifikatsiyasiga ko‘ra"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Tashqi vositani yashirish"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Oʻquvchining elektron pochta manzilini ushbu vositaga yuborish uchun buni "
"yoqing."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Qo‘shimcha parametrlarni yuboring"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Qoʻshimcha parametrlarni yuborish uchun buni yoqing (shaxsiy maʼlumotlarni "
"oʻz ichiga olishi mumkin). Tafsilotlar uchun sayt adminiga murojaat qiling."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Maxsus parametrlar ro‘yxat bo‘lishi kerak"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Maxsus parametrlar \"x = y\" formatidagi satrlar bo‘lishi kerak."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Qayta foydalanish mumkin bo‘lgan konfiguratsiya identifikatori tashqi "
"konfiguratsiyadan foydalanganda o‘rnatilishi kerak (Masalan: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Belgilangan LTI identifikatori ushbu kursning Kengaytirilgan sozlamalarida "
"sozlanmagan."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Joriy so‘rov uchun foydalanuvchi ma’lumotlarini olinmadi"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"LTI passportni tahlil qilishning imkoni bo‘lmadi: {lti_passport!r}. Bu "
"\"id:key:secret\" formatidagi qator bo‘lishi kerak."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Joriy so‘rov uchun foydalanuvchi identifikatori olinmadi"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Maxsus parametrni tahlil qilib bo‘lmadi: {custom_parameter!r}. \"x = y\" "
"qatori bo‘lishi kerak."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: haqiqiy foydalanuvchi anon_id ga qarshi topilmadi: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Platformaning yaratilgan Shaxsiy kaliti. Ushbu qiymatni sir saqlang."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platformada yaratilgan Shaxsiy kalit identifikatori"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platformada yaratilgan JWK kalitlar to‘plami."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTI vositasi tomonidan ishlatiladigan mijoz identifikatori"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 modelida saqlangan LTI konfiguratsiyasi lti_1p3_tool_public_key yoki"
" lti_1p3_tool_keyset_url dan biri uchun qiymatga ega bo‘lishi kerak."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguratsiya XBlock maydonlarida saqlanadi"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Ushbu modelda saqlangan konfiguratsiya"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguratsiya tashqi xizmatda saqlanadi"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI konfiguratsiya ma'lumotlari."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Ishga tushirishni boshlaydigan tashqi vositaning URL manzili."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "LTI asbob provayderi tomonidan taqdim etilgan mijoz kaliti."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "LTI vositasi provayderi tomonidan taqdim etilgan mijoz siri."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI konfiguratsiyasi XBlockda saqlanadi, blok joylashuvi o‘rnatilishi kerak."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Qayta ishlatiladigan konfiguratsiyadan foydalanadigan LTI konfiguratsiyasi "
"uchun \"x:y\" formatida tashqi ID kerak."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK va CONFIG_EXTERNAL LTI 1.3 Proktoring xizmatlari uchun "
"qo‘llab-quvvatlanmaydi."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Yaroqsiz LTI konfiguratsiyasi."

