#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "โทเค็นการตรวจสอบสิทธิ์ LTI 1.3 หายไป"

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "ส่วนหัวโทเค็นไม่ถูกต้อง ไม่มีข้อมูลประจำตัวที่ให้ไว้"

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "ส่วนหัวโทเค็นไม่ถูกต้อง สตริงโทเค็นไม่ควรมีช่องว่าง"

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "ไม่พบการกำหนดค่า LTI"

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "ลายเซ็นโทเค็นไม่ถูกต้อง"

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "ไม่พบรหัสผู้ใช้ที่ถูกต้องใน url ปลายทาง"

#: lti_xblock.py:147
msgid "New"
msgstr "ใหม่"

#: lti_xblock.py:151
msgid "Database"
msgstr "ฐานข้อมูล"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "ชื่อที่แสดง"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"ป้อนชื่อที่ผู้เรียนเห็นสำหรับส่วนประกอบนี้ ชื่อนี้อาจปรากฏในรายงานด้วย"

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "ผู้บริโภค LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "ประกาศการแบ่งปันข้อมูล"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"ป้อนประกาศสั้นๆ เกี่ยวกับเครื่องมือนี้ "
"ใช้ช่องนี้เพื่ออธิบายว่าเหตุใดข้อมูลผู้เรียนจึงอาจถูกแชร์กับเครื่องมือนี้"

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "ประเภทการกำหนดค่า"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"เลือก 'ใหม่' เพื่อกำหนดค่าเครื่องมือ LTI ใหม่ หากผู้ดูแลของคุณให้ ID "
"การกำหนดค่าเครื่องมือที่นำกลับมาใช้ใหม่ได้ที่มีอยู่แล้ว ให้เลือก 'ที่มีอยู่'"
" และป้อนลงในช่องข้อความทางด้านขวา"

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "เวอร์ชัน LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "เลือกรุ่น LTI ที่เครื่องมือของคุณรองรับ"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "ป้อน ID ของการกำหนดค่าเครื่องมือที่นำกลับมาใช้ใหม่ได้ที่มีอยู่"

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti 1.3 passport ID ที่ชี้ไปยังตาราง Lti1p3Passport"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "เปิด URL"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"ป้อน URL สำหรับเปิดใช้เครื่องมือนี้ สำหรับ LTI 1.3 นี่คือ URL ที่ Open edX "
"ใช้เพื่อเปิดใช้เครื่องมือ"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"ป้อน URL การเริ่มต้นเข้าสู่ระบบ OIDC ของเครื่องมือ Open edX จะใช้ URL "
"นี้เพื่อเริ่มขั้นตอนการเข้าสู่ระบบ LTI 1.3"

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI การเปลี่ยนเส้นทางที่ลงทะเบียน"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"ป้อน URI "
"สำหรับการเปลี่ยนเส้นทางที่เครื่องมือนี้ได้รับอนุญาตให้ใช้ระหว่างการเข้าสู่ระบบ"
" เช่น [\"https://tool.com\", \"https://tool_deeplink.com\"] หากเว้นว่างไว้ "
"จะใช้ URL สำหรับการเปิดใช้งานและ URL "
"สำหรับการเชื่อมโยงแบบเจาะลึกเป็นค่าเริ่มต้น"

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "เครื่องมือโหมดคีย์สาธารณะ"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"เลือกวิธีที่ Open edX "
"จะได้รับคีย์สาธารณะของเครื่องมือเพื่อตรวจสอบข้อความที่ลงนาม"

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL คีย์เครื่องมือ"

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "เครื่องมือกุญแจสาธารณะ"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"ป้อนคีย์สาธารณะของเครื่องมือในรูปแบบ PEM (ขึ้นต้นด้วย -----BEGIN PUBLIC "
"KEY-----) ใช้สิ่งนี้เมื่อเครื่องมือให้คีย์สาธารณะแบบคงที่โดยตรง"

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "ชื่อและบทบาท (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"เปิดใช้งานตัวเลือกนี้เพื่อให้เครื่องมือสามารถเข้าใช้ชื่อและบทบาทของผู้เรียนที่ลงทะเบียน"
" หากเครื่องมือรองรับ NRPS"

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "การเชื่อมโยงลึก"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"เปิดใช้งานตัวเลือกนี้หากคุณต้องการเชื่อมโยงเนื้อหาเชิงลึกจากภายในเครื่องมือใน"
" Studio"

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL เปิดตัว Deep Linking"

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "การมอบหมายงานและเกรด"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"เปิดใช้งาน AGS และเลือกฟังก์ชันการทำงาน 'Declarative' "
"จะให้เครื่องมือที่มีรายการบรรทัดที่มีอยู่ 'Programmatic' "
"จะช่วยให้เครื่องมือสามารถสร้างและจัดการรายการบรรทัดได้"

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI Passport ID"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"ป้อน URL สำหรับเปิดใช้เครื่องมือนี้ สำหรับ LTI 1.1/1.2 นี่คือ URL ที่ Open "
"edX ใช้เพื่อเปิดใช้เครื่องมือ"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "ตัวแปรตามสั่ง"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"ป้อนคู่คีย์-ค่าเพื่อส่งพร้อมกับการเปิดใช้งานแต่ละครั้ง เช่น [\"page=1\", "
"\"color=white\"]"

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "เปิดเครื่องมือใน"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"เลือกวิธีที่เครื่องมือจะเปิดสำหรับผู้เรียน: เปิดในหน้าเดียวกัน, "
"ในหน้าต่างป๊อปอัป หรือในหน้าต่างใหม่"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"ป้อนป้ายกำกับที่แสดงบนปุ่มเปิดใช้งานเมื่อเครื่องมือเปิดขึ้นในหน้าต่างโมดอลหรือหน้าต่างใหม่"

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "ความสูงแบบอินไลน์ (พิกเซล)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "ป้อนความสูงของ iframe แบบอินไลน์เป็นพิกเซล"

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "ความสูงของโมดัล (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "ป้อนความสูงของโมดอลเป็นเปอร์เซ็นต์ของหน้าต่างเบราว์เซอร์"

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "ความกว้างของโมดอล (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "ป้อนความกว้างของโมดอลเป็นเปอร์เซ็นต์ของหน้าต่างเบราว์เซอร์"

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "กิจกรรมนี้มีการให้คะแนน"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "เปิดใช้งานตัวเลือกนี้หากเครื่องมือส่งคะแนนตัวเลขกลับไปยัง Open edX"

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "น้ำหนักคะแนน"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "ป้อนคะแนนสูงสุดสำหรับส่วนประกอบนี้"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr "คะแนนเก็บใน xblock KVS -- สำเนาคะแนนที่ถูกตีพิมพ์ใน django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "ความคิดเห็นถูกส่งกลับไปยังผู้ให้คะแนน LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "ซ่อนเครื่องมือภายนอก"

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "ยอมรับเกรดหลังวันครบกำหนด"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"เปิดใช้งานตัวเลือกนี้เพื่อให้เครื่องมือสามารถส่งเกรดได้หลังจากวันครบกำหนด"

#: lti_xblock.py:530
msgid "Share Username"
msgstr "แบ่งปันชื่อผู้ใช้"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "เปิดใช้งานตัวเลือกนี้เพื่อส่งชื่อผู้ใช้ของผู้เรียนไปยังเครื่องมือ"

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "แชร์ชื่อเต็ม"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "เปิดใช้งานตัวเลือกนี้เพื่อส่งชื่อเต็มของผู้เรียนไปยังเครื่องมือ"

#: lti_xblock.py:544
msgid "Share Email"
msgstr "แบ่งปันอีเมล"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "เปิดใช้งานตัวเลือกนี้เพื่อส่งที่อยู่อีเมลของผู้เรียนไปยังเครื่องมือ"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "ส่งพารามิเตอร์พิเศษ"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"เปิดใช้งานตัวเลือกนี้เพื่อส่งพารามิเตอร์เพิ่มเติม "
"(อาจมีข้อมูลส่วนบุคคลที่ระบุตัวตนได้) "
"โปรดปรึกษาผู้ดูแลเว็บไซต์สำหรับรายละเอียด"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "พารามิเตอร์ที่กำหนดเองต้องเป็นรายการ"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "พารามิเตอร์ที่กำหนดเองควรเป็นสตริงในรูปแบบ &quot;x=y&quot;"

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"ต้องตั้งค่า ID การกำหนดค่าที่ใช้ซ้ำได้เมื่อใช้การกำหนดค่าภายนอก (ตัวอย่าง: "
"\"x:y\")"

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr "LTI ID ที่ระบุไม่ได้รับการกำหนดค่าในการตั้งค่าขั้นสูงของหลักสูตรนี้"

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "ไม่สามารถรับข้อมูลผู้ใช้สำหรับคำขอปัจจุบัน"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"ไม่สามารถแยกวิเคราะห์หนังสือเดินทาง LTI: {lti_passport!r} ควรเป็นสตริง "
"\"id:key:secret\""

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "ไม่สามารถรับ ID ผู้ใช้สำหรับคำขอปัจจุบัน"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"ไม่สามารถแยกวิเคราะห์พารามิเตอร์ที่กำหนดเอง: {custom_parameter!r} "
"ควรเป็นสตริง \"x=y\""

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: ไม่พบผู้ใช้จริงกับ anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "คีย์ส่วนตัวที่สร้างโดยแพลตฟอร์ม เก็บค่านี้ไว้เป็นความลับ"

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "รหัสคีย์ส่วนตัวที่สร้างขึ้นของแพลตฟอร์ม"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "ชุดคีย์ JWK ที่สร้างโดยแพลตฟอร์ม"

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "รหัสไคลเอ็นต์ที่ใช้โดยเครื่องมือ LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"การกำหนดค่า LTI ที่จัดเก็บไว้ในโมเดลสำหรับ LTI 1.3 จะต้องมีค่าสำหรับ "
"lti_1p3_tool_public_key หรือ lti_1p3_tool_keyset_url อย่างใดอย่างหนึ่ง"

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "การกำหนดค่าที่จัดเก็บไว้ในฟิลด์ XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "การกำหนดค่าที่จัดเก็บไว้ในรุ่นนี้"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "การกำหนดค่าที่เก็บไว้ในบริการภายนอก"

#: models.py:239
msgid "LTI configuration data."
msgstr "ข้อมูลการกำหนดค่า LTI"

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
