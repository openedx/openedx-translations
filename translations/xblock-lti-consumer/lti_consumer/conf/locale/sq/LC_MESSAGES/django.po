#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Mungon kodi i vërtetimit LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Titulli i kodit të pavlefshëm. Nuk ofrohen kredenciale."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Titulli i kodit të pavlefshëm. Vargu i tokenit nuk duhet të përmbajë "
"hapësira."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Konfigurimi LTI nuk u gjet."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Nënshkrimi simbol i pavlefshëm."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"Nuk u gjet asnjë ID e vlefshme e përdoruesit në URL-në e pikës fundore"

#: lti_xblock.py:147
msgid "New"
msgstr "E re"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Emri i shfaqur"

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Konsumatori LTI"

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Lloji i konfigurimit"

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versioni LTI"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Nis URL-në"

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI-të e regjistruara të ridrejtimit"

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Modaliteti i çelësit publik të mjetit"

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL e grupit të veglave"

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Çelësi publik i mjetit"

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Lidhje e thellë"

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL-ja e nisjes së lidhjes së thellë"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "I paaftë"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL LTI"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Parametrat e personalizuar"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Rezultati ruhet në xblock KVS -- dublikatë e rezultatit të publikuar në "
"django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Koment si i kthyer nga grader, specifikim LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Fshihni mjetin e jashtëm"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Dërgoni parametra shtesë"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Parametrat e personalizuar duhet të jenë një listë"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Parametrat e personalizuar duhet të jenë vargje në formatin &quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"ID-ja e konfigurimit të ripërdorshme duhet të vendoset kur përdoret "
"konfigurimi i jashtëm (Shembull: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"ID-ja e specifikuar LTI nuk është konfiguruar në Cilësimet e Avancuara të "
"këtij kursi."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nuk mund të merreshin të dhënat e përdoruesit për kërkesën aktuale"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nuk mund të analizohej pasaporta LTI: {lti_passport!r}. Duhet të jetë vargu "
"&quot;id:key:secret&quot;."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "ID-ja e përdoruesit nuk mund të merrej për kërkesën aktuale"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nuk mund të analizohej parametri i personalizuar: {custom_parameter!r}. "
"Duhet të jetë vargu &quot;x=y&quot;."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Përdoruesi i vërtetë nuk u gjet kundër anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Çelësi privat i krijuar nga platforma. Mbajeni të fshehtë këtë vlerë."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID-ja e çelësit privat të krijuar nga platforma"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Kompleti i tasteve JWK i krijuar nga platforma."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID-ja e klientit e përdorur nga mjeti LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Konfigurimi LTI i ruajtur në modelin për LTI 1.3 duhet të ketë një vlerë për"
" një nga lti_1p3_tool_public_key ose lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfigurimi i ruajtur në fushat XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfigurimi i ruajtur në këtë model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfigurimi i ruajtur në shërbimin e jashtëm"

#: models.py:239
msgid "LTI configuration data."
msgstr "Të dhënat e konfigurimit LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL-ja e mjetit të jashtëm që fillon nisjen."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Çelësi i klientit i dhënë nga ofruesi i veglave LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Sekreti i klientit i ofruar nga ofruesi i mjeteve LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Konfigurimi LTI ruan në XBlock ka nevojë për një grup vendndodhjeje blloku."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Konfigurimi LTI që përdor konfigurimin e ripërdorshëm ka nevojë për një ID "
"të jashtme në formatin &quot;x:y&quot;."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK dhe CONFIG_EXTERNAL nuk mbështeten për Shërbimet Mbrojtëse "
"LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Konfigurim i pavlefshëm LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Lloji i përzgjedhur i përmbajtjes nuk mbështetet nga Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Nuk ke akses për të ruajtur artikujt e përmbajtjes LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Ju lutemi kontrolloni që keni lejet e stafit të kursit dhe kontrolloni dy "
"herë cilësimet LTI të këtij blloku."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Lidhja e thellë LTI dështoi."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Lidhja e thellë LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Përmbajtja LTI Deep Linking u ruajt me sukses në LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Ju mund ta mbyllni me siguri këtë faqe tani."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "I paautorizuar."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Studentët nuk kanë leje për të kryer nisjet e konfigurimit të lidhjes së "
"thellë LTI."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Nisjet mund të kryhen vetëm nga LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Për të konfiguruar integrimin LTI, duhet të regjistroni LMS në mjet me "
"informacionin e dhënë më poshtë."

