#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Mungon kodi i vërtetimit LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Titulli i kodit të pavlefshëm. Nuk ofrohen kredenciale."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Titulli i kodit të pavlefshëm. Vargu i tokenit nuk duhet të përmbajë "
"hapësira."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Konfigurimi LTI nuk u gjet."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Nënshkrimi simbol i pavlefshëm."

#: lti_xblock.py:135
msgid "No valid user id found in endpoint URL"
msgstr ""
"Nuk u gjet asnjë ID e vlefshme e përdoruesit në URL-në e pikës fundore"

#: lti_xblock.py:148
msgid "New"
msgstr "E re"

#: lti_xblock.py:152
msgid "Database"
msgstr "Baza e të dhënave"

#: lti_xblock.py:155
msgid "Existing"
msgstr "ekzistuese"

#: lti_xblock.py:263
msgid "Display Name"
msgstr "Emri i shfaqur"

#: lti_xblock.py:265
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Vendosni emrin që shohin nxënësit për këtë komponent. Ky emër mund të "
"shfaqet edhe në raporte."

#: lti_xblock.py:268
msgid "LTI Consumer"
msgstr "Konsumatori LTI"

#: lti_xblock.py:271
msgid "Data Sharing Notice"
msgstr "Njoftim për ndarjen e të dhënave"

#: lti_xblock.py:273
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Vendosni një njoftim të shkurtër rreth mjetit. Përdoreni këtë fushë për të "
"shpjeguar pse të dhënat e nxënësve mund të ndahen me të."

#: lti_xblock.py:279
msgid "Configuration Type"
msgstr "Lloji i konfigurimit"

#: lti_xblock.py:284
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Zgjidhni 'E re' për të konfiguruar një mjet të ri LTI. Nëse administratori "
"juaj ju ka dhënë ID-në e një konfigurimi ekzistues të mjetit të "
"ripërdorshëm, zgjidhni 'Ekzistues' dhe shkruajeni atë në fushën e tekstit në"
" të djathtë."

#: lti_xblock.py:290
msgid "LTI Version"
msgstr "Versioni LTI"

#: lti_xblock.py:298
msgid "Select the LTI version supported by your tool."
msgstr "Zgjidhni versionin LTI të mbështetur nga mjeti juaj."

#: lti_xblock.py:303
msgid "LTI Reusability ID"
msgstr "ID-ja e ripërdorshmërisë LTI"

#: lti_xblock.py:305
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Vendosni ID-në e një konfigurimi ekzistues të mjetit të ripërdorshëm."

#: lti_xblock.py:310
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ID-ja e pasaportës Lti 1.3 që i referohet tabelës Lti1p3Passport"

#: lti_xblock.py:313
msgid "Passport ID for a reusable keys."
msgstr "ID-ja e pasaportës për çelësat e ripërdorshëm."

#: lti_xblock.py:317
msgid "Launch URL"
msgstr "Nis URL-në"

#: lti_xblock.py:321
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Vendosni URL-në e nisjes për këtë mjet. Për LTI 1.3, kjo është URL-ja që "
"Open edX përdor për të nisur mjetin."

#: lti_xblock.py:325
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL-ja e nisjes së hyrjes së mjetit (OIDC)"

#: lti_xblock.py:329
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Vendosni URL-në e fillimit të hyrjes OIDC të mjetit. Open edX e përdor këtë "
"URL për të filluar rrjedhën e hyrjes LTI 1.3."

#: lti_xblock.py:333
msgid "Registered Redirect URIs"
msgstr "URI-të e regjistruara të ridrejtimit"

#: lti_xblock.py:335
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Vendosni URI-të ridrejtuese që ky mjet lejohet të përdorë gjatë hyrjes, "
"p.sh. [\"https://tool.com\", \"https://tool_deeplink.com\"]. Lëreni bosh për"
" të përdorur URL-në e nisjes dhe URL-në e lidhjes së thellë si parazgjedhje."

#: lti_xblock.py:343
msgid "Tool Public Key Mode"
msgstr "Modaliteti i çelësit publik të mjetit"

#: lti_xblock.py:351
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Zgjidhni se si Open edX do të marrë çelësin publik të mjetit për vërtetimin "
"e mesazheve të nënshkruara."

#: lti_xblock.py:355
msgid "Tool Keyset URL"
msgstr "URL e grupit të veglave"

#: lti_xblock.py:359
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Vendosni URL-në e grupit të çelësave JWK të mjetit. Open edX e përdor këtë "
"URL për të marrë çelësat publikë të nevojshëm për të vërtetuar mesazhet e "
"nënshkruara."

#: lti_xblock.py:364
msgid "Tool Public Key"
msgstr "Çelësi publik i mjetit"

#: lti_xblock.py:369
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Vendosni çelësin publik të mjetit në formatin PEM (fillon me -----BEGIN "
"PUBLIC KEY-----). Përdoreni këtë kur mjeti ofron drejtpërdrejt një çelës "
"publik statik."

#: lti_xblock.py:375
msgid "Names & Roles (NRPS)"
msgstr "Emrat dhe Rolet (NRPS)"

#: lti_xblock.py:377
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Aktivizo këtë që mjeti të ketë akses në emrat dhe rolet e nxënësve të "
"regjistruar, nëse mjeti mbështet NRPS."

#: lti_xblock.py:386
msgid "Deep linking"
msgstr "Lidhje e thellë"

#: lti_xblock.py:388
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Aktivizoni këtë nëse dëshironi të lidhni thellësisht përmbajtjen nga brenda "
"mjetit, në Studio."

#: lti_xblock.py:394
msgid "Deep Linking Launch URL"
msgstr "URL-ja e nisjes së lidhjes së thellë"

#: lti_xblock.py:402
msgid "Assignment and Grades"
msgstr "Detyrat dhe notat"

#: lti_xblock.py:404
msgid "Declarative"
msgstr "Deklarativ"

#: lti_xblock.py:405
msgid "Programmatic"
msgstr "Programmatikë"

#: lti_xblock.py:406 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "I paaftë"

#: lti_xblock.py:411
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Aktivizo AGS dhe zgjidh funksionalitetin. 'Deklarative' i ofron mjetit një "
"artikull ekzistues. 'Programatike' i lejon mjetet të krijojnë dhe menaxhojnë"
" artikuj."

#: lti_xblock.py:420
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Zgjidhni ID-në e pasaportës LTI për këtë mjet. Kjo është ID-ja e pasaportës "
"LTI që keni krijuar në faqen e Konfigurimeve të avancuara."

#: lti_xblock.py:427
msgid "LTI URL"
msgstr "URL LTI"

#: lti_xblock.py:429
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Vendosni URL-në e nisjes për këtë mjet. Për LTI 1.1/1.2, kjo është URL-ja që"
" Open edX përdor për të nisur mjetin."

#: lti_xblock.py:437
msgid "Custom Parameters"
msgstr "Parametrat e personalizuar"

#: lti_xblock.py:439
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Vendosni çifte çelës-vlerë për t'u dërguar me çdo lëshim, p.sh. [\"faqe=1\","
" \"ngjyrë=bardhë\"]."

#: lti_xblock.py:444
msgid "Open tool in"
msgstr "Hap mjetin në"

#: lti_xblock.py:446
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Zgjidhni se si hapet mjeti për nxënësit: brenda faqes, në një dritare "
"modale, ose në një dritare të re."

#: lti_xblock.py:457
msgid "Launch Button Text"
msgstr "Teksti i butonit të nisjes"

#: lti_xblock.py:465
msgid "Inline Height (px)"
msgstr "Lartësia e brendshme (px)"

#: lti_xblock.py:467
msgid "Enter the height of the inline iframe in pixels."
msgstr "Vendosni lartësinë e iframe-it inline në pikselë."

#: lti_xblock.py:473
msgid "Modal Height (%)"
msgstr "Lartësia e dritares modale (%)"

#: lti_xblock.py:475
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Vendosni lartësinë modale si përqindje të dritares së shfletuesit."

#: lti_xblock.py:481
msgid "Modal Width (%)"
msgstr "Gjerësia e modalit (%)"

#: lti_xblock.py:483
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Vendosni gjerësinë modale si përqindje të dritares së shfletuesit."

#: lti_xblock.py:490
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "Aktivizo këtë nëse mjeti dërgon një rezultat numerik në Open edX."

#: lti_xblock.py:495
msgid "Grade Weight"
msgstr "Pesha e notës"

#: lti_xblock.py:497
msgid "Enter the maximum number of points for this component."
msgstr "Përcaktoni numrin maksimal të pikëve për këtë komponent."

#: lti_xblock.py:504
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Rezultati ruhet në xblock KVS -- dublikatë e rezultatit të publikuar në "
"django DB"

#: lti_xblock.py:509
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Koment si i kthyer nga grader, specifikim LTI2.0"

#: lti_xblock.py:514
msgid "Hide External Tool"
msgstr "Fshihni mjetin e jashtëm"

#: lti_xblock.py:516
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Aktivizo këtë për të fshehur butonin e nisjes dhe iframe-in, në mënyrë që të"
" përdorni komponentin për sinkronizimin e notave etj."

#: lti_xblock.py:523
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Aktivizo këtë për t'i lejuar mjetit të dërgojë notat pasi të ketë kaluar "
"afati i fundit."

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:533
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Aktivizoni këtë për të dërguar emrin e përdoruesit të nxënësit te mjeti."

#: lti_xblock.py:538
msgid "Share Full name"
msgstr "Ndani emrin e plotë"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:540
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Aktivizo këtë për të dërguar emrin e plotë të nxënësit te mjeti."

#: lti_xblock.py:545
msgid "Share Email"
msgstr "Ndani emailin"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:547
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Aktivizo këtë për të dërguar adresën e emailit të nxënësit te mjeti."

#: lti_xblock.py:553
msgid "Send extra parameters"
msgstr "Dërgoni parametra shtesë"

#: lti_xblock.py:554
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Aktivizojeni këtë për të dërguar parametra shtesë (mund të përmbajë PII). "
"Konsultohuni me administratorin e faqes për detaje."

#: lti_xblock.py:628
msgid "Custom Parameters must be a list"
msgstr "Parametrat e personalizuar duhet të jenë një listë"

#: lti_xblock.py:635
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Parametrat e personalizuar duhet të jenë vargje në formatin &quot;x=y&quot;."

#: lti_xblock.py:645
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"ID-ja e konfigurimit të ripërdorshme duhet të vendoset kur përdoret "
"konfigurimi i jashtëm (Shembull: &quot;x:y&quot;)."

#: lti_xblock.py:669
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"ID-ja e specifikuar LTI nuk është konfiguruar në Cilësimet e Avancuara të "
"këtij kursi."

#: lti_xblock.py:803 lti_xblock.py:1182
msgid "Could not get user data for current request"
msgstr "Nuk mund të merreshin të dhënat e përdoruesit për kërkesën aktuale"

#: lti_xblock.py:843
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nuk mund të analizohej pasaporta LTI: {lti_passport!r}. Duhet të jetë vargu "
"&quot;id:key:secret&quot;."

#: lti_xblock.py:861 lti_xblock.py:875 lti_xblock.py:891
msgid "Could not get user id for current request"
msgstr "ID-ja e përdoruesit nuk mund të merrej për kërkesën aktuale"

#: lti_xblock.py:1053
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nuk mund të analizohej parametri i personalizuar: {custom_parameter!r}. "
"Duhet të jetë vargu &quot;x=y&quot;."

#: lti_xblock.py:1582
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Përdoruesi i vërtetë nuk u gjet kundër anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Çelësi privat i krijuar nga platforma. Mbajeni të fshehtë këtë vlerë."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID-ja e çelësit privat të krijuar nga platforma"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Kompleti i tasteve JWK i krijuar nga platforma."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID-ja e klientit e përdorur nga mjeti LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Konfigurimi LTI i ruajtur në modelin për LTI 1.3 duhet të ketë një vlerë për"
" një nga lti_1p3_tool_public_key ose lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfigurimi i ruajtur në fushat XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfigurimi i ruajtur në këtë model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfigurimi i ruajtur në shërbimin e jashtëm"

#: models.py:239
msgid "LTI configuration data."
msgstr "Të dhënat e konfigurimit LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL-ja e mjetit të jashtëm që fillon nisjen."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Çelësi i klientit i dhënë nga ofruesi i veglave LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Sekreti i klientit i ofruar nga ofruesi i mjeteve LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Konfigurimi LTI ruan në XBlock ka nevojë për një grup vendndodhjeje blloku."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Konfigurimi LTI që përdor konfigurimin e ripërdorshëm ka nevojë për një ID "
"të jashtme në formatin &quot;x:y&quot;."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK dhe CONFIG_EXTERNAL nuk mbështeten për Shërbimet Mbrojtëse "
"LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Konfigurim i pavlefshëm LTI."

#: plugin/views.py:618
msgid "The selected content type is not supported by Open edX."
msgstr "Lloji i përzgjedhur i përmbajtjes nuk mbështetet nga Open edX."

#: plugin/views.py:633
msgid "You don't have access to save LTI Content Items."
msgstr "Nuk ke akses për të ruajtur artikujt e përmbajtjes LTI."

#: plugin/views.py:634
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Ju lutemi kontrolloni që keni lejet e stafit të kursit dhe kontrolloni dy "
"herë cilësimet LTI të këtij blloku."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Lidhja e thellë LTI dështoi."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Lidhja e thellë LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Përmbajtja LTI Deep Linking u ruajt me sukses në LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Ju mund ta mbyllni me siguri këtë faqe tani."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "I paautorizuar."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Studentët nuk kanë leje për të kryer nisjet e konfigurimit të lidhjes së "
"thellë LTI."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Nisjet mund të kryhen vetëm nga LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Për të konfiguruar integrimin LTI, duhet të regjistroni LMS në mjet me "
"informacionin e dhënë më poshtë."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "ID-ja e klientit: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID-ja e vendosjes: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL-ja e grupit të çelësave: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "Qasuni në URL-në e Tokenit: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL-ja e hyrjes: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Lidhja e thellë është konfiguruar në këtë mjet."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "Konfigurimi i Deep Linking i ruajtur është paraqitur më poshtë:"

#: templates/html/lti_1p3_studio.html:45
