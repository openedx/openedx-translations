msgid "Disabled"
msgstr "བཀག"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "རང་སྒྲིག་ཚད་གཞི།"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"སྐར་གྲངས་དེ་xblock KVSནང་དུ་བཞག་ཡོད། -- django "
"DBནང་དུ་པར་སྐྲུན་བྱས་པའི་སྐར་གྲངས་ཀྱི་འདྲ་བཤུས།"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "མཆན་འགྲེལ། འཛིན་གྲྭ་ནས་ཕྱིར་ལོག་བྱུང་། LTI2.0 ཆ་རྐྱེན།"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "ཕྱི་རོལ་གྱི་ལག་ཆ་སྦས།"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "རང་སྒྲིག་ཚད་གཞི་ནི་ཐོ་གཞུང་ཞིག་ཡིན་དགོས།"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "སྲོལ་སྒྲིག་ཚད་གཞི་གི་ཡིག་རྒྱུན་དེ་ \"x=y\" རྩ་སྒྲིག་ནང་བཞག་དགོས།"

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"ཕྱི་རོལ་གྱི་རིམ་སྒྲིག་བེད་སྤྱོད་བྱེད་སྐབས་བསྐྱར་དུ་བེད་སྤྱོད་གཏོང་ཐུབ་པའི་རིམ་སྒྲིག་IDདེ་སྒྲིག་དགོས།"
" (དཔེར་ན་: \"x:y\")"

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"སློབ་ཚན་འདིའི་ཡར་རྒྱས་སྒྲིག་སྟངས་ནང་གསལ་བཀོད་བྱས་པའི་LTI "
"IDདེ་སྒྲིག་བཀོད་བྱས་མེད།"

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "མིག་སྔའི་རེ་འདུན་ལ་སྤྱོད་མཁན་གྱི་གཞི་གྲངས་ཐོབ་མ་ཐུབ།"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"ཨེལ་ཊི་ཨའི་ཕྱི་སྐྱོད་ལག་ཁྱེར་དབྱེ་ཞིབ་བྱེད་མ་ཐུབ། {lti_passport!r} འདི་ "
"\"id:ལྡེ་མིག:གསང་བ་\" ཡིག་རྒྱུན་ཡིན་དགོས།"

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "མིག་སྔའི་རེ་འདུན་ལ་སྤྱོད་མཁན་ཨང་རྟགས་རག་མ་ཐུབ།"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"སྲོལ་སྒྲིག་ཚད་གཞི་དབྱེ་ཞིབ་མ་ཐུབ། {custom_parameter!r} འདི་ \"x=y\" "
"ཡིག་རྒྱུན་ཡིན་དགོས།"

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: དངོས་གནས་སྤྱོད་མཁན་མ་རྙེད། anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "སྟེགས་བུའི་སྒེར་གྱི་ལྡེ་མིག རིན་ཐང་འདི་གསང་བར་བྱོས།"

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "སྟེགས་བུའི་སྒེར་གྱི་ལྡེ་མིག་ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "སྟེགས་བུའི་བཟོས་པའི་JWKལྡེ་མིག་སྒྲིག་ཆས།"

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTIལག་ཆས་བེད་སྤྱོད་བྱས་པའི་ཚོང་ཤག་ཨང་རྟགས་"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 ཡི་དཔེ་གཞིའི་སྟེང་དུ་གསོག་འཇོག་བྱས་པའི་LTI རིམ་སྒྲིག་ལ་ "
"lti_1p3_tool_public_key ཡང་ན་ lti_1p3_tool_keyset_url ཡི་རིན་ཐང་དགོས།"

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "XBlock ཡིག་དུམ་ཐོག་གསོག་འཇོག་བྱས་པའི་རིམ་སྒྲིག"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "དཔེ་གཟུགས་འདིའི་སྟེང་དུ་སྒྲིག་བཀོད།"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "ཕྱི་རོལ་གྱི་ཞབས་ཞུའི་ཐོག་ཉར་ཚགས་བྱས་པའི་སྒྲིག་བཀོད།"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI བཀོད་སྒྲིག་གཞི་གྲངས།"

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "འགོ་འཛུགས་འགོ་འཛུགས་བྱེད་པའི་ཕྱི་རོལ་གྱི་ལག་ཆའི་URL།"

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr ""
"མཁོ་སྤྲོད་བྱེད་མཁན་གྱི་ལྡེ་མིག "
"LTIལག་ཆ་མཁོ་སྤྲོད་བྱེད་མཁན་གྱིས་མཁོ་སྤྲོད་བྱས།"

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr ""
"མཁོ་སྤྲོད་བྱེད་མཁན་གྱི་གསང་བ་དེ་LTIལག་ཆ་མཁོ་སྤྲོད་བྱེད་མཁན་གྱིས་མཁོ་སྤྲོད་བྱས།"

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"XBlock ཐོག་ལ་ཡོད་པའི་LTI རིམ་སྒྲིག་ཚོང་ཁང་ལ་བཀག་སྡོམ་གྱི་ས་གནས་ཆ་ཚང་དགོས།"

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"བསྐྱར་དུ་བེད་སྤྱོད་གཏོང་ཐུབ་པའི་སྒྲིག་བཀོད་བཀོལ་སྤྱོད་བྱེད་པའི་LTIསྒྲིག་བཀོད་ལ་\"x:y\"རྩ་སྒྲིག་ནང་ཕྱི་རོལ་གྱི་IDདགོས།"

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK དང་ CONFIG_EXTERNAL གཉིས་ LTI 1.3 "
"ལྟ་རྟོག་ཞབས་ཞུའི་ཆེད་དུ་རྒྱབ་སྐྱོར་བྱེད་ཀྱི་མེད།"

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "ནུས་མེད་ཀྱི་LTIསྒྲིག་བཀོད།"

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr ""
"འདེམས་སྒྲུག་བྱས་པའི་ནང་དོན་རིགས་དེ་ Open edX གིས་རྒྱབ་སྐྱོར་བྱེད་ཀྱི་མེད།"

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "ཁྱེད་ལ་LTIནང་དོན་རྣམ་གྲངས་ཉར་ཚགས་བྱེད་པའི་ཐོབ་ཐང་མེད།"

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr "སློབ་ཚན་གྱི་ལས་བྱེད་པའི་ཆོག་མཆན་ཡོད་མེད་བརྟག་དཔྱད་གནང་རོགས།"

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI གཏིང་ཟབ་པའི་འབྲེལ་མཐུད་འཐུས་ཤོར་བྱུང་།"

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI གཏིང་ཟབ་འབྲེལ་མཐུད།"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "LTI Deep Linking ནང་དོན་དེ་LMS ནང་དུ་མཐར་ཕྱིན་ངང་གསོག་འཇོག་བྱས།"

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "ཁྱེད་ཀྱིས་ད་ལྟ་ཤོག་ངོས་འདི་བདེ་འཇགས་ངང་ཁ་རྒྱག་ཆོག།"

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "དབང་ཆ་མེད་པ།"

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
