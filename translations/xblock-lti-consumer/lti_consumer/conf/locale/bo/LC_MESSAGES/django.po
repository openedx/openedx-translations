msgstr "སྒྲིག་བཀོད་རིགས།"

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI ཐོན་རིམ།"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "སྤྱོད་ལམ་འགོ་བཙུགས།"

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "ཐོ་འགོད་བྱས་པའི་བསྐྱར་ལམ་URIs"

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "ལག་ཆའི་སྤྱི་སྤྱོད་ལྡེ་མིག་ཐབས་ལམ།"

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "ལག་ཆའི་ལྡེ་མིག་ཆ་སྒྲིག་URL"

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "ལག་ཆའི་སྤྱི་སྤྱོད་ལྡེ་མིག"

#: lti_xblock.py:385
