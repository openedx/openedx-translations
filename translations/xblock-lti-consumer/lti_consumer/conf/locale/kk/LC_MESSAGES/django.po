#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Өшірілген"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Теңшелетін параметрлер"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"xblock KVS-де сақталған балл -- django DB-де жарияланған баллдың көшірмесі"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Грейдер, LTI2.0 спецификациядан қайтарылған түсініктеме"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Сыртқы құралды жасыру"

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Қосымша параметрлерді жіберіңіз"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Пайдаланушы параметрлері тізім болуы керек"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Пайдаланушы параметрлері \"x=y\" пішіміндегі жолдар болуы керек."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Сыртқы конфигурацияны пайдалану кезінде қайта пайдалануға болатын "
"конфигурация идентификаторы орнатылуы керек (Мысалы: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Көрсетілген LTI идентификаторы осы курстың Кеңейтілген параметрлерінде "
"конфигурацияланбаған."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Ағымдағы сұрау үшін пайдаланушы деректерін алу мүмкін болмады"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"LTI паспортын талдау мүмкін болмады: {lti_passport!r}. «id:key:secret» жолы "
"болуы керек."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Ағымдағы сұрау үшін пайдаланушы идентификаторын алу мүмкін болмады"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Теңшелетін параметрді талдау мүмкін болмады: {custom_parameter!r}. «x=y» "
"жолы болуы керек."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: anon_id бойынша нақты пайдаланушы табылмады: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Платформаның жасалған Жеке кілті. Бұл құндылықты құпия сақтаңыз."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Платформаның жасалған Жеке кілт идентификаторы"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Платформаның жасалған JWK кілттер жинағы."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTI құралы пайдаланатын клиент идентификаторы"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 үлгісінде сақталған LTI конфигурациясында lti_1p3_tool_public_key "
"немесе lti_1p3_tool_keyset_url біреуі үшін мән болуы керек."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "XBlock өрістерінде сақталған конфигурация"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Бұл үлгіде сақталған конфигурация"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Сыртқы қызметте конфигурация сақталады"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI конфигурация деректері."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Іске қосуды бастайтын сыртқы құралдың URL мекенжайы."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "LTI құралы провайдері қамтамасыз ететін клиент кілті."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "LTI құралы провайдері берген клиент құпиясы."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"XBlock жүйесіндегі LTI конфигурациясының қоймасы блоктар орны жинағын қажет "
"етеді."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Қайта пайдалануға болатын конфигурацияны пайдаланатын LTI конфигурациясына "
"\"x:y\" пішіміндегі сыртқы идентификатор қажет."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK және CONFIG_EXTERNAL LTI 1.3 Proctoring қызметтері үшін "
"қолдау көрсетілмейді."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "LTI конфигурациясы жарамсыз."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Таңдалған мазмұн түріне Open edX қолдау көрсетпейді."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "LTI мазмұн элементтерін сақтауға рұқсатыңыз жоқ."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Курс қызметкерлерінің рұқсаттары бар екенін және осы блоктың LTI "
"параметрлерін екі рет тексеріңіз."

#: templates/html/lti-dl/dl_response_error.html:6
