msgid "Disabled"
msgstr "Inaktiverad"

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Anpassade parametrar"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Poängen hölls i xblock KVS - duplikat av det publicerade poänget i django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Kommentera som returnerad från grader, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Dölj externt verktyg"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Aktivera detta för att skicka deltagarens e-postadress till verktyget."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Skicka extra parametrar"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Aktivera detta för att skicka extra parametrar (kan innehålla PII). Kontakta"
" webbplatsadministratören för mer information."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Anpassade parametrar måste vara en lista"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Anpassade parametrar ska vara strängar i formatet \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Återanvändbart konfigurations-ID måste anges när extern konfiguration "
"används (Exempel: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Den angivna LTI-ID:n är inte konfigurerad i den här kursens Avancerade "
"Inställningar."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Kunde inte hämta användardata för aktuell begäran"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Det gick inte att tolka LTI-passet: {lti_passport!r}. Bör vara "
"\"id:nyckel:hemlig\" sträng."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Kunde inte hämta användar-ID för aktuell begäran"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Kunde inte tolka anpassad parameter: {custom_parameter!r}. Bör vara en "
"\"x=y\"-sträng."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Verklig användare hittades inte mot anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Plattformens genererade privata nyckel. Håll detta värde hemligt."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Plattformens genererade privata nyckel-ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Plattformens genererade JWK-nyckeluppsättning."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Klient-ID som används av LTI-verktyg"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI-konfigurationen som lagras i modellen för LTI 1.3 måste ha ett värde för"
" antingen lti_1p3_tool_public_key eller lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguration lagrad på XBlock-fält"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfiguration lagrad på denna modell"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguration lagrad på extern tjänst"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI-konfigurationsdata."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL:en för det externa verktyget som initierar starten."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klientnyckel tillhandahållen av LTI-verktygsleverantören."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Klienthemlighet tillhandahållen av LTI-verktygsleverantören."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI-konfigurationer som lagras på XBlock behöver en blockplats inställd."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI-konfiguration som använder återanvändbar konfiguration behöver ett "
"externt ID i formatet \"x:y\"."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK och CONFIG_EXTERNAL stöds inte för LTI 1.3 Proctoring "
"Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Ogiltig LTI-konfiguration."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Den valda innehållstypen stöds inte av Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Du har inte behörighet att spara LTI-innehållsobjekt."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Kontrollera att du har kursanställdas behörighet och dubbelkolla detta "
"blocks LTI-inställningar."

