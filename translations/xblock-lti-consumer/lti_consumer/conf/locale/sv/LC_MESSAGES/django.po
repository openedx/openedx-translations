#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Saknas LTI 1.3-autentiseringstoken."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Ogiltig tokenrubrik. Inga referenser angivna."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "Ogiltig tokenhuvud. Tokensträngen får inte innehålla mellanslag."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI-konfiguration hittades inte."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Ogiltig tokensignatur."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Ingen giltig användar-id hittades i slutpunktens URL"

#: lti_xblock.py:147
msgid "New"
msgstr "Ny"

#: lti_xblock.py:151
msgid "Database"
msgstr "Databas"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Befintlig"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Visningsnamn"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Ange namnet som deltagarna ser för den här komponenten. Namnet kan även "
"visas i rapporter."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI-konsument"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Meddelande om datadelning"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Ange en kort information om verktyget. Använd det här fältet för att "
"förklara varför elevdata kan delas med det."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Konfigurationstyp"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Välj \"Ny\" för att konfigurera ett nytt LTI-verktyg. Om din administratör "
"har gett dig ID för en befintlig återanvändbar verktygskonfiguration, välj "
"\"Befintlig\" och ange det i textfältet till höger."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI-version"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Välj den LTI-version som ditt verktyg stöder."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "LTI-återanvändnings-ID"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Ange ID för en befintlig återanvändbar verktygskonfiguration."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti 1.3-pass-ID som pekar på Lti1p3Passport-tabellen"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Pass-ID för återanvändbara nycklar."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Starta URL"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Ange start-URL:en för det här verktyget. För LTI 1.3 är detta den URL som "
"Open edX använder för att starta verktyget."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL för verktygets initieringsinloggning (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Ange verktygets OIDC-URL för inloggningsinitiering. Open edX använder denna "
"URL för att starta LTI 1.3-inloggningsflödet."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Registrerade omdirigerings-URI:er"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Ange de omdirigerings-URI:er som det här verktyget får använda under "
"inloggning, t.ex. [\"https://tool.com\", \"https://tool_deeplink.com\"]. "
"Lämna fältet tomt för att använda start-URL:en och djuplänknings-URL:en som "
"standard."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Verktygets offentliga nyckelläge"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Välj hur Open edX ska få verktygets publika nyckel för att validera "
"signerade meddelanden."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Verktygsnyckeluppsättningens URL"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Ange URL:en till verktygets JWK-nyckeluppsättning. Open edX använder denna "
"URL för att hämta de publika nycklar som behövs för att validera signerade "
"meddelanden."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Verktygets offentliga nyckel"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Ange verktygets publika nyckel i PEM-format (börjar med -----BEGIN PUBLIC "
"KEY-----). Använd detta när verktyget tillhandahåller en statisk publik "
"nyckel direkt."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Namn och roller (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Aktivera detta för att tillåta verktyget att komma åt namn och roller för "
"registrerade deltagare, om verktyget stöder NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Djup länkning"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr "Aktivera detta om du vill djuplänka innehåll från verktyget i Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL för start av djup länkning"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Ange djuplänknings-URL:en för det här verktyget. Om verktyget inte anger "
"någon, ange \"Start-URL\" här."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Uppgifter och betyg"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklarativ"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programmatisk"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Inaktiverad"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Aktivera AGS och välj funktionalitet. \"Deklarativ\" ger verktyget en "
"befintlig radpost. \"Programmatisk\" låter verktyg skapa och hantera "
"radposter."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI Passport-ID"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Välj LTI-pass-ID för det här verktyget. Detta är ID:t för det LTI-pass som "
"du skapade på sidan Avancerade Inställningar."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Ange start-URL:en för det här verktyget. För LTI 1.1/1.2 är detta den URL "
"som Open edX använder för att starta verktyget."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Anpassade parametrar"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Ange nyckel-värde-par att skicka med varje start, t.ex. [\"page=1\", "
"\"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Öppna verktyget i"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Välj hur verktyget öppnas för deltagarna: infogat på sidan, i en modal eller"
" i ett nytt fönster."

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Ange etiketten som visas på startknappen när verktyget öppnas i en modal "
"eller ett nytt fönster."

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Ange höjden för den inbäddade iframen i pixlar."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Modalhöjd (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Ange modalhöjden som en procentandel av webbläsarfönstret."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Modalbredd (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Ange modalens bredd som en procentandel av webbläsarfönstret."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Denna aktivitet är betygsatt"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Aktivera detta om verktyget skickar ett numeriskt resultat tillbaka till "
"Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Betygsvikt"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Ange det maximala antalet poäng för den här komponenten."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Poängen hölls i xblock KVS - duplikat av det publicerade poänget i django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Kommentera som returnerad från grader, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Dölj externt verktyg"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Aktivera detta för att dölja startknappen och iframen så att du kan använda "
"komponenten för betygssynkronisering etc."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Acceptera betyg efter förfallodatum"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Aktivera detta för att tillåta verktyget att skicka betyg efter att "
"förfallodatumet har passerat."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Dela användarnamn"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Aktivera detta för att skicka deltagarens användarnamn till verktyget."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Dela fullständigt namn"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Aktivera detta för att skicka deltagarens fullständiga namn till verktyget."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Dela e-post"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Aktivera detta för att skicka deltagarens e-postadress till verktyget."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Skicka extra parametrar"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Aktivera detta för att skicka extra parametrar (kan innehålla PII). Kontakta"
" webbplatsadministratören för mer information."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Anpassade parametrar måste vara en lista"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Anpassade parametrar ska vara strängar i formatet \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Återanvändbart konfigurations-ID måste anges när extern konfiguration "
"används (Exempel: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Den angivna LTI-ID:n är inte konfigurerad i den här kursens Avancerade "
"Inställningar."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Kunde inte hämta användardata för aktuell begäran"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Det gick inte att tolka LTI-passet: {lti_passport!r}. Bör vara "
"\"id:nyckel:hemlig\" sträng."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Kunde inte hämta användar-ID för aktuell begäran"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Kunde inte tolka anpassad parameter: {custom_parameter!r}. Bör vara en "
"\"x=y\"-sträng."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Verklig användare hittades inte mot anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Plattformens genererade privata nyckel. Håll detta värde hemligt."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Plattformens genererade privata nyckel-ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Plattformens genererade JWK-nyckeluppsättning."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Klient-ID som används av LTI-verktyg"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI-konfigurationen som lagras i modellen för LTI 1.3 måste ha ett värde för"
" antingen lti_1p3_tool_public_key eller lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguration lagrad på XBlock-fält"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfiguration lagrad på denna modell"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguration lagrad på extern tjänst"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI-konfigurationsdata."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL:en för det externa verktyget som initierar starten."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klientnyckel tillhandahållen av LTI-verktygsleverantören."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Klienthemlighet tillhandahållen av LTI-verktygsleverantören."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI-konfigurationer som lagras på XBlock behöver en blockplats inställd."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI-konfiguration som använder återanvändbar konfiguration behöver ett "
"externt ID i formatet \"x:y\"."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK och CONFIG_EXTERNAL stöds inte för LTI 1.3 Proctoring "
"Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Ogiltig LTI-konfiguration."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Den valda innehållstypen stöds inte av Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Du har inte behörighet att spara LTI-innehållsobjekt."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Kontrollera att du har kursanställdas behörighet och dubbelkolla detta "
"blocks LTI-inställningar."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI Deep Linking misslyckades."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI Deep Linking"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "LTI Deep Linking-innehållet sparades framgångsrikt i LMS:en."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Du kan nu stänga den här sidan."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Obehörig."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Studenter har inte behörighet att utföra LTI Deep Linking-"
"konfigurationsstarter."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3-lanseringar kan endast utföras från LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"För att ställa in LTI-integrationen behöver du registrera LMS:et i verktyget"
" med informationen nedan."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Klient-ID: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Distributions-ID: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "Nyckeluppsättningens URL: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "Åtkomsttoken-URL: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "Inloggnings-URL: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Djup länkning är konfigurerad på detta verktyg."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "Den lagrade konfigurationen för Deep Linking presenteras nedan:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr "Om du kör djup länkning igen kommer innehållet ovan att ersättas."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Du kan konfigurera det här verktygets innehåll med hjälp av LTI Deep "
"Linking."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"För att göra det, se till att blocket är publicerat och klicka på länken "
"nedan:"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Starta djup länkning - Konfigurera verktyg"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Tryck på för att starta"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "Det uppstod ett fel vid start av LTI-verktyget: "

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
"If you're seeing this on a live course, please contact the course staff."
msgstr "Om du ser detta på en livekurs, vänligen kontakta kursens personal."

#: templates/html/lti_proctoring_start_error.html:10
msgid "There was an error while starting your LTI proctored assessment."
msgstr ""
"Det uppstod ett fel när din LTI-proktorerade bedömning skulle startas."

#: templates/html/lti_start_assessment.html:11
msgid "Sending you back to your exam."
msgstr "Skickar dig tillbaka till ditt prov."

#: templates/html/lti_start_assessment.html:15
msgid "Return to exam."
msgstr "Återgå till prov."

#: templates/html/lti_studio_edit/_actions.html:5
msgid "Previous"
msgstr "Tidigare"

#: templates/html/lti_studio_edit/_actions.html:10
#: static/js/xblock_lti_consumer.js:143
msgid "Cancel"
msgstr "Avbryt"

#: templates/html/lti_studio_edit/_actions.html:13
msgid "Next"
msgstr "Nästa"

