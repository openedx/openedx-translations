#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Token di autenticazione LTI 1.3 mancante."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Intestazione del token non valida. Nessuna credenziale fornita."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Intestazione del token non valida. La stringa token non deve contenere "
"spazi."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Configurazione LTI non trovata."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Firma del token non valida."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Nessun ID utente valido trovato nell&#39;url dell&#39;endpoint"

#: lti_xblock.py:147
msgid "New"
msgstr "Nuovo"

#: lti_xblock.py:151
msgid "Database"
msgstr "Database"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Esistente"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Mostra il nome"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Inserisci il nome che gli studenti vedono per questo componente. Questo nome"
" potrebbe apparire anche nei report."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Consumatore LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Informativa sulla condivisione dei dati"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Inserisci una breve nota sullo strumento. Utilizza questo campo per spiegare"
" perché i dati degli studenti potrebbero essere condivisi con esso."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Tipo di configurazione"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Seleziona \"Nuovo\" per configurare un nuovo strumento LTI. Se l'admin ti ha"
" fornito l'ID di una configurazione strumento riutilizzabile esistente, "
"seleziona \"Esistente\" e inseriscilo nel campo di testo a destra."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versione LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Seleziona la versione LTI supportata dal tuo strumento."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "ID di riutilizzabilità LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Inserisci l'ID di una configurazione strumento riutilizzabile esistente."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ID passaporto LTI 1.3 che rimanda alla tabella Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Passaporto ID per chiavi riutilizzabili."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL di avvio"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Inserisci l'url di avvio per questo strumento. Per LTI 1.3, questo è l'url "
"che Open edX utilizza per avviare lo strumento."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL di avvio del login dello strumento (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Inserisci l'URL di avvio del login OIDC dello strumento. Open edX utilizza "
"questo URL per avviare il flusso di login LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI di reindirizzamento registrati"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Inserisci gli URI di reindirizzamento che questo strumento può utilizzare "
"durante l'accesso, ad esempio [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Lascia vuoto per utilizzare l'url di avvio e"
" l'url di deep linking per impostazione predefinita."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Modalità chiave pubblica dello strumento"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Scegli come Open edX otterrà la chiave pubblica dello strumento per la "
"convalida dei messaggi firmati."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL del set di chiavi dello strumento"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Inserisci l'URL del set di chiavi JWK dello strumento. Open edX utilizza "
"questo URL per recuperare le chiavi pubbliche necessarie per convalidare i "
"messaggi firmati."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Chiave pubblica dello strumento"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Inserisci la chiave pubblica dello strumento in formato PEM (inizia con "
"-----BEGIN PUBLIC KEY-----). Usala quando lo strumento fornisce direttamente"
" una chiave pubblica statica."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Nomi e ruoli (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Abilita questa opzione per consentire allo strumento di accedere ai nomi e "
"ai ruoli degli studenti iscritti, se lo strumento supporta NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Collegamento profondo"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Abilita questa opzione se vuoi collegare in profondità il contenuto dallo "
"strumento, in Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL di avvio del collegamento diretto"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Inserisci l'URL di deep linking per questo strumento. Se lo strumento non ne"
" specifica uno, inserisci qui l'URL di avvio."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Assegnazione e voti"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Dichiarativo"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programmatico"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Disabilitato"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Abilita AGS e seleziona la funzionalità. \"Dichiarativo\" fornisce allo "
"strumento una voce di riga esistente. \"Programmatico\" consente agli "
"strumenti di creare e gestire voci di riga."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "ID passaporto LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Seleziona l'ID del passaporto LTI per questo strumento. Questo è l'ID del "
"passaporto LTI che hai creato nella pagina Impostazioni Avanzate."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Inserisci l'URL di avvio per questo strumento. Per LTI 1.1/1.2, questo è "
"l'URL che Open edX utilizza per avviare lo strumento."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Parametri personalizzati"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Inserisci coppie chiave-valore da inviare a ogni avvio, ad esempio "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Apri lo strumento in"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Scegli come lo strumento si apre per gli studenti: in linea nella pagina, in"
" una finestra modale o in una nuova finestra."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Testo pulsante di avvio"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Inserisci l'etichetta mostrata sul pulsante di avvio quando lo strumento si "
"apre in una finestra modale o in una nuova finestra."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Altezza in linea (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Inserisci l'altezza dell'iframe inline in pixel."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Altezza modale (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr ""
"Inserisci l'altezza della modale come percentuale della finestra del "
"browser."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Larghezza modale (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr ""
"Inserisci la larghezza della modale come percentuale della finestra del "
"browser."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Questa attività è valutata"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Abilita questa opzione se lo strumento invia un punteggio numerico a Open "
"edX."

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Inserire il numero massimo di punti per questo componente."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Il punteggio conservato in xblock KVS -- duplicato del punteggio pubblicato "
"nel DB django"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Commento come restituito dall'esaminatore, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Nascondi Strumento Esterno"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Abilita questa opzione per nascondere il pulsante di avvio e l'iframe, in "
"modo da utilizzare il componente per la sincronizzazione dei voti, ecc."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Accetta voti dopo la data di scadenza"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Abilita questa opzione per consentire allo strumento di inviare i voti anche"
" dopo la scadenza."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Condividi nome utente"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Abilita questa opzione per inviare il nome utente del discente allo "
"strumento."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Condividi nome completo"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Abilita questa opzione per inviare il nome completo del discente allo "
"strumento."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Condividi email"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Abilita questa opzione per inviare l'indirizzo email del discente allo "
"strumento."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Invia parametri aggiuntivi"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Abilita questa opzione per inviare parametri aggiuntivi (potrebbero "
"contenere PII). Consulta l'admin del sito per i dettagli."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "I parametri personalizzati devono essere un elenco"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"I parametri personalizzati devono essere stringhe nel formato "
"&quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"L&#39;ID di configurazione riutilizzabile deve essere impostato quando si "
"utilizza la configurazione esterna (esempio: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"L&#39;ID LTI specificato non è configurato nelle Impostazioni Avanzate di "
"questo corso."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Impossibile ottenere i dati utente per la richiesta corrente"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Impossibile analizzare il passaporto LTI: {lti_passport!r}. Dovrebbe essere "
"la stringa \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Impossibile ottenere l&#39;ID utente per la richiesta corrente"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Impossibile analizzare il parametro personalizzato: {custom_parameter!r}. "
"Dovrebbe essere la stringa \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: utente reale non trovato rispetto anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Chiave privata generata dalla piattaforma. Mantieni segreto questo valore."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID della chiave privata generata dalla piattaforma"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Set di chiavi JWK generato dalla piattaforma."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID client utilizzato dallo strumento LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"La configurazione LTI archiviata nel modello per LTI 1.3 deve avere un "
"valore per uno tra lti_1p3_tool_public_key e lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Configurazione memorizzata sui campi XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Configurazione memorizzata su questo modello"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Configurazione archiviata nel servizio esterno"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dati di configurazione LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "L'URL dello strumento esterno che avvia l'avvio."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Chiave client fornita dal fornitore dello strumento LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Segreto client fornito dal fornitore dello strumento LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Gli archivi di configurazione LTI su XBlock necessitano di una posizione di "
"blocco impostata."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"La configurazione LTI che usa la configurazione riutilizzabile richiede un "
"ID esterno nel formato &quot;x:y&quot;."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK e CONFIG_EXTERNAL non sono supportati per i servizi di "
"supervisione LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Configurazione LTI non valida."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Il tipo di contenuto selezionato non è supportato da Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Non hai accesso per salvare elementi di contenuto LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Verifica di disporre delle autorizzazioni del corso e ricontrolla le "
"impostazioni LTI di questo blocco."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Collegamento profondo LTI non riuscito."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Collegamento profondo LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr ""
"Il contenuto LTI Deep Linking è stato salvato correttamente nel sistema LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Puoi chiudere tranquillamente questa pagina ora."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Non autorizzato."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Gli studenti non dispongono delle autorizzazioni per configurare lanci di "
"LTI Deep Linking."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "I lanci LTI 1.3 possono essere eseguiti solo dall&#39;LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Per impostare l&#39;integrazione LTI, è necessario registrare l&#39;LMS "
"nello strumento con le informazioni fornite di seguito."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Identificativo cliente: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID distribuzione: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL del set di chiavi: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL del token di accesso: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL di accesso: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Deep Linking è configurato su questo strumento."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr ""
"La configurazione dei collegamenti profondi memorizzata è presentata di "
"seguito:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Se esegui nuovamente il collegamento diretto, il contenuto sopra verrà "
"sostituito."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Puoi configurare il contenuto di questo strumento utilizzando LTI Deep "
"Linking."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"Per fare ciò, assicurati che il blocco sia pubblicato e clicca sul "
"collegamento seguente:"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Lancio di Deep Linking: Configura strumento"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Premere per Lanciare"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "Si è verificato un errore durante l&#39;avvio dello strumento LTI: "

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
"If you're seeing this on a live course, please contact the course staff."
msgstr ""
"Se vedi questo durante un Corso dal vivo, contatta lo staff del Corso."

#: templates/html/lti_proctoring_start_error.html:10
msgid "There was an error while starting your LTI proctored assessment."
msgstr ""
