msgid "Platform's generated Private key ID"
msgstr "Platform tərəfindən yaradılan Şəxsi açar ID-si"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platform tərəfindən yaradılan JWK açar dəsti."

