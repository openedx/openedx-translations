msgid "Client ID used by LTI tool"
msgstr "LTI aləti tərəfindən istifadə olunan Müştəri ID-si"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 üçün modeldə saxlanılan LTI Konfiqurasiyası lti_1p3_tool_public_key "
"və ya lti_1p3_tool_keyset_url üçün bir dəyərə malik olmalıdır."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "XBlock sahələrində saxlanılan konfiqurasiya"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Bu modeldə konfiqurasiya saxlanılıb"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiqurasiya xarici xidmətdə saxlanılır"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI konfiqurasiya məlumatları."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Xarici alətin işə salınmasını başladan URL."

