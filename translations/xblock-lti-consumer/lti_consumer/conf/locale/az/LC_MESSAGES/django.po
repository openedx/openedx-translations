msgid "Client key provided by the LTI tool provider."
msgstr "Müştəri açarı LTI alət təminatçısı tərəfindən təqdim edilir."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Müştəri sirri LTI alət təminatçısı tərəfindən təqdim edilir."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI Konfiqurasiyası XBlock-da saxlanılır və blokun yeri təyin edilməlidir."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
