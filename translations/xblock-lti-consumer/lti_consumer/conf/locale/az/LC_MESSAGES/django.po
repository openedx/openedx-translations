#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "LTI 1.3 autentifikasiya tokeni çatışmır."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Token başlığı etibarsızdır. Heç bir etimadnamə təqdim edilməyib."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "Token başlığı etibarsızdır. Token sətiri boşluqlar içerməməlidir."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI konfiqurasiyası tapılmadı."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Etibarsız token imzası."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Son nöqtə URL-də etibarlı istifadəçi ID-si tapılmadı"

#: lti_xblock.py:147
msgid "New"
msgstr "Yeni"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Mövcud"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Görünüş adı"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Tələbələrin bu komponent üçün gördüyü adı daxil edin. Bu ad hesabatlarda da "
"görünə bilər."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI İstehlakçısı"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Məlumat Paylaşma Bildirişi"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Alət haqqında qısa bildiriş daxil edin. Bu sahədən tələbə məlumatlarının "
"niyə onunla paylaşıla biləcəyini izah etmək üçün istifadə edin."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Konfiqurasiya Növü"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Yeni LTI Alətini konfiqurasiya etmək üçün \"Yeni\" seçin. Əgər "
"administratorunuz sizə mövcud təkrar istifadə edilə bilən alət "
"konfiqurasiyasının ID-sini təqdim edibsə, \"Mövcud\" seçin və sağdakı mətn "
"sahəsinə daxil edin."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI Versiyası"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Alətinizin dəstəklədiyi LTI versiyasını seçin."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "LTI Təkrar İstifadə İD-si"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Mövcud təkrar istifadə edilə bilən alət konfiqurasiyasının ID-sini daxil "
"edin."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Lti1p3Passport cədvəlinə işarə edən Lti 1.3 pasport ID-si"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Başlatma URL-si"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Bu alət üçün başlatma URL-ini daxil edin. LTI 1.3 üçün bu, Open edX-in aləti"
" başlatmaq üçün istifadə etdiyi URL-dir."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "Alətin Giriş URL-ini Başlat (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Alətin OIDC giriş başlama URL-ini daxil edin. Open edX LTI 1.3 giriş axınını"
" başlamaq üçün bu URL-dən istifadə edir."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Qeydiyyatdan keçmiş yönləndirmə URI-ləri"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Bu alətin giriş zamanı istifadə etməsinə icazə verilən yönləndirmə URI-"
"lərini daxil edin, məsələn [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Varsayılan olaraq işə salma URL-ini və "
"dərindən keçid URL-ini istifadə etmək üçün bu sahəni boş buraxın."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Alət İctimai Açar Rejimi"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Open edX-in imzalanmış mesajları təsdiqləmək üçün alətin açıq açarını necə "
"əldə edəcəyini seçin."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Alət Açar Dəsti URL-i"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Alətin JWK açar dəstinin URL-ini daxil edin. Open edX imzalanmış mesajları "
"təsdiqləmək üçün lazım olan açıq açarları əldə etmək üçün bu URL-dən "
"istifadə edir."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Alətin İctimai Açarı"

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Adlar və Rolllar (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Alətin NRPS-i dəstəklədiyi təqdirdə, onun qeydiyyatdan keçmiş tələbələrin "
"adlarına və rollarına daxil olmasına icazə vermək üçün bunu aktivləşdirin."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Dərin əlaqələndirmə"

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "Dərin Bağlantı Başlatma URL-si"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Bu alət üçün dərindən keçid URL-ini daxil edin. Əgər alət bunu göstərmirsə, "
"buraya \"Başlatma URL-i\"ni daxil edin."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Tapşırıq və Qiymətlər"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklarativ"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Proqramlı"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "deaktiv"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"AGS-i aktivləşdirin və funksionallığı seçin. \"Bəyannamə\" alətə mövcud "
"sətir elementi təqdim edir. \"Proqramlaşdırma\" alətlərə sətir elementləri "
"yaratmağa və idarə etməyə imkan verir."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI Passport ID"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Bu alət üçün LTI pasport ID-sini seçin. Bu, Qabaqcıl Parametrlər səhifəsində"
" yaratdığınız LTI pasportunun ID-sidir."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Bu alət üçün işə salma URL-ini daxil edin. LTI 1.1/1.2 üçün bu, Open edX-in "
"aləti işə salmaq üçün istifadə etdiyi URL-dir."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Xüsusi parametrlər"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Hər bir işə salma ilə göndəriləcək açar-dəyər cütlərini daxil edin, məsələn:"
" [\"page=1\", \"color=white\"]."

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Şagirdlər üçün alətin necə açılacağını seçin: səhifədə daxili, modalda və ya"
" yeni pəncərədə."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Başlat düyməsinin mətni"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Alət modal və ya yeni pəncərədə açıldıqda işə salma düyməsində göstərilən "
"etiketi daxil edin."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Sətirdaxili Hündürlük (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Səhifədaxili iframe-in hündürlüyünü piksellərlə daxil edin."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Modal hündürlüyü (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Modal hündürlüyünü brauzer pəncərəsinin faizi ilə daxil edin."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Modal Eni (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Modalın enini brauzer pəncərəsinin faizi ilə daxil edin."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Bu fəaliyyət qiymətləndirilir"

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Qiymət çəkisi"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Bu komponent üçün maksimum bal sayını daxil edin."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Hesab xblock KVS-də saxlanılır - django DB-də nəşr olunmuş hesabın dublikatı"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Qiymət qoyandan şərh gəldikdə, LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Xarici aləti gizlədin"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Alətin son tarixdən sonra qiymətlər göndərməsinə icazə vermək üçün bunu "
"aktiv edin."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "İstifadəçi adını paylaşın"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Öyrənənin istifadəçi adını alətə göndərmək üçün bunu aktiv edin."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Tam adı paylaşın"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Öyrənənin tam adını alətə göndərmək üçün bunu aktiv edin."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "E-poçtu paylaşın"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Öyrənənin e-poçt ünvanını alətə göndərmək üçün bunu aktiv edin."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Əlavə parametrləri göndərin"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Əlavə parametrləri göndərmək üçün bunu aktiv edin (şəxsi məlumatları ehtiva "
"edə bilər). Ətraflı məlumat üçün sayt administratoru ilə məsləhətləşin."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Xüsusi Parametrlər siyahı olmalıdır"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Xüsusi Parametrlər \"x=y\" formatında sətirlər olmalıdır."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Yenidən istifadə edilə bilən konfiqurasiya ID-si xarici konfiqurasiya "
"istifadə edildikdə təyin edilməlidir (Məsələn: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Bu kursun Ətraflı Parametrlərində göstərilən LTI ID konfiqurasiya edilməyib."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Cari sorğu üçün istifadəçi məlumatlarını əldə etmək mümkün olmadı"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"LTI pasportunu yoxlaya bilmədi: {lti_passport!r}. \"id:key:secret\" "
"olmalıdır."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Cari sorğu üçün istifadəçi ID-si əldə edilə bilmədi"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Xüsusi parametrləri yoxlaya bilmədi: {custom_parameter!r}. \"x = y\" "
"bərabərliyi olmalıdır."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Həqiqi istifadəçi anon_id: {} ilə tapılmadı"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Platform tərəfindən yaradılan Şəxsi açar. Bu dəyəri gizli saxlayın."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platform tərəfindən yaradılan Şəxsi açar ID-si"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platform tərəfindən yaradılan JWK açar dəsti."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTI aləti tərəfindən istifadə olunan Müştəri ID-si"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 üçün modeldə saxlanılan LTI Konfiqurasiyası lti_1p3_tool_public_key "
"və ya lti_1p3_tool_keyset_url üçün bir dəyərə malik olmalıdır."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "XBlock sahələrində saxlanılan konfiqurasiya"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Bu modeldə konfiqurasiya saxlanılıb"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiqurasiya xarici xidmətdə saxlanılır"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI konfiqurasiya məlumatları."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Xarici alətin işə salınmasını başladan URL."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Müştəri açarı LTI alət təminatçısı tərəfindən təqdim edilir."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Müştəri sirri LTI alət təminatçısı tərəfindən təqdim edilir."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"LTI Konfiqurasiyası XBlock-da saxlanılır və blokun yeri təyin edilməlidir."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI konfiqurasiyası üçün təkrar istifadə edilə bilən konfiqurasiya xarici "
"ID-nin \"x:y\" formatında olmasını tələb edir."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "LTI 1.3 üçün konfiqurasiya pasportun təyin olunmasını tələb edir."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK və CONFIG_EXTERNAL LTI 1.3 Proktorinq Xidmətləri üçün "
"dəstəklənmir."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "LTI konfiqurasiyası etibarsızdır."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Seçilmiş məzmun növü Open edX tərəfindən dəstəklənmir."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "LTI Məzmun Elementlərini saxlamaq üçün girişiniz yoxdur."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Zəhmət olmasa, kurs heyəti icazələrinizin olduğunu yoxlayın və bu blokun LTI"
" parametrlərini iki dəfə yoxlayın."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI Dərin Bağlantı uğursuz oldu."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI Dərin Bağlantı"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "LTI Dərin Bağlantı məzmunu LMS-də uğurla yadda saxlanıldı."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "İndi bu səhifəni təhlükəsiz şəkildə bağlaya bilərsiniz."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "İcazəsiz."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Tələbələrin LTI Dərin Bağlantı konfiqurasiya başlatmalarını yerinə yetirmək "
"icazəsi yoxdur."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Başlatmaları yalnız LMS-dən həyata keçirilə bilər."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"LTI inteqrasiyasını qurmaq üçün, aşağıda verilmiş məlumatlarla LMS-i alətdə "
"qeydiyyatdan keçirməlisiniz."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Müştəri ID: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Yerləşdirmə ID-si: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "Açar dəsti URL: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "Giriş Tokeni URL-si: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "Giriş URL: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Dərin Bağlantı bu alətdə konfiqurasiya edilib."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
