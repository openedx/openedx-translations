msgstr ""
"LTI konfiqurasiyası üçün təkrar istifadə edilə bilən konfiqurasiya xarici "
"ID-nin \"x:y\" formatında olmasını tələb edir."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "LTI 1.3 üçün konfiqurasiya pasportun təyin olunmasını tələb edir."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK və CONFIG_EXTERNAL LTI 1.3 Proktorinq Xidmətləri üçün "
"dəstəklənmir."

#: models.py:369
msgid "Invalid LTI configuration."
