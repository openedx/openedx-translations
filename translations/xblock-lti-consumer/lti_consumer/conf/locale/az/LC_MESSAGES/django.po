#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Hesab xblock KVS-də saxlanılır - django DB-də nəşr olunmuş hesabın dublikatı"

