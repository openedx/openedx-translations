#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Отсутствует токен аутентификации LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Неверный заголовок токена. Учетные данные не предоставлены."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Неверный заголовок токена. Строка токена не должна содержать пробелов."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Конфигурация LTI не найдена."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Неверная подпись токена."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"В URL конечной точки не найден действительный идентификатор пользователя."

#: lti_xblock.py:147
msgid "New"
msgstr "Новый"

#: lti_xblock.py:151
msgid "Database"
msgstr "База данных"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Существующий"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Отображаемое имя"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Введите название, которое слушатели будут видеть для этого Компонента. Это "
"название также может отображаться в отчетах."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI потребитель"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Уведомление об обмене данных"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Введите краткое примечание об инструменте. Используйте это поле, чтобы "
"объяснить, почему данные слушателей могут быть переданы ему."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Тип конфигурации"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Выберите «Новый», чтобы настроить новый инструмент LTI. Если ваш "
"администратор предоставил вам идентификатор существующей многократно "
"используемой конфигурации инструмента, выберите «Существующий» и введите его"
" в текстовое поле справа."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI-версия"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Выберите версию LTI, поддерживаемую вашим инструментом."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "Идентификатор повторного использования LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Введите Идентификатор существующей многократно используемой конфигурации "
"инструмента."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ИДЕНТИФИКАТОР паспорта LTI 1.3, указывающий на таблицу Lti1p3Passport"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL-адрес запуска"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Введите URL-адрес запуска для этого инструмента. Для LTI 1.3 это URL-адрес, "
"который Open edX использует для запуска инструмента."

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Введите URL-адрес инициации входа OIDC для инструмента. Open edX использует "
"этот URL-адрес для запуска процесса входа LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Зарегистрированные URI перенаправления"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Введите URI перенаправления, которые этот инструмент может использовать во "
"время входа в систему, например [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Оставьте это поле пустым, чтобы по умолчанию"
" использовать URL запуска и URL глубокой ссылки."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Режим открытого ключа инструмента"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Выберите, как Open edX будет получать открытый ключ инструмента для проверки"
" подписанных сообщений."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL набора ключей инструмента"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Введите URL набора ключей JWK инструмента. Open edX использует этот URL для "
"получения открытых ключей, необходимых для проверки подписанных сообщений."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Открытый ключ инструмента"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Введите открытый ключ инструмента в формате PEM (начинается с -----BEGIN "
"PUBLIC KEY-----). Используйте это, когда инструмент предоставляет "
"статический открытый ключ напрямую."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Имена и роли (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Включите эту опцию, чтобы инструмент мог получать доступ к именам и ролям "
"зачисленных слушателей, если инструмент поддерживает NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Глубокие ссылки"

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL-адрес запуска диплинкинга"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Введите URL-адрес глубокой ссылки для этого инструмента. Если инструмент не "
"указывает его, введите здесь «URL-адрес запуска»."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Задание и Оценка"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Декларативный"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Программный"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Отключено"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Включите AGS и выберите функциональность. «Декларативный» предоставляет "
"инструменту существующий элемент строки. «Программный» позволяет "
"инструментам создавать элементы строки и управлять ими."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "Идентификатор LTI Passport"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Выберите Идентификатор LTI-паспорта для этого инструмента. Это Идентификатор"
" LTI-паспорта, который вы создали на странице «Расширенные настройки»."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL на LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Введите URL-адрес запуска для этого инструмента. Для LTI 1.1/1.2 это URL-"
"адрес, который Open edX использует для запуска инструмента."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Пользовательские параметры"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Введите пары \"ключ-значение\" для отправки при каждом запуске, например "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Открыть инструмент в"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Выберите, как инструмент открывается для слушателей: встроенно на странице, "
"в модальном окне или в новом окне."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Текст кнопки запуска"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Введите метку, отображаемую на кнопке запуска, когда инструмент открывается "
"в модальном или новом окне."

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Введите высоту встроенного iframe в пикселях."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Высота модального окна (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Введите высоту модального окна в процентах от окна браузера."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Ширина модального окна (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Введите ширину модального окна в процентах от окна браузера."

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Включите эту опцию, если инструмент отправляет числовую оценку обратно в "
"Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Вес оценки"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Введите максимальное количество баллов для этого компонента."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Результат сохранён в xblock KVS — дубликат опубликованного результата в "
"django DB."

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Комментарий оценивающего, спецификация LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Скрыть внешнее приложение"

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Принимать оценки после срока сдачи"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Включите эту опцию, чтобы инструмент мог отправлять оценки после истечения "
"срока сдачи."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Поделиться Именем Пользователя"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Включите эту опцию, чтобы отправить имя пользователя слушателя в инструмент."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Поделиться полным именем"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Включите эту опцию, чтобы отправить полное имя слушателя в инструмент."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Поделиться электронной почтой"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Включите эту опцию, чтобы отправить адрес электронной почты слушателя в "
"инструмент."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Отправить дополнительные параметры"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Включите это, чтобы отправлять дополнительные параметры (могут содержать "
"персональные данные). За подробностями обратитесь к администратору сайта."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Пользовательские параметры должны быть списком"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Пользовательские параметры должны быть строками в формате «x=y»."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Идентификатор многократно используемой конфигурации должен быть установлен "
"при использовании внешней конфигурации (пример: «x:y»)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Указанный идентификатор LTI не настроен в Расширенных настройках этого "
"курса."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Не удалось получить данные пользователя для текущего запроса."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Не удалось распознать регистрационные данные LTI: {lti_passport!r}. "
"Требуется строка вида \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Не удалось получить идентификатор пользователя для текущего запроса."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Не удалось проанализировать специальный параметр: {custom_parameter!r}. "
"Должна быть строка «x=y»."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Реальный пользователь не найден по anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Сгенерированный платформой закрытый ключ. Держите данное значение в секрете."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Идентификатор закрытого ключа, сгенерированный платформой"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Набор ключей JWK, сгенерированный платформой."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Идентификатор клиента, используемый инструментом LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Конфигурация LTI, хранящаяся в модели для LTI 1.3, должна иметь значение "
"одного из lti_1p3_tool_public_key или lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Конфигурация хранится в полях XBlock."

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Конфигурация сохранена на этой модели"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Конфигурация хранится на внешнем сервисе"

#: models.py:239
msgid "LTI configuration data."
msgstr "Данные конфигурации LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL внешнего инструмента, инициирующего запуск."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Клиентский ключ, предоставленный поставщиком инструмента LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Секрет клиента, предоставленный поставщиком инструмента LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Хранилищам конфигурации LTI в XBlock нужна установка местонахождения блока."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Для конфигурации LTI с использованием многоразовой конфигурации требуется "
"внешний идентификатор в формате «x:y»."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK и CONFIG_EXTERNAL не поддерживаются для служб прокторинга "
"LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Неверная конфигурация LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Выбранный тип контента не поддерживается Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "У вас нет доступа сохранить единицы контента LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Убедитесь, что у вас есть права доступа персонала курса, и ещё раз проверьте"
" настройки LTI этого блока."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Не удалось выполнить глубокое связывание LTI."

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Контент LTI Deep Linking был успешно сохранен в СУО."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Вы можете безопасно закрыть эту страницу сейчас."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Неавторизовано."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr "У студентов нет разрешения на запуск конфигурации LTI Deep Linking."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Запуски можно выполнять только из СУО."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Чтобы настроить интеграцию LTI, вам необходимо зарегистрировать СУО в "
"инструменте, используя информацию, указанную ниже."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "ID клиента: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Идентификатор развертывания: "

#: templates/html/lti_1p3_studio.html:21
