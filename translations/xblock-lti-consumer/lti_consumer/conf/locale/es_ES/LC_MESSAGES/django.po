msgid "New"
msgstr "Nuevo"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nombre para mostrar"

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Consumidor LTI"

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Tipo de configuración"

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versión LTI"

