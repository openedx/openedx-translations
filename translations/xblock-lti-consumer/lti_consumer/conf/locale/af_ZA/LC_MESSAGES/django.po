msgstr "Pasgemaakte parameters"

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Die telling gehou in die xblok KVS -- duplikaat van die gepubliseerde "
"telling in django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Kommentaar soos teruggestuur van gradeerder, LTI2.0-spesifikasie"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Versteek eksterne hulpmiddel"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Aktiveer dit om die leerder se e-posadres na die instrument te stuur."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Stuur ekstra parameters"

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Gepasmaakte parameters moet &#39;n lys wees"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Gepasmaakte parameters moet stringe in &quot;x=y&quot;-formaat wees."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Herbruikbare konfigurasie-ID moet gestel word wanneer eksterne konfigurasie "
"gebruik word (Byvoorbeeld: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Die gespesifiseerde LTI ID is nie in hierdie kursus se Gevorderde "
"Instellings opgestel nie."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Kon nie gebruikerdata vir huidige versoek kry nie"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Kon nie LTI-paspoort ontleed nie: {lti_passport!r}. Moet "
"&quot;id:key:secret&quot;-string wees."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Kon nie gebruiker-ID vir huidige versoek kry nie"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Kon nie gepasmaakte parameter ontleed nie: {custom_parameter!r}. Moet "
"&quot;x=y&quot;-string wees."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Regte gebruiker nie gevind teen anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Platform se gegenereerde privaat sleutel. Hou hierdie waarde geheim."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platform se gegenereerde privaatsleutel-ID"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platform se gegenereerde JWK-sleutelstel."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Kliënt-ID wat deur LTI-nutsding gebruik word"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI-konfigurasie wat op die model vir LTI 1.3 gestoor word, moet &#39;n "
"waarde hê vir een van lti_1p3_tool_public_key of lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfigurasie gestoor op XBlock-velde"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfigurasie Geberg op hierdie model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfigurasie gestoor op eksterne diens"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI-konfigurasiedata."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Die URL van die eksterne nutsding wat die bekendstelling begin."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Kliëntsleutel verskaf deur die LTI-nutsmiddelverskaffer."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Kliëntgeheim verskaf deur die LTI-nutsmiddelverskaffer."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr "LTI-konfigurasiewinkels op XBlock benodig &#39;n blokliggingstel."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"LTI-konfigurasie wat herbruikbare konfigurasie gebruik, benodig &#39;n "
"eksterne ID in &quot;x:y&quot;-formaat."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "LTI-konfigurasie vir 1.3 vereis dat paspoort gestel moet word."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK en CONFIG_EXTERNAL word nie vir LTI 1.3 Proctoring Services"
" ondersteun nie."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Ongeldige LTI-opstelling."

