#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Jeton d&#39;authentification LTI 1.3 manquant."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr ""
"En-tête de jeton non valide. Aucune information d'identification fournie."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"En-tête de jeton invalide. La chaîne de jetons ne doit pas contenir "
"d&#39;espaces."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI configuration introuvable."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Signature de jeton invalide."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"Aucun identifiant utilisateur valide trouvé dans l'url du point de "
"terminaison"

#: lti_xblock.py:147
msgid "New"
msgstr "Nouveau"

#: lti_xblock.py:151
msgid "Database"
msgstr "Base de données"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Existant"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nom d'affichage"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Saisissez le nom que les apprenants verront pour ce composant. Ce nom peut "
"également apparaître dans les rapports."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Consommateur LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Avis de partage de données"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Entrez une brève note sur l’outil. Utilisez ce champ pour expliquer pourquoi"
" les données des apprenants peuvent être partagées avec cet outil."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Type de Configuration"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Sélectionnez « Nouveau » pour configurer un nouvel outil LTI. Si votre admin"
" vous a fourni l'ID d'une configuration d'outil réutilisable existante, "
"sélectionnez « Existant » et saisissez-le dans le champ de texte à droite."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Version LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Sélectionnez la version LTI prise en charge par votre outil."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "ID de réutilisation LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Entrez l’ID d’une configuration d’outil réutilisable existante."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Identité de passeport LTI 1.3 qui pointe vers la table Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "ID de passeport pour des clés réutilisables."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL de lancement"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Saisissez l’URL de lancement de cet outil. Pour LTI 1.3, il s’agit de l’URL "
"qu’Open edX utilise pour lancer l’outil."

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Saisissez l’URL d’initialisation de la connexion OIDC de l’outil. Open edX "
"utilise cette URL pour démarrer le flux de connexion LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI de redirection enregistrés"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Saisissez les URI de redirection que cet outil est autorisé à utiliser lors "
"de la connexion, par exemple [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Laissez ce champ vide pour utiliser l'URL de"
" lancement et l'URL de lien profond par défaut."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Mode de clé publique de l'outil"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Choisissez comment Open edX obtient la clé publique de l’outil pour valider "
"les messages signés."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL de la clé de l'outil"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Entrez l’URL de l’ensemble de clés JWK de l’outil. Open edX utilise cette "
"URL pour récupérer les clés publiques nécessaires à la validation des "
"messages signés."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Clé publique de l&#39;outil"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Entrez la clé publique de l’outil au format PEM (commence par -----BEGIN "
"PUBLIC KEY-----). Utilisez cette option lorsque l’outil fournit directement "
"une clé publique statique."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Noms et rôles (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Activez cette option pour permettre à l'outil d'accéder aux noms et aux "
"rôles des apprenants inscrits, si l'outil prend en charge NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Liens profonds"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Activez cette option si vous souhaitez créer des liens profonds vers du "
"contenu à partir de l'outil, dans Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL de lancement des liens profonds"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Entrez l'URL de lien profond pour cet outil. Si l'outil n'en spécifie pas, "
"entrez l'« URL de lancement » ici."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Devoirs et notes"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Déclaratif"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programmatique"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Désactivé"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Activez AGS et sélectionnez la fonctionnalité. « Déclaratif » fournit à "
"l'outil un élément de ligne existant. « Programmatique » permet aux outils "
"de créer et de gérer des éléments de ligne."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "ID de passeport LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Sélectionnez l'ID de passeport LTI pour cet outil. Il s'agit de l'ID du "
"passeport LTI que vous avez créé sur la page Paramètres avancés."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "url LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Saisissez l'URL de lancement de cet outil. Pour LTI 1.1/1.2, il s'agit de "
"l'URL qu'Open edX utilise pour lancer l'outil."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Paramètres Personnalisés"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Entrez des paires clé-valeur à envoyer à chaque lancement, par exemple "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Ouvrir l'outil dans"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Choisissez comment l'outil s'ouvre pour les apprenants : intégré à la page, "
"dans une fenêtre modale ou dans une nouvelle fenêtre."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Texte du bouton de lancement"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Saisissez l'étiquette affichée sur le bouton de lancement lorsque l'outil "
"s'ouvre dans une fenêtre modale ou une nouvelle fenêtre."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Hauteur en ligne (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Entrez la hauteur du cadre intégré (iframe) en pixels."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Hauteur du modal (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr ""
"Saisissez la hauteur de la fenêtre modale en pourcentage de la fenêtre du "
"navigateur."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Largeur modale (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr ""
"Entrez la largeur de la modale en pourcentage de la fenêtre du navigateur."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Cette activité est notée"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Activez cette option si l'outil renvoie un score numérique à Open edX."

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Nombre maximal de points pour ce composant."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"La partition conservée dans le xblock KVS -- doublon de la partition publiée"
" dans Django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Commentaire renvoyé par l'évaluateur, spécification LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Masquer l&#39;outil externe"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Activez cette option pour masquer le bouton de lancement et l'iframe afin "
"d'utiliser le composant pour la synchronisation des notes, etc."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Acceptez les notes après la date limite"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Activez cette option pour permettre à l'outil d'envoyer les notes après la "
"date limite."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Partager le nom d'utilisateur"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Activez cette option pour que le nom d’utilisateur de l’apprenant soit "
"envoyé à l’outil."

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Activez cette option pour envoyer le nom complet de l’apprenant à l’outil."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Partager l'adresse courriel"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Activez cette option pour que l’adresse courriel de l’apprenant soit envoyée"
" à l’outil."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Envoyer des paramètres extra"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Activez cette option pour envoyer des paramètres supplémentaires (peut "
"contenir des renseignements personnels identifiables). Consultez l’admin du "
"site pour plus de détails."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Les paramètres personnalisés doivent être une liste"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Les Paramètres Personnalisés doivent être des chaînes au format "
"&quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"L&#39;Identité de configuration réutilisable doit être définie lors de "
"l&#39;utilisation d&#39;une configuration externe (Exemple : "
"&quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"L&#39;Identité LTI spécifiée n&#39;est pas configurée dans les Paramètres "
"avancés de ce cours."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr ""
"Impossible d&#39;obtenir les données utilisateur pour la demande actuelle"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Impossible d'analyser le passeport LTI : {lti_passport!r}. Devrait être une "
"chaîne \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr ""
"Nous n&#39;arrivons pas à obtenir l&#39;identité utilisateur pour la demande"
" en cours."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Impossible d'analyser le paramètre personnalisé: {custom_parameter!r}. Doit "
"être une chaîne \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI] : utilisateur réel introuvable pour anon_id : {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Clé privée générée par la plateforme. Gardez cette valeur secrète."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Identité de clé privée générée par la plateforme"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Jeu de clés JWK généré par la plateforme."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Identité client utilisé par l'outil LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"La configuration LTI stockée sur le modèle pour LTI 1.3 doit avoir une "
"valeur parmi lti_1p3_tool_public_key ou lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Configuration stockée sur les champs du XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Configuration stockée sur ce modèle"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Configuration stockée sur un service externe"

#: models.py:239
msgid "LTI configuration data."
msgstr "Données de configuration LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "L&#39;URL de l&#39;outil externe qui initie le lancement."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Clé client fournie par le fournisseur d&#39;outils LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Client secret fourni par le fournisseur d&#39;outils LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Les configurations LTI sont stockées sur XBlock et ont besoin d'un ensemble "
"de localisations de bloc."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"La configuration LTI utilisant une configuration réutilisable nécessite une "
"identité externe au format « x:y »."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr ""
"La Configuration LTI pour la version 1.3 nécessite que le passeport soit "
"défini."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK et CONFIG_EXTERNAL ne sont pas pris en charge pour les "
"services de surveillance LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "La configuration LTI est invalide."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr ""
"Le type de contenu sélectionné n&#39;est pas pris en charge par Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Vous n'avez pas accès d'enregistrer les éléments de contenu LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Veuillez vérifier que vous disposez des permissions du personnel du cours et"
" confirmez les paramètres LTI de ce bloc."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Échec du lien profond LTI."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Liens profonds LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Le contenu LTI Deep Linking a bien été enregistré dans le LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Vous pouvez maintenant fermer cette page en toute sécurité."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Non autorisé."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Les apprenants ne disposent pas des permissions nécessaires pour effectuer "
"des lancements de configuration LTI Deep Linking."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr ""
"Les lancements LTI 1.3 ne peuvent être effectués qu&#39;à partir du LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Pour configurer l&#39;intégration LTI, vous devez enregistrer le LMS dans "
"l&#39;outil avec les informations fournies ci-dessous."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Identité du client : "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID de déploiement : "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL du jeu de clés : "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL du jeton d'accès : "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL de connexion : "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Deep Linking est configurée sur cet outil."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "La configuration de Deep Linking stockée est présentée ci-dessous :"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Si vous exécutez à nouveau le deep linking, le contenu ci-dessus sera "
"remplacé."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Vous pouvez configurer le contenu de cet outil à l&#39;aide de LTI Deep "
"Linking."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"Pour ce faire, assurez-vous que le bloc est publié et cliquez sur le lien "
"ci-dessous :"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Lancement du Lien Profond - Configuration de l'outil"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Appuyez pour lancer"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "Une erreur s&#39;est produite lors du lancement de l&#39;outil LTI : "

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
"If you're seeing this on a live course, please contact the course staff."
msgstr ""
"Si vous voyez cela sur un cours en direct, veuillez contacter l&#39;équipe "
"du cours."

#: templates/html/lti_proctoring_start_error.html:10
