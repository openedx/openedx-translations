#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Falta o 'token' de autenticação LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Cabeçalho do 'token' inválido. Nenhuma credencial fornecida."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Cabeçalho de token inválido. A string de token não deve conter espaços."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Configuração LTI não encontrada."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Assinatura de token inválida."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Nenhum ID de utilizador válido no URL de destino"

#: lti_xblock.py:147
msgid "New"
msgstr "Novo"

#: lti_xblock.py:151
msgid "Database"
msgstr "Base de dados"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Existente"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nome"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Introduza o nome que os estudantes veem para este componente. Este nome "
"também pode aparecer em relatórios."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Consumidor LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Aviso de Partilha de Dados"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Introduza uma breve nota sobre a ferramenta. Utilize este campo para "
"explicar por que os dados dos estudantes podem ser partilhados com a mesma."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Tipo de configuração"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Selecione \"Novo\" para configurar uma nova ferramenta LTI. Se o seu "
"administrador lhe disponibilizou o Id. de uma configuração de ferramenta "
"reutilizável existente, selecione \"Existente\" e introduza-o no campo de "
"texto à direita."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versão LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Selecione a versão LTI suportada pela sua ferramenta."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "ID de Reutilização LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Introduza o Id. de uma configuração de ferramenta reutilizável existente."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ID do passaporte Lti 1.3 que aponta para a tabela Lti1p3Passport"

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL de lançamento"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Introduza o URL de lançamento para esta ferramenta. Para LTI 1.3, este é o "
"URL que o Open edX utiliza para lançar a ferramenta."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL de Início de Sessão da Ferramenta (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Introduza o URL de início de sessão OIDC da ferramenta. O Open edX utiliza "
"este URL para iniciar o fluxo de início de sessão LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URIs de redireccionamento registados"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Introduza os URIs de redirecionamento que esta ferramenta pode utilizar "
"durante o início de sessão, por exemplo, [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Deixe este campo em branco para utilizar o "
"URL de lançamento e o URL de ligação profunda por predefinição."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Modo de chave pública da ferramenta"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Escolha como o Open edX irá obter a chave pública da ferramenta para validar"
" mensagens assinadas."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL do conjunto de chaves da ferramenta"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Introduza o URL do conjunto de chaves JWK da ferramenta. O Open edX utiliza "
"este URL para obter as chaves públicas necessárias para validar mensagens "
"assinadas."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Ferramenta Chave Pública"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Introduza a chave pública da ferramenta em formato PEM (começa com "
"-----BEGIN PUBLIC KEY-----). Utilize esta opção quando a ferramenta "
"disponibiliza uma chave pública estática diretamente."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Nomes e Perfis (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Ativar esta opção para permitir que a ferramenta aceda aos nomes e perfis "
"dos estudantes inscritos, caso a ferramenta suporte NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Ligação profunda"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Ative esta opção se quiser criar ligações diretas para conteúdos da "
"ferramenta, no Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL de lançamento Deep Linking"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Introduza o URL de ligação direta para esta ferramenta. Se a ferramenta não "
"especificar um, introduza o \"URL de Lançamento\" aqui."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Tarefa e Notas"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Declarativo"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programático"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Desativado"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Ative o AGS e selecione a funcionalidade. \"Declarativo\" disponibiliza à "
"ferramenta um item de linha existente. \"Programático\" permite que as "
"ferramentas criem e gerenciem itens de linha."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "Id. do Passaporte LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Selecione o Id. do passaporte LTI para esta ferramenta. Este é o Id. do "
"passaporte LTI que criou na página Configurações Avançadas."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Introduza o URL de lançamento para esta ferramenta. Para LTI 1.1/1.2, este é"
" o URL que o Open edX utiliza para lançar a ferramenta."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Parâmetros personalizados"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Introduza pares de chave-valor para enviar com cada lançamento, por exemplo,"
" [\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Abrir ferramenta em"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Escolha como a ferramenta se abre para os estudantes: incorporada na página,"
" num modal ou numa nova janela."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Texto do Botão de Lançamento"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Introduza a etiqueta apresentada no botão de lançamento quando a ferramenta "
"abre numa janela modal ou nova janela."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Altura em linha (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Introduza a altura do iframe incorporado em píxeis."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Altura do Modal (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr ""
"Introduza a altura do modal como uma percentagem da janela do navegador."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Largura do Modal (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr ""
"Introduza a largura do modal como uma percentagem da janela do navegador."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Esta atividade é classificada"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Ative esta opção se a ferramenta enviar uma pontuação numérica para o Open "
"edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Ponderação da Classificação"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Introduza o número máximo de pontos para este componente."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"A pontuação mantida no xblock KVS -- duplicado da pontuação publicada no "
"django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "O comentário apresentado pelo avaliador, especificação LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Ocultar Ferramenta Externa"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Ativar esta opção para ocultar o botão de lançamento e o iframe, para que "
"possa usar o componente para sincronização de notas, etc."

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Ative esta opção para permitir que a ferramenta envie as classificações após"
" a data limite ter passado."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Partilhar Nome de Utilizador"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Ativar esta opção para enviar o nome de utilizador do estudante para a "
"ferramenta."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Partilhar nome completo"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Ative esta opção para enviar o nome completo do estudante para a ferramenta."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Partilhar e-mail"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Ative esta opção para enviar o endereço de e-mail do estudante para a "
"ferramenta."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Enviar parâmetros extras"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Ativar esta opção para enviar parâmetros adicionais (pode conter PII). "
"Consulte o administrador do site para obter detalhes."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Os parâmetros personalizados devem ser uma lista"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Os parâmetros personalizados devem ser cadeias de caracteres no formato "
"\"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"A ID de configuração reutilizável deve ser definida quando se utiliza a "
"configuração externa (Exemplo: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"O ID LTI indicado não está configurado nas Definições Avançadas deste curso."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Não foi possível obter os dados do utilizador para o pedido actual"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Não foi possível analisar o passaporte LTI: {lti_passport!r}. Deve ser a "
"string \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Não foi possível obter ID de usuário para a solicitação atual"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Não foi possível analisar o parâmetro personalizado: {custom_parameter!r}. "
"Deve ser uma string \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: usuário real não encontrado contra anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Chave privada gerada pela plataforma. Mantenha esse valor em segredo."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID da chave privada gerada pela plataforma"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Conjunto de chaves JWK gerado pela plataforma."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID do cliente usado pela ferramenta LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"A configuração de LTI armazenada no modelo para LTI 1.3 deve ter um valor "
"para uma das chaves lti_1p3_tool_public_key ou lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Configuração armazenada em campos XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Configuração armazenada neste modelo"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Configuração armazenada num serviço externo"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dados de configuração LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL da ferramenta externa que inicia a inicialização."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Chave do cliente fornecida pelo provedor da ferramenta LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Segredo do cliente fornecido pelo provedor da ferramenta LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Os armazenamentos de configuração LTI no XBlock precisam de um conjunto de "
"localização de bloco."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"A Configuração LTI que utiliza a configuração reutilizável necessita de uma "
"identificação externa no formato \"x:y\"."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "A Configuração LTI para 1.3 requer que o passaporte esteja definido."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK e CONFIG_EXTERNAL não são suportados pelos serviços de "
"supervisão de avaliação LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Configuração de LTI inválida."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "O tipo de conteúdo selecionado não é suportado pelo Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Você não tem acesso para salvar itens de conteúdo LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Verifique se você tem permissões de equipe do curso e verifique novamente as"
" configurações de LTI deste bloco."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI Deep Linking falhou."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI Deep Linking"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "O conteúdo LTI Deep Linking foi salvo com sucesso no LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Você pode fechar esta página com segurança agora."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Não autorizado."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Os alunos não têm permissão para executar inicializações de configuração de "
"LTI Deep Linking."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Os lançamentos do LTI 1.3 só podem ser executados a partir do LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Para configurar a integração LTI, você precisa se registar no LMS na "
"ferramenta com as informações fornecidas abaixo."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "ID do cliente: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID de instalação: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL do conjunto de chaves: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL de token de acesso: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL de login: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Deep Linking é configurado nesta ferramenta."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "A configuração do Deep Linking armazenada é apresentada a seguir:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Se você executar links diretos novamente, o conteúdo acima será substituído."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Você pode configurar o conteúdo desta ferramenta usando LTI Deep Linking."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"Para isso, certifique-se de que o bloco é publicado e clique no link abaixo:"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Lançamento de Deep Linking - Configurar ferramenta"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Pressione para iniciar"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "Ocorreu um erro no lançamento da ferramenta LTI:"

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
"If you're seeing this on a live course, please contact the course staff."
msgstr ""
"Se estiver a ver isto num curso ao vivo, por favor contacte a equipa do "
"curso."

#: templates/html/lti_proctoring_start_error.html:10
msgid "There was an error while starting your LTI proctored assessment."
msgstr "Ocorreu um erro ao iniciar a sua avaliação supervisionada LTI."

#: templates/html/lti_start_assessment.html:11
