#: default_data.py:5
msgid ""
"An isosceles triangle with three layers of similar height. It is shown "
"upright, so the widest layer is located at the bottom, and the narrowest "
"layer is located at the top."
msgstr ""
"Trójkąt równoramienny z trzema warstwami o podobnej wysokości. Jest pokazany"
" pionowo, więc najszersza warstwa znajduje się na dole, a najwęższa warstwa "
"znajduje się na górze."

#: default_data.py:14
msgid "The Top Zone"
msgstr "Górna strefa"

#: default_data.py:15
msgid "The Middle Zone"
msgstr "Strefa Środka"

#: default_data.py:16
msgid "The Bottom Zone"
msgstr "Strefa Dolna"

#: default_data.py:18
msgid "Use this zone to associate an item with the top layer of the triangle."
msgstr "Użyj tej strefy, aby powiązać element z górną warstwą trójkąta."

#: default_data.py:19
msgid ""
"Use this zone to associate an item with the middle layer of the triangle."
msgstr "Użyj tej strefy, aby powiązać przedmiot ze środkową warstwą trójkąta."

#: default_data.py:20
msgid ""
"Use this zone to associate an item with the bottom layer of the triangle."
msgstr "Użyj tej strefy, aby powiązać element z dolną warstwą trójkąta."

#: default_data.py:22
msgid "Correct! This one belongs to The Top Zone."
msgstr "Prawidłowo! Ten należy do Strefy Top."

#: default_data.py:23
msgid "Correct! This one belongs to The Middle Zone."
msgstr "Prawidłowo! Ten należy do Strefy Środkowej."

#: default_data.py:24
msgid "Correct! This one belongs to The Bottom Zone."
msgstr "Prawidłowo! Ten należy do Strefy Dolnej."

#: default_data.py:25
msgid "No, this item does not belong here. Try again."
msgstr "Nie, ten przedmiot nie pasuje tutaj. Spróbuj ponownie."

#: default_data.py:26
msgid "You silly, there are no zones for this one."
msgstr "Oj, tutaj nie ma żadnych stref."

#: default_data.py:27
msgid "Of course it goes here! It goes anywhere!"
msgstr "Oczywiście, że idzie tutaj! To idzie wszędzie!"

#: default_data.py:29
msgid "Goes to the top"
msgstr "Idzie na górę"

#: default_data.py:30
msgid "Goes to the middle"
msgstr "Idzie do środka"
