msgstr "არასწორი კურსის id: '{course_id}'"

#: views.py:95
#, python-brace-format
msgid "Course not found: '{course_id}'"
msgstr "კურსი ვერ მოიძებნა: „ {course_id} “"

#: xblock.py:47 xblock.py:48
msgid "Display name"
msgstr "საჩვენებელი სახელი"

#: xblock.py:49
msgid "Superset Dashboard"
msgstr "Superset -ის საინფორმაციო დაფა"

#: xblock.py:54
msgid "Dashboard UUID"
msgstr "დაფის UUID"

#: xblock.py:56
msgid ""
"The ID of the dashboard to embed. Available in the Superset embed dashboard "
"UI."
msgstr ""
"ჩასაშენებელი დაფის ID. იგი ხელმისაწვდომია Superset -ის ჩასაშენებელი დაფის "
"ინტერფეისში."

#: xblock.py:63
msgid "Filters"
msgstr "ფილტრები"

#: xblock.py:65
msgid ""
"List of SQL filters to apply to the\n"
"               dashboard. E.g: [\"org='edX'\", \"country in ('us', 'co')\"]\n"
"               The fields used here must be available on every dataset used by the dashboard.\n"
"               "
msgstr ""
"გამოსაყენებელი SQL ფილტრების სია\n"
"დაფა. მაგ.: [\"org='edX'\", \"country in ('us', 'co')\"]\n"
" აქ გამოყენებული ველები ხელმისაწვდომი უნდა იყოს დაფის მიერ გამოყენებულ ყველა მონაცემთა ნაკრებზე.\n"
"               "
