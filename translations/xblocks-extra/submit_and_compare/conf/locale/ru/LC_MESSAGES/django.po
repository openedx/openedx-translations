#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} возможный балл"
msgstr[1] "{weight} возможных баллов"
msgstr[2] "{weight} возможных баллов"
msgstr[3] "{weight} возможных баллов"

#: views.py:301
#, python-brace-format
