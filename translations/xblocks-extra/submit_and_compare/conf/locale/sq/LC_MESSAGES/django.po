#: templates/edit.html:8
msgid "Display Name"
msgstr "Emri i shfaqur"

#: templates/edit.html:16
msgid "Weight"
msgstr "Pesha"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Kjo cakton një vlerë të plotë që përfaqëson peshën e këtij problemi"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Numri maksimal i tentativave"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Kjo cakton një vlerë të plotë që përfaqëson numrin maksimal të përpjekjeve "
"që një student mund të bëjë për problemin."

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Etiketë për përgjigjen e studentit"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Etiketë për zonën e tekstit që përmban përgjigjen e studentit"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Etiketë për përgjigjen e ekspertit"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Etiketë për përgjigjen e 'ekspertit'"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Etiketë për butonin Dërgo"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Etiketë për butonin e dërgimit"

#: templates/edit.html:56
msgid "Definition"
msgstr "Përkufizimi"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "Përkufizimi XML për pyetjen dhe përgjigjen e ekspertit"

#: templates/edit.html:69
msgid "Save"
msgstr "Ruaj"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Anulo"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Sugjerim ({number} nga {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Ju keni përdorur {count_attempts} të paraqitjes {max_attempts}"
msgstr[1] "Ju keni përdorur {count_attempts} të parashtrimeve {max_attempts}"

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} pikë e mundshme"
msgstr[1] "{weight} pikë të mundshme"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} pikë"
msgstr[1] "/{weight} pikë"
