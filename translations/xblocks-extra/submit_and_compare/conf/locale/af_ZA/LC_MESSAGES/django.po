#: templates/edit.html:8
msgid "Display Name"
msgstr "Vertoon Naam"

#: templates/edit.html:16
msgid "Weight"
msgstr "Gewig"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Dit ken &#39;n heelgetalwaarde toe wat die gewig van hierdie probleem "
"verteenwoordig"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Maximale Pogings"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Dit ken 'n heelgetalwaarde toe wat die maksimum aantal kere verteenwoordig "
"wat 'n student die probleem kan probeer"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Etiket vir Studentantwoord"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Etiket vir die teksarea wat die student se antwoord bevat"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Etiket vir Deskundige Antwoord"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Etiket vir die 'deskundige' antwoord"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Etiket vir Stuurknoppie"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Etiket vir die stuurknoppie"

#: templates/edit.html:56
msgid "Definition"
msgstr "Definisie"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "Die XML-definisie vir die vraag en kundige antwoord"

#: templates/edit.html:69
msgid "Save"
msgstr "Stoor"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Kanselleer"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Wenk ({number} van {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Jy het {count_attempts} van {max_attempts} indiening gebruik"
msgstr[1] "Jy {count_attempts} van {max_attempts} voorleggings gebruik"

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} punt moontlik"
msgstr[1] "{weight} punte moontlik"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} punt"
msgstr[1] "/{weight} punte"
