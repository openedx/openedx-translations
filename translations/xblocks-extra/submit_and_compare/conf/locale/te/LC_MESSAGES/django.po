#: templates/edit.html:8
msgid "Display Name"
msgstr "ప్రదర్శన పేరు"

#: templates/edit.html:16
msgid "Weight"
msgstr "బరువు"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "ఇది ఈ సమస్య యొక్క బరువును సూచించే పూర్ణాంక విలువను కేటాయిస్తుంది"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "గరిష్ట ప్రయత్నాలు"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"ఇది ఒక విద్యార్థి సమస్యను ప్రయత్నించగల గరిష్ట సంఖ్యను సూచించే పూర్ణాంక "
"విలువను కేటాయిస్తుంది"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "విద్యార్థి సమాధానం కోసం లేబుల్"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "విద్యార్థి సమాధానం ఉన్న టెక్స్ట్ ఏరియా కోసం లేబుల్"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "నిపుణుల సమాధానం కోసం లేబుల్"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "నిపుణుల సమాధానం కోసం లేబుల్"

#: templates/edit.html:56
msgid "Definition"
msgstr "నిర్వచనం"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "ప్రశ్న మరియు నిపుణుల సమాధానం కోసం XML నిర్వచనం"

#: templates/edit.html:69
msgid "Save"
msgstr "సేవ్ చేయండి"

#: templates/edit.html:72
msgid "Cancel"
msgstr "రద్దు"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "సూచన ({number} లో {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "మీరు {count_attempts} సమర్పణలను {max_attempts} లో ఉపయోగించారు"
msgstr[1] "మీరు {max_attempts} సమర్పణలలో {count_attempts} ఉపయోగించారు"

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} పాయింట్ సాధ్యం"
msgstr[1] "{weight} పాయింట్లు సాధ్యమే"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} పాయింట్"
msgstr[1] "/{weight} పాయింట్లు"
