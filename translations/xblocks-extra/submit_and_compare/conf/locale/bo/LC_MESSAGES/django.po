#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] ""
"ཁྱོད་ཀྱིས་ {max_attempts} ཡི་འབུལ་བ {count_attempts} བེད་སྤྱོད་བྱས།"

#: views.py:289
#, python-brace-format
