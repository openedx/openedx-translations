#: templates/edit.html:8
msgid "Display Name"
msgstr "שם לתצוגה"

#: templates/edit.html:16
msgid "Weight"
msgstr "משקל"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "זה מקצה ערך שלם המייצג את המשקל של בעיה זו"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "מספר ניסיונות מקסימלי"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"זה מקצה ערך שלם המייצג את המספר המרבי של פעמים שתלמיד יכול לנסות את הבעיה"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "תווית לתשובת תלמיד"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "תווית עבור תיבת ה**טקסט** המכילה את **תשובת** התלמיד"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "תווית לתשובת מומחה"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "תווית לתשובת ה'מומחה'"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "תווית עבור כפתור שליחה"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "תווית עבור כפתור השליחה"

#: templates/edit.html:56
msgid "Definition"
msgstr "הַגדָרָה"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "הגדרת ה-XML לשאלה ולתשובת המומחה"

#: templates/edit.html:69
msgid "Save"
msgstr "שמור"

#: templates/edit.html:72
msgid "Cancel"
msgstr "בטל"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "רמז ({number} מתוך {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "אתה משתמש {count_attempts} של {max_attempts} הגשות"
msgstr[1] "השתמשת ב- {count_attempts} מתוך {max_attempts} הגשות."
msgstr[2] "השתמשת ב- {count_attempts} מתוך {max_attempts} הגשות."

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "נקודת {weight} אפשרית"
msgstr[1] "{weight} נקודות אפשריות"
msgstr[2] "{weight} נקודות אפשריות"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} נקודה"
msgstr[1] "/{weight} נקודות"
msgstr[2] "/{weight} נקודות"
