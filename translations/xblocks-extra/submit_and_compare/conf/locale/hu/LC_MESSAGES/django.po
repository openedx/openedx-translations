#: templates/edit.html:8
msgid "Display Name"
msgstr "Megjelenített név"

#: templates/edit.html:16
msgid "Weight"
msgstr "Súlyozás"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Ez egy egész számértéket rendel ehhez a probléma súlyának reprezentálásához."

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Ez egy egész számértéket rendel, amely a maximális számú próbálkozást "
"jelöli, ahányszor egy diák megpróbálhatja megoldani a feladatot"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Szakértői Válasz címkéje"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Címke a „szakértői” válaszhoz"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Beküldés gomb felirata"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Címke a beküldés gombhoz"

#: templates/edit.html:56
msgid "Definition"
msgstr "Meghatározás"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "A kérdés és a szakértői válasz XML definíciója"

#: templates/edit.html:69
msgid "Save"
msgstr "Mentés"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Megszakít"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Tipp ({number} / {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] ""
"Felhasználtad a(z) {count_attempts} a(z) {max_attempts} beküldésből."
msgstr[1] ""
"Már {count_attempts} lehetőséget felhasználtál a {max_attempts} "
"lehetőségből."

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} pont lehetséges"
msgstr[1] "{weight} lehetséges pont"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} pont"
