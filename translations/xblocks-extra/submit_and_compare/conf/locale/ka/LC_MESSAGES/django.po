#: templates/edit.html:8
msgid "Display Name"
msgstr "ხილვადი სახელი"

#: templates/edit.html:16
msgid "Weight"
msgstr "წონა"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "მიანიჭებს მთელ რიცხვს, რომელიც წარმოადგენს ამ დავალების წონას"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"ეს ანიჭებს მთელ რიცხვს, რომელიც წარმოადგენს მაქსიმალურ რაოდენობას, რამდენჯერ"
" შეუძლია სტუდენტს სცადოს დავალების ამოხსნა"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "მოსწავლის პასუხის ეტიკეტი"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "ექსპერტის პასუხის ეტიკეტი"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "ექსპერტის პასუხის ეტიკეტი"

#: templates/edit.html:56
msgid "Definition"
msgstr "განმარტება"

#: templates/edit.html:69
msgid "Save"
msgstr "შენახვა"

#: templates/edit.html:72
msgid "Cancel"
msgstr "გაუქმება"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "მინიშნება ({number} {total}-დან): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "თქვენ გამოიყენეთ {count_attempts} {max_attempts} TXEND."
msgstr[1] ""
"თქვენ გამოიყენეთ {count_attempts} წარდგენის მაქსიმუმ რაოდენობიდან "
"{max_attempts} "

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} წერტილი შესაძლებელია"
msgstr[1] "{weight} შესაძლო ქულა"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} ქულა"
msgstr[1] "/{weight} ქულა"
