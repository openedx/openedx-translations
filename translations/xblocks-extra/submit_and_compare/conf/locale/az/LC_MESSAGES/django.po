#: templates/edit.html:69
msgid "Save"
msgstr "Yaddaşda saxlayın"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Ləğv edin"

#: views.py:225
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "İpucu ({number} / {total}): {hint}"

#: views.py:246
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Siz {max_attempts} göndərişdən {count_attempts} istifadə etmisiniz"
msgstr[1] "Siz {max_attempts} göndərişdən {count_attempts} istifadə etmisiniz"

#: views.py:289
#, python-brace-format
