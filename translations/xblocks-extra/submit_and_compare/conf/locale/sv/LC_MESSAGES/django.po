msgstr[0] "Du har använt {count_attempts} av {max_attempts} inlämningar"
msgstr[1] "Du har använt {count_attempts} av {max_attempts} inskickningar."

#: views.py:289
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} poäng möjligt"
msgstr[1] "{weight} möjliga poäng"

#: views.py:301
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
