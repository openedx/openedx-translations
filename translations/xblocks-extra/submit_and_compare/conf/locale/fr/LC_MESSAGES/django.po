#: templates/edit.html:8
msgid "Display Name"
msgstr "Nom d'affichage"

#: templates/edit.html:16
msgid "Weight"
msgstr "Poids"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Ceci assigne une valeur entière représentant le poids de cet exercice"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Nombre maximal de tentatives"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Ceci attribue une valeur entière représentant le nombre maximal de "
"tentatives qu'un étudiant peut faire pour résoudre le problème."

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Étiquette pour la réponse de l'étudiant"

#: templates/edit.html:35
