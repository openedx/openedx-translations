#: models.py:25
msgid "Display Name"
msgstr "Megjelenített név"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "Ez az XBlock megjelenítési neve"

#: models.py:32
msgid "Image URL"
msgstr "Kép URL-címe"

#: models.py:40
msgid "This is the location of the full-screen image to be displayed."
msgstr "Ez a megjelenítendő teljes képernyős kép helye."

#: models.py:44
msgid "Thumbnail URL"
msgstr "Bélyegkép URL"

#: models.py:48
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr ""
"Ez a (nem kötelező) helye egy bélyegképnek, amely megjelenik, mielőtt a fő "
"kép nagyításra kerül."

#: models.py:54
msgid "Description"
msgstr "Leírás"

#: models.py:57
msgid "Description text, displayed to screen readers"
msgstr "Leíró szöveg, amelyet a képernyőolvasók jelenítenek meg"

#: models.py:62
msgid "Alt Text"
msgstr "Alternatív szöveg"

#: models.py:65
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr ""
"Ez a mező lehetővé teszi, hogy alternatív vagy leíró szöveget adjon meg a "
"képéhez."

#: templates/view.html:15
msgid "Fullscreen"
msgstr "Teljes képernyő"

#: templates/view.html:25
msgid "Zoom In"
msgstr "Nagyítás"

#: templates/view.html:29
msgid "Close"
msgstr "Bezár"
