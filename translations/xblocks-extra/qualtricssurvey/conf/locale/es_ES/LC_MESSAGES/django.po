#: models.py:23
msgid "Display Name:"
msgstr "Nombre para mostrar:"

#: models.py:26
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr ""
"Este nombre aparece en la navegación horizontal en la parte superior de la "
"página."

#: models.py:29
msgid "Link Text:"
msgstr "Texto del Enlace:"

#: models.py:32
msgid "This is the text that will link to your survey."
msgstr "Este es el texto que se enlazará a su encuesta."

#: models.py:35
msgid "Message:"
msgstr "Mensaje:"

#: models.py:38
msgid "This is the text that will be displayed above the link to your survey."
msgstr "Este es el Texto que se mostrará encima del enlace a su encuesta."

#: models.py:41
msgid "Param Name:"
msgstr "Nombre del parámetro:"

#: models.py:44
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"Este es el nombre del parámetro Identificador de usuario en la url. Si está "
"en blanco, el Identificador de usuario se omite en la url."

#: models.py:47
msgid "Survey ID:"
msgstr "ID de la encuesta:"

#: models.py:51
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"Este es el Identificador que utiliza Qualtrics para la encuesta, que puede "
"incluir números y letras, y debe ingresarse en el siguiente formato: "
"SV_###############"

#: models.py:57
msgid "Your University:"
msgstr "Tu universidad:"

#: models.py:60
msgid "This is the name of your university."
msgstr "Tu universidad se llama así."
