#: models.py:23
msgid "Display Name:"
msgstr "Vertoonnaam:"

#: models.py:26
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "Hierdie naam verskyn in die horisontale navigasie boaan die bladsy."

#: models.py:29
msgid "Link Text:"
msgstr "Skakelteks:"

#: models.py:32
msgid "This is the text that will link to your survey."
msgstr "Dit is die teks wat na jou opname sal skakel."

#: models.py:35
msgid "Message:"
msgstr "Boodskap:"

#: models.py:38
msgid "This is the text that will be displayed above the link to your survey."
msgstr "Dit is die teks wat bo die skakel na jou opname vertoon sal word."

#: models.py:41
msgid "Param Name:"
msgstr "Param Naam:"

#: models.py:44
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"Dit is die naam vir die User ID-parameter in die url. Indien leeg, word "
"gebruiker-ID van die url weggelaat."

#: models.py:47
msgid "Survey ID:"
msgstr "Opname ID:"

#: models.py:51
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"Dit is die ID wat Qualtrics vir die opname gebruik, wat syfers en letters "
"kan insluit en moet in die volgende formaat ingevoer word: SV_##############"

#: models.py:57
msgid "Your University:"
msgstr "Jou Universiteit:"

#: models.py:60
msgid "This is the name of your university."
msgstr "Dit is die naam van jou universiteit."
