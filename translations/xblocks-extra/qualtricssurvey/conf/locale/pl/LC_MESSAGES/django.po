#: models.py:23
msgid "Display Name:"
msgstr "Wyświetlana nazwa:"

#: models.py:26
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "Nazwa ta pojawia się w poziomej nawigacji u góry strony."

#: models.py:29
msgid "Link Text:"
msgstr "Tekst linku:"

#: models.py:32
msgid "This is the text that will link to your survey."
msgstr "To jest tekst, który będzie linkiem do Twojej ankiety."

#: models.py:35
msgid "Message:"
msgstr "Wiadomość:"

#: models.py:38
msgid "This is the text that will be displayed above the link to your survey."
msgstr "To jest tekst, który wyświetli się nad linkiem do Twojej ankiety."

#: models.py:41
msgid "Param Name:"
msgstr "Nazwa parametru:"

#: models.py:44
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"To jest nazwa parametru User ID w adresie URL. Jeśli puste, identyfikator "
"użytkownika zostanie pominięty w adresie URL."

#: models.py:47
msgid "Survey ID:"
msgstr "Identyfikator ankiety:"

#: models.py:51
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"Jest to identyfikator używany przez Qualtrics w ankiecie, który może "
"zawierać cyfry i litery i powinien być wprowadzony w następującym formacie: "
"SV_################"

#: models.py:57
msgid "Your University:"
msgstr "Twój uniwersytet:"

#: models.py:60
msgid "This is the name of your university."
msgstr "To jest nazwa twojej uczelni."
