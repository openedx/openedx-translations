#: models.py:23
msgid "Display Name:"
msgstr "Nome de exibição:"

#: models.py:26
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "Este nome aparece na navegação horizontal no topo da página."

#: models.py:29
msgid "Link Text:"
msgstr "Texto do Link:"

#: models.py:32
msgid "This is the text that will link to your survey."
msgstr "Este é o texto que vinculará à sua pesquisa."

#: models.py:35
msgid "Message:"
msgstr "Mensagem:"

#: models.py:38
msgid "This is the text that will be displayed above the link to your survey."
msgstr "Este é o texto que será exibido acima do link da sua pesquisa."

#: models.py:41
msgid "Param Name:"
msgstr "Nome do parâmetro:"

#: models.py:44
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"Este é o nome do parâmetro Identificação do usuário na url. Se estiver em "
"branco, a Identificação do usuário será omitida da url."

#: models.py:47
msgid "Survey ID:"
msgstr "ID da pesquisa:"

#: models.py:51
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"Esta é a Identificação que a Qualtrics usa para a pesquisa, que pode incluir"
" números e letras, e deve ser inserida no seguinte formato: "
"SV_###############"

#: models.py:57
msgid "Your University:"
msgstr "Sua universidade:"

#: models.py:60
msgid "This is the name of your university."
msgstr "Este é o nome da sua universidade."
