#: models.py:38
msgid "Display Correctness?"
msgstr "Gösterim Doğruluğu?"

#: models.py:40
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"Bu, öğrenci yanıtını girdikten sonra gösterge simgesinin görüntülenip "
"görüntülenmeyeceğini belirten bir işarettir"

#: models.py:48
msgid "Display Other Student Responses"
msgstr "Diğer Öğrenci Yanıtlarını Görüntüle"

#: models.py:49
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Bu, öğrenci yanıtını gönderdikten sonra diğer öğrencilerin yanıtlarını "
"gösterecektir."

#: models.py:56
msgid "System selected answers to give to students"
msgstr "Öğrencilere verilecek sistem tarafından seçilen yanıtlar"

#: models.py:59
msgid "Display Name"
msgstr "Görünen Ad"

#: models.py:60
msgid "This is the title for this question type"
msgstr "Bu, bu soru türünün başlığıdır"

#: models.py:65
msgid "Full-Credit Key Phrases"
msgstr "Tam Kredi Anahtar İfadeleri"

#: models.py:67
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Bu, öğrencinin cevabının tam puan alması için bir tanesinin mevcut olması "
"gereken kelime veya kelime öbeklerinin bir listesidir."

#: models.py:75
msgid "Half-Credit Key Phrases"
msgstr "Yarı Kredili Anahtar İfadeler"

#: models.py:77
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Bu, öğrencinin cevabının yarım kredi alması için bunlardan birinin mevcut "
"olması gereken kelime veya kelime öbeklerinin bir listesidir."

#: models.py:85
msgid "Maximum Number of Attempts"
msgstr "Maksimum Deneme Sayısı"

#: models.py:86
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr "Bu, bir öğrencinin problemi denemesine izin verilen maksimum sayıdır"

#: models.py:92
msgid "Maximum Word Count"
msgstr "Maksimum Kelime Sayısı"

#: models.py:93
msgid "This is the maximum number of words allowed for this question"
msgstr "Bu, bu soru için izin verilen maksimum kelime sayısıdır"

#: models.py:99
msgid "Minimum Word Count"
msgstr "Minimum Kelime Sayısı"

#: models.py:100
msgid "This is the minimum number of words required for this question"
msgstr "Bu soru için gereken minimum kelime sayısı budur"

#: models.py:106
msgid "Prompt"
msgstr "Sufle"

#: models.py:107
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"Bu, öğrencilerin yanıtlarını girmeleri istendiğinde görecekleri istemcidir"

#: models.py:113
msgid "Submission Received Message"
msgstr "Gönderim Alındı Mesajı"

#: models.py:114
msgid "This is the message students will see upon submitting their response"
msgstr "Bu, öğrencilerin yanıtlarını gönderdikten sonra görecekleri mesajdır"

#: models.py:119
msgid "Weight"
msgstr "Ağırlık"

#: models.py:120
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Bu, bu sorunun ağırlığını temsil eden bir tamsayı değeri atar"

#: models.py:126
msgid "Draft Received Message"
msgstr "Taslak Alınan Mesaj"

#: models.py:127
msgid "This is the message students will see upon submitting a draft response"
msgstr "Bu, öğrencilerin taslak yanıt gönderdikten sonra görecekleri mesajdır"

#: templates/view.html:16
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Yanıtlarını gönderdikten sonra yanıtımın diğer öğrenciler tarafından "
"görülebilmesine izin ver"

#: templates/view.html:23 templates/view.html:26
msgid "Checking..."
msgstr "Kontrol ediliyor..."

#: templates/view.html:23 templates/view.html:24
msgid "Submit"
msgstr "Yükle"

#: templates/view.html:26 templates/view.html:27
msgid "Save"
msgstr "Kaydet"

#: templates/view.html:36
msgid "Hide"
msgstr "Gizle"

#: templates/view.html:37
msgid "Show"
msgstr "Göster"

#: templates/view.html:38
msgid "peer responses"
msgstr "akran yanıtları"

#: templates/view.html:40
msgid "Submissions by others"
msgstr "Başkalarının gönderileri"

#: templates/view.html:41 templates/view.html:45
msgid "No responses to show at this time"
msgstr "Şu anda gösterilecek yanıt yok"

#: views.py:127
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} puan mümkün"
msgstr[1] "{weight} puan mümkün"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} noktası"
msgstr[1] "{score_string} /{weight} puan"

#: views.py:146
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] ""
"{max_attempts} gönderim hakkınızdan {count_attempts} tanesini kullandınız"
msgstr[1] ""
"{max_attempts} gönderim hakkınızdan {count_attempts} tanesini kullandınız"

#: views.py:170
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "Yanıtınız {min} ile {max} arasında kelime içermelidir."
msgstr[1] "Yanıtınız {min} ile {max} arasında kelime içermelidir."

#: views.py:256
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Geçersiz Kelime Sayısı. {word_count_message}"
