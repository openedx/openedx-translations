#: models.py:38
msgid "Display Correctness?"
msgstr "გაჩვენოთ სწორია თუ არა?"

#: models.py:40
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"ეს არის დროშა, რომელიც მიუთითებს, უნდა გამოჩნდეს თუ არა ინდიკატორის ხატულა "
"სტუდენტის მიერ პასუხის შეყვანის შემდეგ."

#: models.py:48
msgid "Display Other Student Responses"
msgstr "სხვა სტუდენტების პასუხების ჩვენება"

#: models.py:49
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr "აჩვენებს სტუდენტს სხვათა პასუხებს მას შემდეგ, რაც საკუთარს გაგზავნის."

#: models.py:56
msgid "System selected answers to give to students"
msgstr "სისტემის მიერ შერჩეული პასუხები სტუდენტებისთვის მისაცემად"

#: models.py:59
msgid "Display Name"
msgstr "ხილვადი სახელი"

#: models.py:60
msgid "This is the title for this question type"
msgstr "ეს არის ამ ტიპის კითხვის სათაური"

#: models.py:65
msgid "Full-Credit Key Phrases"
msgstr "სრული კრედიტის მქონე ძირითადი ფრაზები"

#: models.py:67
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"ეს არის სიტყვების ან ფრაზების სია, რომელთაგან ერთ-ერთი უნდა იყოს "
"წარმოდგენილი, რათა სტუდენტის პასუხმა სრული ქულა მიიღოს."

#: models.py:75
msgid "Half-Credit Key Phrases"
msgstr "ნახევრად კრედიტიანი საკვანძო ფრაზები"

#: models.py:77
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"ეს არის სიტყვების ან ფრაზების სია, რომელთაგან ერთ-ერთი უნდა იყოს "
"წარმოდგენილი, რათა სტუდენტმა მიიღოს ნახევარი კრედიტი."

#: models.py:85
msgid "Maximum Number of Attempts"
msgstr "მცდელობების მაქსიმალური რაოდენობა"

#: models.py:86
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"მაქსიმალური რაოდენობა, რამდენჯერაც სტუდენტს შეუძლია სცადოს ეს დავალება."

#: models.py:92
msgid "Maximum Word Count"
msgstr "სიტყვების მაქსიმალური რაოდენობა"

#: models.py:93
msgid "This is the maximum number of words allowed for this question"
msgstr "ეს ამ კითხვისთვის დაშვებული სიტყვების მაქსიმალური რაოდენობაა"

#: models.py:99
msgid "Minimum Word Count"
msgstr "მინიმალური სიტყვების რაოდენობა"

#: models.py:100
msgid "This is the minimum number of words required for this question"
msgstr "ეს არის ამ კითხვისთვის საჭირო სიტყვების მინიმალური რაოდენობა"

#: models.py:106
msgid "Prompt"
msgstr "მინიშნება"

#: models.py:107
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"ეს არის შეტყობინება პასუხის შეტანის თხოვნის შესახებ, რომელსაც სტუდენტები "
"დაინახავენ"

#: models.py:113
msgid "Submission Received Message"
msgstr "წარდგენის მიღების შეტყობინება"

#: models.py:114
msgid "This is the message students will see upon submitting their response"
msgstr ""
"ეს არის შეტყობინება, რომელსაც სტუდენტები დაინახავენ პასუხის გაგზავნის შემდეგ"

#: models.py:119
msgid "Weight"
msgstr "წონა"

#: models.py:120
msgid "This assigns an integer value representing the weight of this problem"
msgstr "მიანიჭებს მთელ რიცხვს, რომელიც წარმოადგენს ამ დავალების წონას"

#: models.py:126
msgid "Draft Received Message"
msgstr "მიღებული შეტყობინების სამუშაო ვერსია"

#: models.py:127
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"ეს არის შეტყობინება, რომელსაც სტუდენტები დაინახავენ პასუხების სამუშაო "
"ვერსიის წარდგენისას"

#: templates/view.html:16
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr "ჩემი პასუხის გაგზავნის შემდეგ, აჩვენე ისინი ჩემს თანაკურსელებს"

#: templates/view.html:23 templates/view.html:26
msgid "Checking..."
msgstr "მიმდინარეობს შემოწმება..."

#: templates/view.html:23 templates/view.html:24
msgid "Submit"
msgstr "გაგზავნა"

#: templates/view.html:26 templates/view.html:27
msgid "Save"
msgstr "შენახვა"

#: templates/view.html:36
msgid "Hide"
msgstr "დამალვა"

#: templates/view.html:37
msgid "Show"
msgstr "ჩვენება"

#: templates/view.html:38
msgid "peer responses"
msgstr "თანაკურსელების პასუხები"

#: templates/view.html:40
msgid "Submissions by others"
msgstr "სხვების მიერ წარდგენილი"

#: templates/view.html:41 templates/view.html:45
msgid "No responses to show at this time"
msgstr "ამ დროისთვის პასუხები არ არის ხილული"

#: views.py:127
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} წერტილი შესაძლებელია"
msgstr[1] "{weight} შესაძლო ქულა"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string} / {weight} წერტილი"
msgstr[1] "{score_string} / {weight} ქულა"

#: views.py:146
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "თქვენ გამოიყენეთ {count_attempts} {max_attempts} TXEND."
msgstr[1] ""
"თქვენ გამოიყენეთ {count_attempts} წარდგენის მაქსიმუმ რაოდენობიდან "
"{max_attempts} "

#: views.py:170
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "თქვენი პასუხი უნდა იყოს {min} და {max} ს შორის."
msgstr[1] "თქვენი პასუხი უნდა იყოს {min} და {max} სიტყვებს შორის."

#: views.py:256
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "არასწორი სიტყვების რაოდენობა. {word_count_message}"
