#: models.py:38
msgid "Display Correctness?"
msgstr "แสดงความถูกต้อง?"

#: models.py:40
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"นี่คือธงที่ระบุว่าควรแสดงไอคอนตัวบ่งชี้หลังจากที่นักเรียนป้อนคำตอบแล้วหรือไม่"

#: models.py:48
msgid "Display Other Student Responses"
msgstr "แสดงคำตอบของนักเรียนคนอื่นๆ"

#: models.py:49
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"นี่จะแสดงคำตอบของนักเรียนคนอื่นๆ ให้กับนักเรียนหลังจากที่พวกเขาส่งคำตอบแล้ว"

#: models.py:56
msgid "System selected answers to give to students"
msgstr "ระบบได้เลือกคำตอบมามอบให้กับนักเรียน"

#: models.py:59
msgid "Display Name"
msgstr "ชื่อที่แสดง"

#: models.py:60
msgid "This is the title for this question type"
msgstr "นี่คือชื่อของคำถามประเภทนี้"

#: models.py:65
msgid "Full-Credit Key Phrases"
msgstr "วลีสำคัญแบบเต็มเครดิต"

#: models.py:67
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"นี่คือรายการคำหรือวลีที่ต้องแสดงอย่างใดอย่างหนึ่งเพื่อให้คำตอบของนักเรียนได้รับเครดิตเต็ม"

#: models.py:75
msgid "Half-Credit Key Phrases"
msgstr "วลีสำคัญครึ่งเครดิต"

#: models.py:77
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"นี่คือรายการคำหรือวลี "
"ซึ่งต้องมีรายการใดรายการหนึ่งเพื่อให้คำตอบของนักเรียนได้รับครึ่งหนึ่งเครดิต"

#: models.py:85
msgid "Maximum Number of Attempts"
msgstr "จำนวนความพยายามสูงสุด"

#: models.py:86
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr "นี่คือจำนวนครั้งสูงสุดที่นักเรียนจะได้รับอนุญาตให้พยายามแก้ปัญหา"

#: models.py:92
msgid "Maximum Word Count"
msgstr "จำนวนคำสูงสุด"

#: models.py:93
msgid "This is the maximum number of words allowed for this question"
msgstr "นี่คือจำนวนคำสูงสุดที่อนุญาตสำหรับคำถามนี้"

#: models.py:99
msgid "Minimum Word Count"
msgstr "จำนวนคำขั้นต่ำ"

#: models.py:100
msgid "This is the minimum number of words required for this question"
msgstr "นี่คือจำนวนคำขั้นต่ำที่จำเป็นสำหรับคำถามนี้"

#: models.py:106
msgid "Prompt"
msgstr "แจ้ง"

#: models.py:107
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr "นี่คือข้อความที่นักเรียนจะเห็นเมื่อถูกขอให้ป้อนคำตอบ"

#: models.py:113
msgid "Submission Received Message"
msgstr "ข้อความที่ได้รับการส่ง"

#: models.py:114
msgid "This is the message students will see upon submitting their response"
msgstr "นี่คือข้อความที่นักเรียนจะเห็นเมื่อส่งคำตอบ"

#: models.py:119
msgid "Weight"
msgstr "น้ำหนัก"

#: models.py:120
msgid "This assigns an integer value representing the weight of this problem"
msgstr "ซึ่งจะกำหนดค่าจำนวนเต็มที่แสดงถึงน้ำหนักของปัญหานี้"

#: models.py:126
msgid "Draft Received Message"
msgstr "ข้อความที่ได้รับฉบับร่าง"

#: models.py:127
msgid "This is the message students will see upon submitting a draft response"
msgstr "นี่คือข้อความที่นักเรียนจะเห็นเมื่อส่งคำตอบฉบับร่าง"

#: templates/view.html:16
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr "อนุญาตให้ผู้เรียนคนอื่นมองเห็นคำตอบของฉันได้หลังจากส่งคำตอบแล้ว"

#: templates/view.html:23 templates/view.html:26
msgid "Checking..."
msgstr "กำลังตรวจสอบ..."

#: templates/view.html:23 templates/view.html:24
msgid "Submit"
msgstr "ส่ง"

#: templates/view.html:26 templates/view.html:27
msgid "Save"
msgstr "บันทึก"

#: templates/view.html:36
msgid "Hide"
msgstr "ซ่อน"

#: templates/view.html:37
msgid "Show"
msgstr "แสดง"

#: templates/view.html:38
msgid "peer responses"
msgstr "การตอบสนองของเพื่อน"

#: templates/view.html:40
msgid "Submissions by others"
msgstr "การส่งผลงานโดยผู้อื่น"

#: templates/view.html:41 templates/view.html:45
msgid "No responses to show at this time"
msgstr "ไม่มีคำตอบที่จะแสดงในขณะนี้"

#: views.py:127
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} คะแนนที่เป็นไปได้"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string} / {weight} คะแนน"

#: views.py:146
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "คุณได้ใช้การส่ง {count_attempts} จาก {max_attempts} แล้ว"

#: views.py:170
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "คำตอบของคุณจะต้องอยู่ระหว่างคำ {min} ถึง {max}"

#: views.py:256
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "จำนวนคำไม่ถูกต้อง {word_count_message}"
