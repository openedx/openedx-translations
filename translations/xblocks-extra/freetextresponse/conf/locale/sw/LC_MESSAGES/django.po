#: models.py:38
msgid "Display Correctness?"
msgstr "Onyesha Usahihi?"

#: models.py:40
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"Hii ni bendera inayoonyesha ikiwa ikoni ya kiashirio inapaswa kuonyeshwa "
"baada ya mwanafunzi kuingiza jibu lake"

#: models.py:48
msgid "Display Other Student Responses"
msgstr "Onyesha Majibu Mengine ya Wanafunzi"

#: models.py:49
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Hii itaonyesha majibu mengine ya wanafunzi kwa mwanafunzi baada ya "
"kuwasilisha majibu yao."

#: models.py:56
msgid "System selected answers to give to students"
msgstr "Mfumo uliyochagua majibu ya kuwapa wanafunzi"

#: models.py:59
msgid "Display Name"
msgstr "Jina la Kuonyesha"

#: models.py:60
msgid "This is the title for this question type"
msgstr "Hiki ndicho kichwa cha aina hii ya swali"

#: models.py:65
msgid "Full-Credit Key Phrases"
msgstr "Maneno muhimu ya Mkopo kamili"

#: models.py:67
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Hii ni orodha ya maneno au vifungu vya maneno, ambavyo mojawapo ni lazima "
"liwepo ili jibu la mwanafunzi lipate salio kamili"

#: models.py:75
msgid "Half-Credit Key Phrases"
msgstr "Maneno Muhimu ya Nusu ya Mkopo"

#: models.py:77
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Hii ni orodha ya maneno au vifungu vya maneno, ambavyo mojawapo ni lazima "
"liwepo ili jibu la mwanafunzi lipate nusu ya mkopo"

#: models.py:85
msgid "Maximum Number of Attempts"
msgstr "Idadi ya Juu ya Majaribio"

#: models.py:86
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"Hii ndiyo idadi ya juu zaidi ya mara ambazo mwanafunzi anaruhusiwa kujaribu "
"tatizo"

#: models.py:92
msgid "Maximum Word Count"
msgstr "Upeo wa Hesabu ya Neno"

#: models.py:93
msgid "This is the maximum number of words allowed for this question"
msgstr "Hii ndiyo idadi ya juu zaidi ya maneno inayoruhusiwa kwa swali hili"

#: models.py:99
msgid "Minimum Word Count"
msgstr "Kiwango cha chini cha Hesabu ya Neno"

#: models.py:100
msgid "This is the minimum number of words required for this question"
msgstr ""
"Hii ndiyo idadi ya chini kabisa ya maneno inayohitajika kwa swali hili"

#: models.py:106
msgid "Prompt"
msgstr "Haraka"

#: models.py:107
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"Hili ndilo swali ambalo wanafunzi wataona watakapoulizwa kuandika majibu yao"

#: models.py:113
msgid "Submission Received Message"
msgstr "Ujumbe Umepokelewa"

#: models.py:114
msgid "This is the message students will see upon submitting their response"
msgstr "Huu ndio ujumbe ambao wanafunzi wataona wanapowasilisha majibu yao"

#: models.py:119
msgid "Weight"
msgstr "Uzito"

#: models.py:120
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Hii inapeana thamani kamili inayowakilisha uzito wa tatizo hili"

#: models.py:126
msgid "Draft Received Message"
msgstr "Rasimu ya Ujumbe Umepokelewa"

#: models.py:127
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"Huu ndio ujumbe ambao wanafunzi wataona wanapowasilisha rasimu ya jibu"

#: templates/view.html:16
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Ruhusu majibu yangu yaweze kuonekana na wanafunzi wengine baada ya "
"kuwasilisha majibu yao"

#: templates/view.html:23 templates/view.html:26
msgid "Checking..."
msgstr "Inaangalia..."

#: templates/view.html:23 templates/view.html:24
msgid "Submit"
msgstr "Wasilisha"

#: templates/view.html:26 templates/view.html:27
msgid "Save"
msgstr "Hifadhi"

#: templates/view.html:36
msgid "Hide"
msgstr "Ficha"

#: templates/view.html:37
msgid "Show"
msgstr "Onyesha"

#: templates/view.html:38
msgid "peer responses"
msgstr "majibu ya rika"

#: templates/view.html:40
msgid "Submissions by others"
msgstr "Mawasilisho na wengine"

#: templates/view.html:41 templates/view.html:45
msgid "No responses to show at this time"
msgstr "Hakuna majibu ya kuonyesha kwa wakati huu"

#: views.py:127
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} point inawezekana"
msgstr[1] "{weight} point zinawezekana"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string} / {weight} uhakika"
msgstr[1] "{score_string} / {weight} point"

#: views.py:146
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Umekutumia {count_attempts} ya {max_attempts} wasilisho"
msgstr[1] "Umetumia {count_attempts} ya mawasilisho {max_attempts}"

#: views.py:170
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "Jibu lako lazima liwe kati ya {min} na {max} neno."
msgstr[1] "Jibu lako lazima liwe kati ya maneno {min} na {max}."

#: views.py:256
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Hesabu ya Maneno Batili. {word_count_message}"
