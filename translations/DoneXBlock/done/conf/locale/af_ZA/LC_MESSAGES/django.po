#: done.py:39
msgid "Is the student done?"
msgstr "Is die student klaar?"

#: done.py:45
msgid "Align left/right/center"
msgstr "Belyn links/regs/middel"

#: done.py:132
msgid "Display name"
msgstr "Vertoon naam"

#: done.py:137
msgid ""
"ISO-8601 formatted string representing the start date of this assignment. We"
" ignore this."
msgstr ""
"ISO-8601-geformateerde string wat die begindatum van hierdie werkopdrag "
"verteenwoordig. Ons ignoreer dit."

#: done.py:142
msgid ""
"ISO-8601 formatted string representing the due date of this assignment. We "
"ignore this."
msgstr ""
"ISO-8601-geformateerde string wat die sperdatum van hierdie werkopdrag "
"verteenwoordig. Ons ignoreer dit."

#: done.py:146
msgid "Problem Weight"
msgstr "Probleem Gewig"

#: done.py:148
msgid ""
"Defines the number of points each problem is worth. If the value is not set,"
" the problem is worth the sum of the option point values."
msgstr ""
"Definieer die aantal punte wat elke probleem werd is. As die waarde nie "
"gestel is nie, is die probleem die som van die opsiepuntwaardes werd."

