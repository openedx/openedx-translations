#: models.py:24
msgid "Display Name:"
msgstr "საჩვენებელი სახელი:"

#: models.py:28
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "სახელი გამოჩნდება გვერდის ზედა ნაწილის ჰორიზონტალური ნავიგაციაზე."

#: models.py:33
msgid "Link Text:"
msgstr "ბმულის ტექსტი:"

#: models.py:36
msgid "This is the text that will link to your survey."
msgstr "ეს არის ტექსტი, რომელიც თქვენს გამოკითხვასთან იქნება დაკავშირებული."

#: models.py:39
msgid "Message:"
msgstr "შეტყობინება:"

#: models.py:43
msgid "This is the text that will be displayed above the link to your survey."
msgstr "ეს არის ტექსტი, რომელიც გამოჩნდება თქვენი გამოკითხვის ბმულის ზემოთ."

#: models.py:48
msgid "Param Name:"
msgstr "პარამეტრის სახელი:"

#: models.py:52
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"ეს არის URL-ში მომხმარებლის ID პარამეტრის სახელი. თუ ცარიელია, მომხმარებლის "
"ID URL-დან გამოტოვებულია."

#: models.py:57
msgid "Survey ID:"
msgstr "გამოკითხვის ID:"

#: models.py:61
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"ეს არის ID, რომელსაც Qualtrics იყენებს გამოკითხვისთვის, რომელიც შეიძლება "
"შეიცავდეს ციფრებს და ასოებს და უნდა შეიყვანოთ შემდეგი ფორმატით: "
"SV_#################"

#: models.py:67
msgid "Your University:"
msgstr "თქვენი უნივერსიტეტი:"

#: models.py:70
msgid "This is the name of your university."
msgstr "ეს თქვენი უნივერსიტეტის სახელია."
